## Tests
##############################################################################

# Smoke test: invoke tcpdump --help to verify the binary links and
# runs correctly.  The output is captured to a file so the genrule
# produces a build artifact that downstream targets can depend on.
genrule(
    name = "smoke_test",
    outs = ["smoke_test.txt"],
    cmd = "$(execpath :tcpdump) --help > $@ 2>&1",
    cmd_bat = "$(execpath :tcpdump) --help > $@ 2>&1",
    tools = [":tcpdump"],
)
