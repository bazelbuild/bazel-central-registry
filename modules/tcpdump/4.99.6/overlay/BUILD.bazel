# Missing libc function replacements (CMakeLists.txt lines 1452-1458).
# strlcat/strlcpy were added to glibc in 2.38 (2023-08) and are present
# on macOS/BSD.  The remaining functions (strdup, strsep, getservent,
# getopt_long) are available on all modern platforms the BCR targets.
NETDISSECT_MISSING_SRCS = select({
    "@platforms//os:linux": [
        "missing/strlcat.c",
        "missing/strlcpy.c",
    ],
    "//conditions:default": [],
})

NETDISSECT_HDRS = glob(
    ["*.h"],
    exclude = ["getservent.h"],
) + ["missing/getopt_long.h"]

# The netdissect static library (CMakeLists.txt line 1460).
cc_library(
    name = "netdissect",
    srcs = NETDISSECT_SRCS + NETDISSECT_MISSING_SRCS + NETDISSECT_HDRS,
    implementation_deps = [
        ":config",
    ],
    includes = ["."],
    deps = [
        "@libpcap",
    ],
)

# The tcpdump binary (CMakeLists.txt lines 1467, 1546).
# bpf_dump.c and missing/pcap_dump_ftell.c are excluded because
# libpcap >= 1.10.5 provides bpf_dump() and pcap_dump_ftell().
# missing/datalinks.c and missing/dlnames.c are excluded because
# libpcap >= 1.10.5 provides the corresponding functions.
cc_binary(
    name = "tcpdump",
    srcs = [
        "fptype.c",
        "tcpdump.c",
    ],
    visibility = ["//visibility:public"],
    deps = [
        ":config",
        ":netdissect",
        "@libpcap",
    ],
)

