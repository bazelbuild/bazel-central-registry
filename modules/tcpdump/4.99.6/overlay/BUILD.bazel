"""Build tcpdump 4.99.6 — ported from CMakeLists.txt / configure.ac."""

load("@rules_cc//cc:cc_binary.bzl", "cc_binary")
load("@rules_cc//cc:cc_library.bzl", "cc_library")
load("@rules_cc_autoconf//autoconf:autoconf.bzl", "autoconf")
load("@rules_cc_autoconf//autoconf:autoconf_hdr.bzl", "autoconf_hdr")
load("@rules_cc_autoconf//autoconf:checks.bzl", "checks")
load("@rules_cc_autoconf//autoconf:package_info.bzl", "package_info")

licenses(["notice"])

exports_files(["LICENSE"])

package_info(
    name = "package",
    module_bazel = "MODULE.bazel",
    strip_bcr_version = True,
)

# All autoconf checks ported from configure.ac / CMakeLists.txt.
# Checks that require linking against libpcap (pcap_* functions) use
# AC_DEFINE instead of AC_CHECK_FUNC because libpcap is a Bazel target,
# not a system library available during autoconf probing.  The defines
# match what libpcap 1.10.5 exports.
autoconf(
    name = "autoconf",
    checks = [
        checks.AC_PROG_CC(),

        # ── AC_CHECK_SIZEOF (configure.ac lines 43, 48) ──
        checks.AC_CHECK_SIZEOF(
            "void *",
            define = "SIZEOF_VOID_P",
        ),
        checks.AC_CHECK_SIZEOF(
            "time_t",
            define = "SIZEOF_TIME_T",
            includes = ["#include <time.h>"],
        ),

        # ── Standard headers ──
        checks.AC_CHECK_HEADER(
            "inttypes.h",
            define = "HAVE_INTTYPES_H",
        ),
        checks.AC_CHECK_HEADER(
            "stdint.h",
            define = "HAVE_STDINT_H",
        ),
        checks.AC_CHECK_HEADER(
            "stdio.h",
            define = "HAVE_STDIO_H",
        ),
        checks.AC_CHECK_HEADER(
            "stdlib.h",
            define = "HAVE_STDLIB_H",
        ),
        checks.AC_CHECK_HEADER(
            "string.h",
            define = "HAVE_STRING_H",
        ),
        checks.AC_CHECK_HEADER(
            "strings.h",
            define = "HAVE_STRINGS_H",
        ),
        checks.AC_CHECK_HEADER(
            "memory.h",
            define = "HAVE_MEMORY_H",
        ),
        checks.AC_CHECK_HEADER(
            "sys/stat.h",
            define = "HAVE_SYS_STAT_H",
        ),
        checks.AC_CHECK_HEADER(
            "sys/types.h",
            define = "HAVE_SYS_TYPES_H",
        ),
        checks.AC_CHECK_HEADER(
            "unistd.h",
            define = "HAVE_UNISTD_H",
        ),

        # ── tcpdump-specific headers (configure.ac line 34) ──
        checks.AC_CHECK_HEADER(
            "rpc/rpc.h",
            define = "HAVE_RPC_RPC_H",
        ),
        checks.AC_CHECK_HEADER(
            "rpc/rpcent.h",
            define = "HAVE_RPC_RPCENT_H",
        ),
        checks.AC_CHECK_HEADER(
            "net/if.h",
            define = "HAVE_NET_IF_H",
        ),

        # ── AC_REPLACE_FUNCS / AC_CHECK_FUNCS (configure.ac lines 449-451) ──
        checks.AC_CHECK_FUNC(
            "strlcat",
            define = "HAVE_STRLCAT",
        ),
        checks.AC_CHECK_FUNC(
            "strlcpy",
            define = "HAVE_STRLCPY",
        ),
        checks.AC_CHECK_FUNC(
            "strdup",
            define = "HAVE_STRDUP",
        ),
        checks.AC_CHECK_FUNC(
            "strsep",
            define = "HAVE_STRSEP",
        ),
        checks.AC_CHECK_FUNC(
            "getservent",
            define = "HAVE_GETSERVENT",
        ),
        checks.AC_CHECK_FUNC(
            "getopt_long",
            define = "HAVE_GETOPT_LONG",
        ),
        checks.AC_CHECK_FUNC(
            "fork",
            define = "HAVE_FORK",
        ),
        checks.AC_CHECK_FUNC(
            "vfork",
            define = "HAVE_VFORK",
        ),
        checks.AC_CHECK_FUNC(
            "setlinebuf",
            define = "HAVE_SETLINEBUF",
        ),

        # ── getrpcbynumber (configure.ac line 544) ──
        checks.AC_CHECK_FUNC(
            "getrpcbynumber",
            define = "HAVE_GETRPCBYNUMBER",
        ),

        # ── ether_ntohost (configure.ac line 564) ──
        checks.AC_CHECK_FUNC(
            "ether_ntohost",
            define = "HAVE_ETHER_NTOHOST",
        ),

        # USE_ETHER_NTOHOST — set when ether_ntohost() exists and is
        # assumed non-buggy (configure.ac line 588, CMakeLists.txt line 664).
        checks.AC_DEFINE(
            "USE_ETHER_NTOHOST",
            "1",
            requires = ["HAVE_ETHER_NTOHOST=1"],
        ),

        # ── ether_ntohost declaration chain (configure.ac lines 600-740) ──
        # Sequential fallback: stop checking once a header is found.
        checks.AC_CHECK_DECL(
            "ether_ntohost",
            name = "ac_cv_have_decl_ether_ntohost_net_ethernet_h",
            define = "NET_ETHERNET_H_DECLARES_ETHER_NTOHOST_TEST",
            includes = ["#include <net/ethernet.h>"],
            requires = ["HAVE_ETHER_NTOHOST=1"],
        ),
        checks.AC_DEFINE(
            "NET_ETHERNET_H_DECLARES_ETHER_NTOHOST",
            "",
            requires = ["NET_ETHERNET_H_DECLARES_ETHER_NTOHOST_TEST=1"],
        ),
        checks.AC_CHECK_DECL(
            "ether_ntohost",
            name = "ac_cv_have_decl_ether_ntohost_netinet_ether_h",
            define = "NETINET_ETHER_H_DECLARES_ETHER_NTOHOST_TEST",
            includes = ["#include <netinet/ether.h>"],
            requires = [
                "HAVE_ETHER_NTOHOST=1",
                "NET_ETHERNET_H_DECLARES_ETHER_NTOHOST_TEST=0",
            ],
        ),
        checks.AC_DEFINE(
            "NETINET_ETHER_H_DECLARES_ETHER_NTOHOST",
            "",
            requires = ["NETINET_ETHER_H_DECLARES_ETHER_NTOHOST_TEST=1"],
        ),
        checks.AC_CHECK_DECL(
            "ether_ntohost",
            name = "ac_cv_have_decl_ether_ntohost_sys_ethernet_h",
            define = "SYS_ETHERNET_H_DECLARES_ETHER_NTOHOST_TEST",
            includes = ["#include <sys/ethernet.h>"],
            requires = [
                "HAVE_ETHER_NTOHOST=1",
                "NET_ETHERNET_H_DECLARES_ETHER_NTOHOST_TEST=0",
                "NETINET_ETHER_H_DECLARES_ETHER_NTOHOST_TEST=0",
            ],
        ),
        checks.AC_DEFINE(
            "SYS_ETHERNET_H_DECLARES_ETHER_NTOHOST",
            "",
            requires = ["SYS_ETHERNET_H_DECLARES_ETHER_NTOHOST_TEST=1"],
        ),
        checks.AC_CHECK_DECL(
            "ether_ntohost",
            name = "ac_cv_have_decl_ether_ntohost_arpa_inet_h",
            define = "ARPA_INET_H_DECLARES_ETHER_NTOHOST_TEST",
            includes = ["#include <arpa/inet.h>"],
            requires = [
                "HAVE_ETHER_NTOHOST=1",
                "NET_ETHERNET_H_DECLARES_ETHER_NTOHOST_TEST=0",
                "NETINET_ETHER_H_DECLARES_ETHER_NTOHOST_TEST=0",
                "SYS_ETHERNET_H_DECLARES_ETHER_NTOHOST_TEST=0",
            ],
        ),
        checks.AC_DEFINE(
            "ARPA_INET_H_DECLARES_ETHER_NTOHOST",
            "",
            requires = ["ARPA_INET_H_DECLARES_ETHER_NTOHOST_TEST=1"],
        ),
        checks.AC_CHECK_DECL(
            "ether_ntohost",
            name = "ac_cv_have_decl_ether_ntohost_netinet_if_ether_h",
            define = "NETINET_IF_ETHER_H_DECLARES_ETHER_NTOHOST_TEST",
            includes = [
                "#include <net/if.h>",
                "#include <netinet/if_ether.h>",
                "#include <netinet/in.h>",
                "#include <sys/socket.h>",
                "#include <sys/types.h>",
            ],
            requires = [
                "HAVE_ETHER_NTOHOST=1",
                "NET_ETHERNET_H_DECLARES_ETHER_NTOHOST_TEST=0",
                "NETINET_ETHER_H_DECLARES_ETHER_NTOHOST_TEST=0",
                "SYS_ETHERNET_H_DECLARES_ETHER_NTOHOST_TEST=0",
                "ARPA_INET_H_DECLARES_ETHER_NTOHOST_TEST=0",
            ],
        ),
        checks.AC_DEFINE(
            "NETINET_IF_ETHER_H_DECLARES_ETHER_NTOHOST",
            "",
            requires = ["NETINET_IF_ETHER_H_DECLARES_ETHER_NTOHOST_TEST=1"],
        ),

        # HAVE_DECL_ETHER_NTOHOST — set if net/ethernet.h declares it
        # (macOS/BSD).  On Linux, netinet/ether.h declares it and the
        # NETINET_ETHER_H_DECLARES_ETHER_NTOHOST define steers the
        # correct header inclusion, so the code still compiles.
        checks.AC_DEFINE(
            "HAVE_DECL_ETHER_NTOHOST",
            "1",
            requires = ["NET_ETHERNET_H_DECLARES_ETHER_NTOHOST_TEST=1"],
        ),

        # ── struct ether_addr (configure.ac lines 731-738) ──
        checks.AC_CHECK_TYPE(
            "struct ether_addr",
            define = "HAVE_STRUCT_ETHER_ADDR",
            includes = [
                "#include <net/if.h>",
                "#include <netinet/if_ether.h>",
                "#include <netinet/in.h>",
                "#include <sys/socket.h>",
                "#include <sys/types.h>",
            ],
        ),

        # ── openat (used by Capsicum sandbox path) ──
        checks.AC_CHECK_FUNC(
            "openat",
            define = "HAVE_OPENAT",
        ),

        # ── libpcap features ──
        # All available in libpcap >= 1.10.5 (the BCR version).
        # Cannot use AC_CHECK_FUNC because libpcap is a Bazel
        # dependency, not a system library reachable during probing.
        checks.AC_DEFINE("HAVE_PCAP_LIST_DATALINKS", "1"),
        checks.AC_DEFINE("HAVE_PCAP_FREE_DATALINKS", "1"),
        checks.AC_DEFINE("HAVE_PCAP_DATALINK_NAME_TO_VAL", "1"),
        checks.AC_DEFINE("HAVE_PCAP_DATALINK_VAL_TO_DESCRIPTION", "1"),
        checks.AC_DEFINE("HAVE_PCAP_SET_DATALINK", "1"),
        checks.AC_DEFINE("HAVE_PCAP_BREAKLOOP", "1"),
        checks.AC_DEFINE("HAVE_PCAP_DUMP_FTELL", "1"),
        checks.AC_DEFINE("HAVE_PCAP_DUMP_FTELL64", "1"),
        checks.AC_DEFINE("HAVE_PCAP_CREATE", "1"),
        checks.AC_DEFINE("HAVE_PCAP_SET_TSTAMP_TYPE", "1"),
        checks.AC_DEFINE("HAVE_PCAP_SET_TSTAMP_PRECISION", "1"),
        checks.AC_DEFINE("HAVE_PCAP_FINDALLDEVS", "1"),
        checks.AC_DEFINE("HAVE_PCAP_DUMP_FLUSH", "1"),
        checks.AC_DEFINE("HAVE_PCAP_LIB_VERSION", "1"),
        checks.AC_DEFINE("HAVE_PCAP_SETDIRECTION", "1"),
        checks.AC_DEFINE("HAVE_PCAP_SET_IMMEDIATE_MODE", "1"),
        checks.AC_DEFINE("HAVE_PCAP_IF_T", "1"),
        checks.AC_DEFINE("HAVE_PCAP_PCAP_INTTYPES_H", "1"),
        checks.AC_DEFINE("HAVE_BPF_DUMP", "1"),

        # ── IPv6 — available on all modern platforms ──
        checks.AC_DEFINE("HAVE_OS_IPV6_SUPPORT", "1"),

        # ── Standard / unconditional defines ──
        checks.AC_DEFINE("STDC_HEADERS", "1"),
        checks.AC_DEFINE("HAVE_UINTPTR_T", "1"),
    ],
    deps = [":package"],
)

autoconf_hdr(
    name = "config_h",
    out = "config.h",
    template = "config.h.in",
    deps = [":autoconf"],
)

# Header-only library so both cc_library and cc_binary targets can
# pick up the generated config.h via deps.
cc_library(
    name = "config",
    hdrs = [":config_h"],
    defines = ["HAVE_CONFIG_H"],
    includes = ["."],
)

