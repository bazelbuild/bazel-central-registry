    "src/aio/usock_win.inc",
    "src/aio/worker_win.h",
    "src/aio/worker_win.inc",
    "src/utils/thread_win.h",
    "src/utils/thread_win.inc",
    "src/utils/win.h",
]

# Poller: epoll (Linux)
_POLLER_EPOLL_SRCS = [
    "src/aio/poller.h",
    "src/aio/poller.c",
    "src/aio/poller_epoll.h",
    "src/aio/poller_epoll.inc",
]

# Poller: kqueue (macOS)
_POLLER_KQUEUE_SRCS = [
    "src/aio/poller.h",
    "src/aio/poller.c",
    "src/aio/poller_kqueue.h",
    "src/aio/poller_kqueue.inc",
]

# Event fd: eventfd (Linux)
_EFD_EVENTFD_SRCS = [
    "src/utils/efd_eventfd.h",
    "src/utils/efd_eventfd.inc",
]

# Event fd: pipe (macOS)
_EFD_PIPE_SRCS = [
    "src/utils/efd_pipe.h",
    "src/utils/efd_pipe.inc",
]

# Event fd: winsock (Windows)
_EFD_WIN_SRCS = [
    "src/utils/efd_win.h",
    "src/utils/efd_win.inc",
]

cc_library(
    name = "nanomsg",
    srcs = _CORE_SRCS +
           _AIO_SRCS +
           _UTILS_SRCS +
           _DEVICE_SRCS +
           _PROTOCOL_UTILS_SRCS +
           _PROTOCOL_SRCS +
           _TRANSPORT_UTILS_SRCS +
           _TRANSPORT_SRCS +
           _INTERNAL_HDRS +
           _PUBLIC_HDRS +
           select({
               "@platforms//os:linux": _POSIX_SRCS + _POLLER_EPOLL_SRCS + _EFD_EVENTFD_SRCS,
               "@platforms//os:macos": _POSIX_SRCS + _POLLER_KQUEUE_SRCS + _EFD_PIPE_SRCS,
               "@platforms//os:windows": _WIN_SRCS + _EFD_WIN_SRCS,
           }),
    hdrs = _PUBLIC_HDRS,
    copts = ["-Isrc"],
    defines = ["NN_STATIC_LIB"],
    include_prefix = "nanomsg",
    linkopts = select({
        "@platforms//os:windows": [
            "-DEFAULTLIB:ws2_32.lib",
            "-DEFAULTLIB:mswsock.lib",
            "-DEFAULTLIB:advapi32.lib",
        ],
        "//conditions:default": [],
    }),
    local_defines = select({
        "@platforms//os:linux": [
            "NN_HAVE_GCC_ATOMIC_BUILTINS",
            "NN_HAVE_LINUX",
            "NN_HAVE_SOCKETPAIR",
            "NN_HAVE_SEMAPHORE",
            "NN_HAVE_PIPE",
            "NN_HAVE_PIPE2",
            "NN_HAVE_EVENTFD",
            "NN_HAVE_EPOLL",
            "NN_HAVE_POLL",
            "NN_HAVE_ACCEPT4",
            "NN_HAVE_CLOCK_MONOTONIC",
            "NN_HAVE_CLOCK_GETTIME",
            "NN_HAVE_MSG_CONTROL",
            "NN_HAVE_UNIX_SOCKETS",
            "NN_USE_EPOLL",
            "NN_USE_EVENTFD",
            "_GNU_SOURCE",
            "_REENTRANT",
            "_THREAD_SAFE",
            "_POSIX_PTHREAD_SEMANTICS",
        ],
        "@platforms//os:macos": [
            "NN_HAVE_GCC_ATOMIC_BUILTINS",
            "NN_HAVE_OSX",
            "NN_HAVE_SOCKETPAIR",
            "NN_HAVE_PIPE",
            "NN_HAVE_KQUEUE",
            "NN_HAVE_POLL",
            "NN_HAVE_CLOCK_MONOTONIC",
            "NN_HAVE_CLOCK_GETTIME",
            "NN_HAVE_MSG_CONTROL",
            "NN_HAVE_UNIX_SOCKETS",
            "NN_USE_KQUEUE",
            "NN_USE_PIPE",
            "_GNU_SOURCE",
            "_REENTRANT",
            "_THREAD_SAFE",
            "_POSIX_PTHREAD_SEMANTICS",
        ],
        "@platforms//os:windows": [
            "NN_HAVE_WINDOWS",
            "NN_HAVE_CONDVAR",
            "_CRT_SECURE_NO_WARNINGS",
            "_WIN32_WINNT=0x0600",
            "NN_USE_WINSOCK",
        ],
    }),
    strip_include_prefix = "src",
    visibility = ["//visibility:public"],
)
