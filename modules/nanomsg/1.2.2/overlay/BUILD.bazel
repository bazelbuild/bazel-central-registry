# BUILD.bazel overlay for nanomsg 1.2.2
#
# This file translates the nanomsg CMake build to Bazel.
# The CMake build uses configure-time feature detection; here we map
# those checks to platform-based select() statements.
#
# Platform mapping:
#   Linux  → epoll poller, eventfd signaling
#   macOS  → kqueue poller, pipe signaling
#   Windows → IOCP (winsock), winsock signaling

load("@rules_cc//cc:defs.bzl", "cc_library")

# Public headers installed to include/nanomsg/ by CMake
_PUBLIC_HDRS = [
    "src/nn.h",
    "src/inproc.h",
    "src/ipc.h",
    "src/tcp.h",
    "src/ws.h",
    "src/pair.h",
    "src/pubsub.h",
    "src/reqrep.h",
    "src/pipeline.h",
    "src/survey.h",
    "src/bus.h",
]

# Internal headers (not installed but needed for compilation)
_INTERNAL_HDRS = [
    "src/protocol.h",
    "src/transport.h",
]

# Core source files (platform-independent)
_CORE_SRCS = [
    "src/core/ep.h",
    "src/core/ep.c",
    "src/core/global.h",
    "src/core/global.c",
    "src/core/pipe.c",
    "src/core/poll.c",
    "src/core/sock.h",
    "src/core/sock.c",
    "src/core/sockbase.c",
