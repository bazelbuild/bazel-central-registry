Zero-initialize the FlatVector storage in one step.

Resize-then-set-last-element leaves the newly grown units uninitialized
except for the final one, which trips MemorySanitizer with a
use-of-uninitialized-value. Passing the fill value to resize() zero-
initializes every new unit.
See https://github.com/BYVoid/OpenCC/blob/master/patches/marisa-flat-vector-zero-init.patch

--- lib/marisa/grimoire/vector/flat-vector.h
+++ lib/marisa/grimoire/vector/flat-vector.h
@@ -117,10 +117,7 @@ class FlatVector {
       num_units += num_units % (64 / MARISA_WORD_SIZE);
     }

-    units_.resize(num_units);
-    if (num_units > 0) {
-      units_.back() = 0;
-    }
+    units_.resize(num_units, 0);

     value_size_ = value_size;
     if (value_size != 0) {
