 use std::fs::File;
 use std::io::*;
 
-use include_dir::{include_dir, Dir};
-
-const DATABASE_DIR: Dir = include_dir!("../../database");
+// Bazel patch: load the database at runtime through Bazel runfiles instead
+// of baking the database directory into the executable via `include_dir!()`.
+// The directory containing one well-known file (`devices.json`) is computed
+// at compile time via `env!("PRJOXIDE_DB_RLOC")`, then resolved at runtime.
+// `PRJOXIDE_DB` (env var) takes precedence so the binary can be pointed at
+// any database directory on disk.
+fn __bazel_prjoxide_db_path() -> String {
+    if let Ok(p) = std::env::var("PRJOXIDE_DB") {
+        return p;
+    }
+    let r = runfiles::Runfiles::create()
+        .expect("failed to initialize Bazel runfiles");
+    let p = runfiles::rlocation!(r, env!("PRJOXIDE_DB_RLOC"))
+        .expect("failed to resolve PRJOXIDE_DB_RLOC via runfiles");
+    p.parent()
+        .expect("rlocation path has no parent directory")
+        .to_string_lossy()
+        .into_owned()
+}
 
