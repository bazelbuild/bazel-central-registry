load("@rules_cc//cc:cc_library.bzl", "cc_library")
load("@rules_cc//cc:cc_test.bzl", "cc_test")

_TEST_COPTS = [
    "-DHAVE_CONFIG_H",
    "-DMPC_BAZEL_TEST",
] + select({
    "@rules_cc//cc/compiler:msvc-cl": ["/w"],
    "//conditions:default": ["-w"],
})

# Shared test support library (libmpc-tests equivalent).
cc_library(
    name = "_mpc_tests",
    testonly = True,
    srcs = [
        "check_data.c",
        "clear_parameters.c",
        "close_datafile.c",
        "comparisons.c",
        "copy_parameter.c",
        "double_rounding.c",
        "init_parameters.c",
        "mpfr_flags.c",
        "open_datafile.c",
        "print_parameter.c",
        "random.c",
        "read_data.c",
        "read_description.c",
        "read_line.c",
        "rounding.c",
        "setprec_parameters.c",
        "timer.c",
        "tpl_gmp.c",
        "tpl_mpc.c",
        "tpl_mpfr.c",
        "tpl_native.c",
    ],
    hdrs = ["mpc-tests.h"],
    copts = _TEST_COPTS,
    includes = ["."],
    textual_hdrs = [
        "data_check.tpl",
        "tgeneric.tpl",
    ],
    deps = [
        "//:_mpc_hdrs",
        "//:mpc",
        "//bazel:runfiles_util",
    ],
)

_TEST_DATA = glob([
    "*.dat",
    "*.dsc",
])

_MPC_TEST_DEPS = [
    ":_mpc_tests",
    "//:_mpc_hdrs",
    "//:mpc",
]

# Tests that use data files (.dsc/.dat) via the test framework.
[
    cc_test(
        name = test,
        srcs = [test + ".c"],
        copts = _TEST_COPTS,
        data = _TEST_DATA,
        env = {"MPC_SRCDIR": "$(rlocationpath abs.dsc)"},
        deps = _MPC_TEST_DEPS,
    )
    for test in [
        "tabs",
        "tacos",
        "tacosh",
        "tadd",
        "tadd_fr",
        "tadd_si",
        "tadd_ui",
        "tagm",
        "targ",
        "tasin",
        "tasinh",
        "tatan",
        "tatanh",
        "tcmp_abs",
        "tconj",
        "tcos",
        "tcosh",
        "tdiv",
        "tdiv_2si",
        "tdiv_2ui",
        "tdiv_fr",
        "tdiv_ui",
        "texp",
        "tfma",
        "tfr_div",
        "tfr_sub",
        "timag",
        "tio_str",
        "tlog",
        "tlog10",
        "tlog2",
        "tmul",
        "tmul_2si",
        "tmul_2ui",
        "tmul_fr",
        "tmul_i",
        "tmul_si",
        "tmul_ui",
        "tneg",
        "tnorm",
        "tpow",
        "tpow_d",
        "tpow_fr",
        "tpow_si",
        "tpow_ui",
        "tpow_z",
        "tproj",
        "treal",
        "trootofunity",
        "tsin",
        "tsin_cos",
        "tsinh",
        "tsqr",
        "tsqrt",
        "tstrtoc",
        "tsub",
        "tsub_fr",
        "tsub_ui",
        "ttan",
        "ttanh",
        "tui_div",
        "tui_ui_sub",
    ]
]

# Tests that do not use data files.
[
    cc_test(
        name = test,
        srcs = [test + ".c"],
        copts = _TEST_COPTS,
        deps = _MPC_TEST_DEPS,
    )
    for test in [
        "tballs",
        "tdot",
        "tdummy",
        "teta",
        "texceptions",
        "tget_version",
        "tpow_ld",
        "tprec",
        "tradius",
        "treimref",
        "tset",
        "tsum",
        "tswap",
    ]
]
