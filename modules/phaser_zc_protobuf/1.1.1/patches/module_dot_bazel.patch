--- MODULE.bazel
+++ MODULE.bazel
@@ -1,5 +1,5 @@
 module(
-    name = "phaser",
+    name = "phaser_zc_protobuf",
     version = "1.1.1"
 )
 
@@ -20,16 +20,14 @@
 bazel_dep(name = "coroutines", version = "3.3.2")
 
 # protobuf pulls an older rules_go via gazelle; Bazel 9 needs a current rules_go.
-single_version_override(
-    module_name = "rules_go",
-    version = "0.61.0",
-)
+# Declared as a direct bazel_dep (instead of single_version_override) so MVS picks
+# 0.61.0 even when phaser_zc_protobuf is used as a transitive dependency.
+bazel_dep(name = "rules_go", version = "0.61.0")
 
 # protobuf -> rules_jvm_external pulls rules_android 0.6.4, whose Android SDK
 # toolchain still references the removed @local_config_platform repo. Bazel 9
 # enables --incompatible_disable_native_repo_rules, so resolving that globally
 # registered toolchain breaks every target (even C++). 0.7.2 is Bazel 9 ready.
-single_version_override(
-    module_name = "rules_android",
-    version = "0.7.2",
-)
+# Declared as a direct bazel_dep (instead of single_version_override) so MVS picks
+# 0.7.2 even when phaser_zc_protobuf is used as a transitive dependency.
+bazel_dep(name = "rules_android", version = "0.7.2")
