"""libpq smoke tests shipped under upstream `src/interfaces/libpq/test/`.

Both programs run without contacting a server and work with any
`--//:with_ssl` setting; they are the closest thing libpq has to a unit-test
suite that builds out of the tarball.
"""

load("@rules_cc//cc:cc_test.bzl", "cc_test")

# Exercises `PQconninfoParse` + `PQconndefaults` against a fixed connection
# URI, printing every parsed option that differs from the libpq defaults.
cc_test(
    name = "libpq_uri_regress",
    srcs = ["libpq_uri_regress.c"],
    args = [
        "postgresql://user:pw@example.com:5433/the_db?sslmode=require",
    ],
    deps = ["//:pq"],
)

# Invokes `PQsslAttribute(NULL, "library")` to report which SSL backend got
# linked. Doubles as a regression test that the `with_ssl` flag actually
# wires a backend into libpq.
cc_test(
    name = "libpq_testclient",
    srcs = ["libpq_testclient.c"],
    args = ["--ssl"],
    deps = ["//:pq"],
)
