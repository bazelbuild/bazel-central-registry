# Compiler-aware config_setting_groups so the autoconf rule below can emit
# different defines on MSVC than on GCC/Clang. MSVC doesn't grok
# `__int128`, GCC's `gnu_printf` format attribute, or x86_64 inline-asm
# popcntq / SSE4.2 CRC32C; it does have `__cpuid` / `__cpuidex` intrinsics
# in their place. The `clang-cl` variant of clang is also MSVC-syntax, so
# it falls into the same bucket.
selects.config_setting_group(
    name = "_msvc_like",
    match_any = [
        "@rules_cc//cc/compiler:msvc-cl",
        "@rules_cc//cc/compiler:clang-cl",
    ],
)

selects.config_setting_group(
    name = "_gcc_like",
    match_any = [
        "@rules_cc//cc/compiler:clang",
        "@rules_cc//cc/compiler:emscripten",
        "@rules_cc//cc/compiler:gcc",
        "@rules_cc//cc/compiler:mingw-gcc",
    ],
)

selects.config_setting_group(
    name = "_x86_64_msvc_like",
    match_all = [
        "@platforms//cpu:x86_64",
        ":_msvc_like",
    ],
)

selects.config_setting_group(
    name = "_x86_64_gcc_like",
    match_all = [
        "@platforms//cpu:x86_64",
        ":_gcc_like",
    ],
)

