autoconf(
    name = "autoconf_probes",
    checks = (
        _AUTOCONF_HEADERS +
        _AUTOCONF_FUNCS +
        _AUTOCONF_DECLS +
        _AUTOCONF_TYPES +
        _AUTOCONF_SIZEOF +
        _AUTOCONF_BUILTINS + [
            checks.AC_DEFINE("STDC_HEADERS", "1"),
            # Both GCC and MSVC accept `__restrict` as a spelling of the
            # C99 `restrict` qualifier, so this define is compiler-agnostic.
            checks.AC_DEFINE("restrict", "__restrict"),
            checks.AC_DEFINE("pg_restrict", "__restrict"),
            checks.AC_DEFINE("MAXIMUM_ALIGNOF", "8"),
            checks.AC_DEFINE("MEMSET_LOOP_LIMIT", "1024"),
            checks.AC_DEFINE(
                "PG_VERSION",
                "\"{}\"".format(PG_VERSION),
            ),
            checks.AC_DEFINE(
                "PG_VERSION_STR",
                "\"PostgreSQL {} compiled by Bazel\"".format(PG_VERSION),
            ),
            checks.AC_DEFINE("PG_VERSION_NUM", PG_VERSION_NUM),
            checks.AC_DEFINE(
                "PG_MAJORVERSION",
                "\"{}\"".format(PG_MAJORVERSION_NUM),
            ),
            checks.AC_DEFINE("PG_MAJORVERSION_NUM", PG_MAJORVERSION_NUM),
            checks.AC_DEFINE("PG_MINORVERSION_NUM", PG_MINORVERSION_NUM),
            checks.AC_DEFINE("CONFIGURE_ARGS", "\" (built by Bazel via rules_cc_autoconf)\""),
            checks.AC_DEFINE("OPENSSL_API_COMPAT", "0x10002000L"),
            checks.AC_DEFINE("PG_KRB_SRVNAM", "\"postgres\""),
            # 17-template-only knobs that pg_config.h.in expects but that
            # don't make sense to probe with rules_cc_autoconf.
            checks.AC_DEFINE("HAVE_ATOMICS", "1"),
            checks.AC_DEFINE("HAVE_SPINLOCKS", "1"),
            # HAVE_LANGINFO_H is probed via AC_CHECK_HEADERS above so
            # it's only defined where `<langinfo.h>` actually exists
            # (MSVC has no langinfo.h; chklocale.c is `#ifdef`-guarded
            # on this).
            checks.AC_DEFINE("HAVE_LONG_INT_64", "1"),
            checks.AC_DEFINE("HAVE_LONG_LONG_INT_64", "1"),
            checks.AC_DEFINE("PG_USE_STDBOOL", "1"),
            checks.AC_DEFINE("PG_INT64_TYPE", "long int"),
            checks.AC_DEFINE("SIZEOF_BOOL", "1"),
            checks.AC_DEFINE("INT64_MODIFIER", "\"l\""),
            checks.AC_DEFINE("BLCKSZ", "8192"),
            checks.AC_DEFINE("XLOG_BLCKSZ", "8192"),
            checks.AC_DEFINE("RELSEG_SIZE", "131072"),
            checks.AC_DEFINE("DEF_PGPORT", "5432"),
            checks.AC_DEFINE("DEF_PGPORT_STR", "\"5432\""),
        ]
    ) + select({
        ":ssl_boringssl": [
            checks.AC_DEFINE("USE_OPENSSL", "1"),
            checks.AC_DEFINE("HAVE_LIBSSL", "1"),
            checks.AC_DEFINE("HAVE_LIBCRYPTO", "1"),
        ],
        ":ssl_openssl": [
            checks.AC_DEFINE("USE_OPENSSL", "1"),
            checks.AC_DEFINE("HAVE_LIBSSL", "1"),
            checks.AC_DEFINE("HAVE_LIBCRYPTO", "1"),
            # OpenSSL 1.1+ APIs probed by upstream's pg_config.h.in. We assume
            # an OpenSSL >=1.1 toolchain (the BCR `openssl` module is 3.x).
            checks.AC_DEFINE("HAVE_BIO_METH_NEW", "1"),
            checks.AC_DEFINE("HAVE_HMAC_CTX_NEW", "1"),
            checks.AC_DEFINE("HAVE_HMAC_CTX_FREE", "1"),
            checks.AC_DEFINE("HAVE_OPENSSL_INIT_SSL", "1"),
            checks.AC_DEFINE("HAVE_ASN1_STRING_GET0_DATA", "1"),
            checks.AC_DEFINE("HAVE_SSL_CTX_SET_CERT_CB", "1"),
            checks.AC_DEFINE("HAVE_SSL_CTX_SET_NUM_TICKETS", "1"),
            checks.AC_DEFINE("HAVE_X509_GET_SIGNATURE_INFO", "1"),
        ],
        "//conditions:default": [],
    }) + select({
        ":gssapi_on": [checks.AC_DEFINE("ENABLE_GSS", "1")],
        "//conditions:default": [],
    }) + select({
        ":zlib_on": [checks.AC_DEFINE("HAVE_LIBZ", "1")],
        "//conditions:default": [],
    }) + select({
        ":lz4_on": [
            checks.AC_DEFINE("USE_LZ4", "1"),
            checks.AC_DEFINE("HAVE_LIBLZ4", "1"),
        ],
        "//conditions:default": [],
    }) + select({
        ":zstd_on": [
            checks.AC_DEFINE("USE_ZSTD", "1"),
            checks.AC_DEFINE("HAVE_LIBZSTD", "1"),
        ],
        "//conditions:default": [],
    }) + select({
        ":readline_on": [checks.AC_DEFINE("HAVE_LIBREADLINE", "1")],
        "//conditions:default": [],
    }) + select({
        ":cassert_on": [checks.AC_DEFINE("USE_ASSERT_CHECKING", "1")],
        "//conditions:default": [],
    }) + select({
        "@platforms//os:macos": [
            checks.AC_DEFINE("USE_SYSV_SEMAPHORES", "1"),
            checks.AC_DEFINE("USE_SYSV_SHARED_MEMORY", "1"),
        ],
        "@platforms//os:windows": [
            checks.AC_DEFINE("USE_WIN32_SEMAPHORES", "1"),
            checks.AC_DEFINE("USE_WIN32_SHARED_MEMORY", "1"),
        ],
        "//conditions:default": [
            checks.AC_DEFINE("USE_UNNAMED_POSIX_SEMAPHORES", "1"),
            checks.AC_DEFINE("USE_SYSV_SHARED_MEMORY", "1"),
        ],
    }) + select({
        "@platforms//os:macos": [checks.AC_DEFINE("DLSUFFIX", "\".dylib\"")],
        "@platforms//os:windows": [checks.AC_DEFINE("DLSUFFIX", "\".dll\"")],
        "//conditions:default": [checks.AC_DEFINE("DLSUFFIX", "\".so\"")],
    }) + select({
        # GCC/Clang-only spellings. `__int128` is GCC/Clang-only (MSVC
        # has no 128-bit integer type); `gnu_printf` is the GCC format
        # archetype; `__typeof__` is a GCC extension. postgres's `c.h`
        # has `#ifdef PG_INT128_TYPE` and `#ifdef typeof` guards, so
        # leaving these undefined on MSVC is the right behavior.
        ":_msvc_like": [],
        "//conditions:default": [
            checks.AC_DEFINE("PG_INT128_TYPE", "__int128"),
            checks.AC_DEFINE("PG_C_PRINTF_ATTRIBUTE", "gnu_printf"),
            checks.AC_DEFINE("PG_CXX_PRINTF_ATTRIBUTE", "gnu_printf"),
            checks.AC_DEFINE("typeof", "__typeof__"),
        ],
    }) + select({
        ":_x86_64_gcc_like": [
            checks.AC_DEFINE("HAVE_X86_64_POPCNTQ", "1"),
            checks.AC_DEFINE("USE_SSE42_CRC32C_WITH_RUNTIME_CHECK", "1"),
            checks.AC_DEFINE("HAVE__GET_CPUID", "1"),
        ],
        # CRC32C strategy + CPUID intrinsics. GCC/Clang on x86_64 can use
        # inline-asm `popcntq` and SSE4.2 CRC32C with a runtime check via
        # `__get_cpuid`. MSVC/clang-cl don't grok GCC inline asm; they
        # have `__cpuid`/`__cpuidex` intrinsics and fall back to the
        # software slicing-by-8 CRC32C. ARMv8 has its own CRC32 path.
        ":_x86_64_msvc_like": [
            checks.AC_DEFINE("HAVE__CPUID", "1"),
            checks.AC_DEFINE("HAVE__CPUIDEX", "1"),
            checks.AC_DEFINE("USE_SLICING_BY_8_CRC32C", "1"),
        ],
        "@platforms//cpu:arm64": [
            checks.AC_DEFINE("USE_ARMV8_CRC32C_WITH_RUNTIME_CHECK", "1"),
        ],
        "//conditions:default": [
            checks.AC_DEFINE("USE_SLICING_BY_8_CRC32C", "1"),
        ],
    }),
    deps = [":package_info"],
)

autoconf_hdr(
    name = "pg_config_h",
