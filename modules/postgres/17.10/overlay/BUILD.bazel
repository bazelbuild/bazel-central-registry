# Replacement files compiled when the OS libc lacks the function. Upstream's
# `meson.build` enables these via `replace_funcs_neg`, gated on the HAVE_*
# autoconf result. We can't easily select on probe-results from srcs, so we
# pick the canonical set for each platform.
_LIBPORT_LINUX_SRCS = [
    # glibc has explicit_bzero (>=2.25), getopt(_long), inet_aton, mkdtemp,
    # strnlen, strsep and pthread_barrier_wait. Everything else needs a
    # postgres-supplied replacement.
    "src/port/explicit_bzero.c",
    "src/port/getpeereid.c",
    "src/port/strlcat.c",
    "src/port/strlcpy.c",
    "src/port/timingsafe_bcmp.c",
    # PG 17 keeps `pg_get_user_home_dir` / `pg_get_user_name` in user.c
    # (folded into pg_localeconv_r.c in 18).
    "src/port/user.c",
]

_LIBPORT_MACOS_SRCS = [
    # macOS provides strlcat/strlcpy/timingsafe_bcmp natively but lacks
    # explicit_bzero and pthread_barrier_wait.
    "src/port/explicit_bzero.c",
    "src/port/pthread_barrier_wait.c",
    "src/port/user.c",
]

_LIBPORT_WINDOWS_SRCS = [
    "src/port/dirent.c",
    "src/port/dirmod.c",
    # MSVC's libc lacks these; postgres ships replacements that meson's
    # `replace_funcs_neg` would add when the probe fails. We can't drive
    # cc_library srcs from probe results, so we list them statically.
    # `strnlen` is intentionally omitted — MSVC's CRT has it since at
    # least 2010.
    "src/port/explicit_bzero.c",
    "src/port/getopt.c",
    "src/port/getopt_long.c",
    "src/port/getpeereid.c",
    "src/port/inet_aton.c",
    "src/port/kill.c",
    "src/port/mkdtemp.c",
    "src/port/open.c",
    "src/port/strlcat.c",
    "src/port/strlcpy.c",
    "src/port/timingsafe_bcmp.c",
    "src/port/win32common.c",
    "src/port/win32dlopen.c",
    "src/port/win32env.c",
    "src/port/win32error.c",
    "src/port/win32fdatasync.c",
    "src/port/win32fseek.c",
    # Postgres's own thread-safe replacement for Winsock `gai_strerror`;
    # `port/win32/sys/socket.h` `#undef`s the Windows macro and declares
    # the postgres extern.
    "src/port/win32gai_strerror.c",
    "src/port/win32getrusage.c",
    "src/port/win32gettimeofday.c",
    "src/port/win32link.c",
    "src/port/win32ntdll.c",
    "src/port/win32pread.c",
    "src/port/win32pwrite.c",
    "src/port/win32security.c",
    "src/port/win32setlocale.c",
