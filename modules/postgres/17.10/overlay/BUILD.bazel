"""PostgreSQL 17.10 - libpq, libcommon and libpgport built with rules_cc_autoconf.

This file replaces the hand-crafted `pg_config.h` from earlier postgres BCR
modules with a real autoconf-style probe driven by `rules_cc_autoconf`.

Public configure-style flags are exposed as `bool_flag`/`string_flag`, mirroring
the `--with-*` / `--enable-*` switches of upstream `./configure`. See the top of
the file for the full list.
"""

load("@bazel_skylib//lib:selects.bzl", "selects")
load("@bazel_skylib//rules:common_settings.bzl", "bool_flag", "string_flag")
load("@bazel_skylib//rules:copy_file.bzl", "copy_file")
load("@bazel_skylib//rules:write_file.bzl", "write_file")
load("@rules_cc//cc:cc_library.bzl", "cc_library")
load("@rules_cc_autoconf//autoconf:autoconf.bzl", "autoconf")
load("@rules_cc_autoconf//autoconf:autoconf_hdr.bzl", "autoconf_hdr")
load("@rules_cc_autoconf//autoconf:checks.bzl", "checks", "macros", "utils")
load("@rules_cc_autoconf//autoconf:package_info.bzl", "package_info")

# ---------------------------------------------------------------------------
# Version metadata.
# ---------------------------------------------------------------------------
PG_MAJORVERSION_NUM = "17"

PG_MINORVERSION_NUM = "10"

PG_VERSION = "17.10"

PG_VERSION_NUM = "170010"

# ---------------------------------------------------------------------------
# Public configure-style flags.
#
# Each maps to an `--with-*` / `--enable-*` switch in upstream configure.ac.
# Only flags meaningful to libpq, libcommon, libpgport (and the frontend tools
# layered on top) are exposed. Server-only switches such as `--with-icu` are
# intentionally omitted because nothing in this build links them.
# ---------------------------------------------------------------------------

# `--with-ssl=LIB` (`--with-openssl` in older releases). Selects the SSL/TLS
# backend libpq compiles against. "openssl" pulls in `@openssl`, "boringssl"
# pulls in `@boringssl` (a Bazel-specific extension of the upstream switch),
# "none" disables SSL entirely. Drives `USE_OPENSSL`, `HAVE_LIBSSL`,
# `HAVE_LIBCRYPTO`, and the per-backend optional function probes.
string_flag(
    name = "with_ssl",
    build_setting_default = "openssl",
    values = [
        "none",
        "openssl",
        "boringssl",
    ],
    visibility = ["//visibility:public"],
)

# `--with-gssapi`: build with Kerberos/GSSAPI authentication. When enabled
# `fe-gssapi-common.c` and `fe-secure-gssapi.c` are compiled into libpq and
# linked against the GSSAPI library named by `:gssapi_lib`. The BCR has no
# canonical Kerberos module today, so consumers must point `:gssapi_lib` at a
# `cc_library` they provide (e.g. a `system_library` wrapping the host
# `libgssapi_krb5.so`). With the flag off, neither `ENABLE_GSS` nor the
# GSSAPI source files are added — `:gssapi_lib` is unused.
bool_flag(
    name = "with_gssapi",
    build_setting_default = False,
    visibility = ["//visibility:public"],
)

# Label of the `cc_library` that provides GSSAPI headers + link inputs. Only
# consulted when `:with_gssapi` is `True`. There is no canonical Kerberos
# module in the BCR, so the default points at `:gssapi_system_lib`, a tiny
# `cc_library` that uses `linkopts = ["-lgssapi_krb5"]` to pick up the host
# system's MIT/Heimdal Kerberos. Consumers that want to vendor their own
# Kerberos build (or disable the dep entirely) override this flag with their
# own `cc_library`:
#
#     bazel build --//:with_gssapi=True \
#                 --//:gssapi_lib=//my:vendored_kerberos
#
# Setting it to an empty cc_library disables the link entirely while still
# compiling the GSSAPI source paths.
label_flag(
    name = "gssapi_lib",
    build_setting_default = ":gssapi_system_lib",
    visibility = ["//visibility:public"],
)

# Default GSSAPI provider — links the host's system Kerberos via -l flags.
# Assumes MIT or Heimdal's libgssapi_krb5 / com_err are installed; if not,
# override `--//:gssapi_lib` with a `cc_library` you control.
cc_library(
    name = "gssapi_system_lib",
    linkopts = select({
        "@platforms//os:macos": [
            # macOS ships Heimdal in /usr/lib but the headers live in the
            # GSS.framework. Consumers who want full GSSAPI on macOS should
            # override this with a cc_library that adds the framework.
            "-lgssapi_krb5",
        ],
        "@platforms//os:windows": [],
        "//conditions:default": [
            "-lgssapi_krb5",
            "-lkrb5",
            "-lk5crypto",
            "-lcom_err",
        ],
    }),
)

