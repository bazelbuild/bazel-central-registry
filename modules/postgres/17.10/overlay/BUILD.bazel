cc_library(
    name = "include",
    hdrs = [
        ":pg_config_ext_h",
        ":pg_config_h",
        ":pg_config_os_h",
        ":pg_config_paths_h",
    ] + glob([
        "src/include/**/*.h",
        "src/common/*.h",
        "src/port/*.h",
        # libpq's pqexpbuffer.h is consumed by `pgcommon`'s frontend `jsonapi.c`
        # (via JSONAPI_USE_PQEXPBUFFER), so expose it as a visible header.
        "src/interfaces/libpq/*.h",
    ]),
    includes = [
        "src/include",
    ] + select({
        # Upstream postgres ships POSIX compatibility shims under
        # `src/include/port/win32/` (all Windows builds, MinGW + MSVC) and
        # `src/include/port/win32_msvc/` (MSVC-only). These provide
        # `<netinet/in.h>`, `<sys/socket.h>`, `<sys/time.h>`, `<unistd.h>`,
        # etc. so the unconditional POSIX includes in `port.h`,
        # `libpq-int.h`, and the win32 port files resolve cleanly. Upstream
        # meson adds these paths in its main meson.build; we mirror that
        # here so we don't have to patch postgres source.
        "@platforms//os:windows": ["src/include/port/win32"],
        "//conditions:default": [],
    }) + select({
        ":_msvc_like": ["src/include/port/win32_msvc"],
        "//conditions:default": [],
    }),
)

