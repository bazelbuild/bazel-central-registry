]

cc_library(
    name = "pgport",
    srcs = _LIBPORT_BASE_SRCS + select({
        "@platforms//os:linux": _LIBPORT_LINUX_SRCS,
        "@platforms//os:macos": _LIBPORT_MACOS_SRCS,
        "@platforms//os:windows": _LIBPORT_WINDOWS_SRCS,
        "//conditions:default": _LIBPORT_LINUX_SRCS,
    }),
    # Upstream meson explicitly adds these as raw `cppflags`
    # (`/DWIN32 /DWINDOWS /D__WIN32__ /D__WINDOWS__
    # /D_CRT_SECURE_NO_DEPRECATE /D_CRT_NONSTDC_NO_DEPRECATE`). Going
    # through `copts` rather than `local_defines`/`defines` matches
    # upstream's meson.build exactly and bypasses flag-ordering quirks in
    # Bazel's MSVC toolchain that have caused `#ifndef WIN32` in
    # `chklocale.c` to evaluate true even when we set WIN32 via
    # `local_defines`/`defines`. Symbol names match upstream meson
    # exactly (`WINDOWS`, not `_WINDOWS`).
    copts = select({
        "@platforms//os:windows": [
            "/DWIN32",
            "/DWINDOWS",
            "/D__WIN32__",
            "/D__WINDOWS__",
            "/D_CRT_SECURE_NO_DEPRECATE",
            "/D_CRT_NONSTDC_NO_DEPRECATE",
        ],
        "//conditions:default": [],
    }),
    # Also on `defines` so they propagate to consumer-compile commands
    # (libpq, libpgcommon, the tests) without each having to repeat the
    # copts dance.
    defines = select({
        "@platforms//os:windows": [
            "WIN32",
            "WINDOWS",
            "__WIN32__",
            "__WINDOWS__",
        ],
        "//conditions:default": [],
    }),
    local_defines = [
        "FRONTEND",
    ] + select({
        "@platforms//os:linux": ["_GNU_SOURCE"],
        "//conditions:default": [],
    }),
    visibility = ["//visibility:public"],
    deps = [
        ":include",
        # pg_strong_random.c calls into OpenSSL's RAND_bytes when USE_OPENSSL
        # is defined; pull the SSL backend in even though pgport otherwise has
        # no link-time requirement on it.
        ":ssl_backend",
    ],
)

