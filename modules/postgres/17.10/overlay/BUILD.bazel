    "src/interfaces/libpq/fe-secure-openssl.c",
]

_LIBPQ_GSSAPI_SRCS = [
    "src/interfaces/libpq/fe-gssapi-common.c",
    "src/interfaces/libpq/fe-secure-gssapi.c",
]

cc_library(
    name = "pq",
    srcs = select({
        "@platforms//os:windows": _LIBPQ_BASE_SRCS + _LIBPQ_WINDOWS,
        "//conditions:default": _LIBPQ_BASE_SRCS,
    }) + select({
        ":ssl_none": [],
        "//conditions:default": _LIBPQ_SSL_SRCS,
    }) + select({
        ":gssapi_on": _LIBPQ_GSSAPI_SRCS,
        "//conditions:default": [],
    }),
    hdrs = _LIBPQ_PUBLIC_HDRS,
    includes = [
        "src/include",
        "src/interfaces",
        "src/interfaces/libpq",
        "src/port",
    ],
    linkopts = select({
        # `fe-secure.c` calls `pthread_sigmask` to block SIGPIPE during SSL
        # writes. glibc x86_64 happens to resolve `pthread_sigmask` from
        # libc directly, but glibc aarch64 (and musl on either arch) keeps
        # it in `libpthread.so`. `-pthread` pulls the right link inputs on
        # both glibc and musl.
        "@platforms//os:linux": ["-pthread"],
        "@platforms//os:windows": [
            # MSVC's link.exe treats bare names as `.obj` files; the `.lib`
            # extension makes it look for system import libraries (it's
            # also the convention `link.exe` documents). MinGW's
            # `ld` accepts both `foo.lib` and `-lfoo`; the `.lib` form is
            # the lowest-common-denominator that works for both Windows
            # toolchains.
            #
            # `Advapi32.lib` provides `GetUserName` (used by libpq's
            # `pg_fe_getusername`) and the EventLog / CryptoAPI symbols
            # that `@openssl`'s `e_capi.obj` / `cryptlib.obj` reach for
            # internally. `Crypt32.lib` provides `Cert*` Windows
            # certificate-store APIs that OpenSSL's CAPI engine calls.
            # `User32.lib` provides `MessageBoxW` for OpenSSL's
            # `OPENSSL_showfatal`. The OpenSSL Bazel module should
            # arguably declare these itself; until it does, we link them
            # transitively from libpq.
            "Advapi32.lib",
            "Crypt32.lib",
            "Secur32.lib",
            "Shell32.lib",
            "User32.lib",
            # Winsock — provides struct in_addr, gethostbyname, ntohl, and
            # the rest of the symbols libpq + libpgport call on Windows.
            "Ws2_32.lib",
        ],
        "//conditions:default": [],
    }),
    linkstatic = True,
    local_defines = [
        "FRONTEND",
        "SO_MAJOR_VERSION=5",
    ] + select({
        "@platforms//os:linux": ["_GNU_SOURCE"],
        "@platforms//os:macos": ["_FORTIFY_SOURCE=0"],
        # Windows defines (WIN32 / _WINDOWS / etc.) come in transitively
        # via `:pgport`'s `defines`. HAVE_SOCKLEN_T mutes a libpq warning
        # since Winsock declares socklen_t.
        "@platforms//os:windows": [
            "HAVE_SOCKLEN_T=1",
        ],
        "//conditions:default": [],
    }),
    visibility = ["//visibility:public"],
    deps = [
        ":include",
        ":pgcommon",
        ":pgport",
        ":ssl_backend",
    ] + select({
        # When --//:with_gssapi=True, the consumer-supplied label at
        # --//:gssapi_lib (typically a system_library wrapping
        # libgssapi_krb5.so) supplies gss_* symbols + headers. The default
        # --//:gssapi_lib points at -lgssapi_krb5 so consumers without a
        # vendored Kerberos still get a working link as long as the host
        # libgssapi-dev is installed.
        ":gssapi_on": [":gssapi_lib"],
        "//conditions:default": [],
    }),
)

alias(
    name = "libpq",
    actual = ":pq",
    visibility = ["//visibility:public"],
)
