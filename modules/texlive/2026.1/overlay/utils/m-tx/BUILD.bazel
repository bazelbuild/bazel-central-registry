"""m-tx - preprocessor for pmx (MusiXTeX preprocessor)."""

load("@rules_cc//cc:cc_binary.bzl", "cc_binary")
load("//bazel:texlive.bzl", "TEXLIVE_COPTS")

cc_binary(
    name = "prepmx",
    srcs = glob([
        "mtx-src/*.c",
        "mtx-src/*.h",
    ]) + [
        "mtx-src/libp2c/p2c.h",
    ],
    copts = TEXLIVE_COPTS,
    includes = ["mtx-src/libp2c"],
    local_defines = ["NO_DECLARE_MALLOC"],
    visibility = ["//visibility:public"],
)
