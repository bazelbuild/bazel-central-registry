MSVC build fixes for icu4c/source/i18n — minimal additions on top
of icu BCR.1's existing patch:

* :headers — propagate `U_STATIC_IMPLEMENTATION` to consumers via
  `defines` on MSVC. See icu_common_msvc.patch for rationale.

* :collation — `/utf-8` copts on MSVC. alphaindex.cpp etc. contain
  UTF-8 char literals (Greek letters) that MSVC misreads as
  multi-byte char constants (C2015) without the flag.

--- icu4c/source/i18n/BUILD.bazel
+++ icu4c/source/i18n/BUILD.bazel
@@ -34,6 +34,11 @@
     local_defines = [
         "U_I18N_IMPLEMENTATION",
     ],
+    defines = select({
+        "@rules_cc//cc/compiler:clang-cl": ["U_STATIC_IMPLEMENTATION"],
+        "@rules_cc//cc/compiler:msvc-cl": ["U_STATIC_IMPLEMENTATION"],
+        "//conditions:default": [],
+    }),
 )
 
 cc_library(
@@ -42,6 +47,11 @@
         "*.h",
         "*.cpp",
     ]),
+    copts = select({
+        "@rules_cc//cc/compiler:clang-cl": ["/utf-8"],
+        "@rules_cc//cc/compiler:msvc-cl": ["/utf-8"],
+        "//conditions:default": [],
+    }),
     includes = ["."],
     deps = [
         ":headers",
