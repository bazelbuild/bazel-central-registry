Two MSVC-only fixes for icu4c/source/i18n (mirror of the common-side
patch — see icu_msvc_utf8_common.patch for the full rationale):

1. /utf-8 copts on `:collation` (alphaindex.cpp etc. have UTF-8
   char literals that MSVC misreads).
2. `defines = ["U_STATIC_IMPLEMENTATION"]` on `:headers` to suppress
   `__declspec(dllimport)` for static linking.

Separate from icu_msvc_utf8_common.patch because bazel's libgit2
patcher mangles multi-file unified diffs.

--- a/icu4c/source/i18n/BUILD.bazel
+++ b/icu4c/source/i18n/BUILD.bazel
@@ -34,6 +34,11 @@
     local_defines = [
         "U_I18N_IMPLEMENTATION",
     ],
+    defines = select({
+        "@rules_cc//cc/compiler:clang-cl": ["U_STATIC_IMPLEMENTATION"],
+        "@rules_cc//cc/compiler:msvc-cl": ["U_STATIC_IMPLEMENTATION"],
+        "//conditions:default": [],
+    }),
 )

 cc_library(
@@ -42,6 +47,11 @@
         "*.h",
         "*.cpp",
     ]),
+    copts = select({
+        "@rules_cc//cc/compiler:clang-cl": ["/utf-8"],
+        "@rules_cc//cc/compiler:msvc-cl": ["/utf-8"],
+        "//conditions:default": [],
+    }),
     includes = ["."],
     deps = [
         ":headers",
