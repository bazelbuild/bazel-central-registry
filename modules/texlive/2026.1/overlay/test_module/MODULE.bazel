"""Presubmit test module — exists so we can layer ad-hoc patches onto
texlive's transitive dependencies (e.g. MSVC build fixes for icu) via
single_version_override without forcing a new BCR release of those
deps. Promote each override to a proper `.bcr.N` bump once the fix
has been confirmed on CI.
"""

bazel_dep(name = "texlive", version = "2026.1")

# MSVC fixes for icu4c:
#   * /utf-8 on libraries with UTF-8 char literals (uchar, platform,
#     collation) — without it, MSVC fails C2015 "too many characters
#     in constant".
#   * U_STATIC_IMPLEMENTATION via `defines` on :headers — without it,
#     icu headers emit __declspec(dllimport) and the static link
#     fails with LNK4217/LNK1120.
#
# Split across two patches because bazel's libgit2 patcher mangles
# multi-file unified diffs (second file's hunks fail with
# CONTENT_DOES_NOT_MATCH_TARGET even when bytes match).
#
# Promote both to icu/78.2.bcr.2 once confirmed on CI.
single_version_override(
    module_name = "icu",
    patches = [
        "//:icu_msvc_utf8_common.patch",
        "//:icu_msvc_utf8_i18n.patch",
    ],
    patch_strip = 1,
)
