"""Presubmit test module — exists so we can layer ad-hoc patches onto
texlive's transitive dependencies (e.g. MSVC build fixes for icu) via
single_version_override without forcing a new BCR release of those
deps. Promote each override to a proper `.bcr.N` bump once the fix
has been confirmed on CI.
"""

bazel_dep(name = "texlive", version = "2026.1")

# In-flight icu fixes being iterated here before promotion to a
# proper icu/78.2.bcr.2 release:
#   * Replace the upstream :platform / :collation glob-based srcs
#     with explicit lists (per BCR review feedback). Globs hid the
#     fact that icu's narrow cc_libraries don't dep on each other —
#     replacing with explicit lists requires also wiring in the
#     missing inter-lib deps.
#   * MSVC: /utf-8 on the libraries with UTF-8 char literals
#     (C2015 otherwise) and U_STATIC_IMPLEMENTATION via `defines`
#     on :headers (LNK4217/LNK1120 from __declspec(dllimport)
#     otherwise).
single_version_override(
    module_name = "icu",
    patches = [
        "//:icu_common_msvc.patch",
        "//:icu_i18n_msvc.patch",
    ],
    patch_strip = 0,
)
