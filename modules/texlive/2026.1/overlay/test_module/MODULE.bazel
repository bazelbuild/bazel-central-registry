"""Presubmit test module — exists so we can layer ad-hoc patches onto
texlive's transitive dependencies (e.g. MSVC build fixes for icu) via
single_version_override without forcing a new BCR release of those
deps. Promote each override to a proper `.bcr.N` bump once the fix
has been confirmed on CI.
"""

bazel_dep(name = "texlive", version = "2026.1")

# /utf-8 fix for icu4c uchar.cpp on MSVC — see icu_msvc_utf8.patch.
# Once landed as icu/78.2.bcr.2, drop this override and bump texlive's
# own bazel_dep.
single_version_override(
    module_name = "icu",
    patches = ["//:icu_msvc_utf8.patch"],
    patch_strip = 1,
)
