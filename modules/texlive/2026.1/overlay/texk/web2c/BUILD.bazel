web2c_convert(
    name = "tex_c_gen",
    src = ":tex_p",
    outs = [
        "tex0.c",
        "texcoerce.h",
        "texd.h",
        "texini.c",
    ],
    coerce_tail = "//texk/web2c/web2c:coerce.h",
    defines = [
        "//texk/web2c/web2c:common.defines",
        "//texk/web2c/web2c:texmf.defines",
        "synctexdir/synctex.defines",
    ],
    header = "texmfmp.h",
    is_tex_engine = True,
    program = "tex",
    tags = ["manual"],
