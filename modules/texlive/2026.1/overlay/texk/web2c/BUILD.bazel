        "synctexdir/synctex-mem.ch0",
        "synctexdir/synctex-mem.ch2",
        "synctexdir/synctex-rec.ch0",
        "synctexdir/synctex-rec.ch1",
        "synctexdir/synctex-rec.ch2",
        "tex-binpool.ch",
    ],
    tags = ["manual"],
    web = "tex.web",
