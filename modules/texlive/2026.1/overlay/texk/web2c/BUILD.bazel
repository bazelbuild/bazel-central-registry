cc_library(
    name = "libtex",
    srcs = [
        "synctexdir/synctex.c",
        ":tex_c_gen",
        ":tex_pool_c",
    ],
    hdrs = glob(["synctexdir/*.h"]),
    copts = TEXLIVE_COPTS + MSVC_ATTRIBUTE_SHIM_COPTS,
    includes = [
        ".",
        "synctexdir",
    ],
    local_defines = TEX_ENGINE_DEFINES + [
        "TeX",
        "__SyncTeX__",
        "SYNCTEX_ENGINE_H=\\\"synctex-tex.h\\\"",
    ],
    tags = ["manual"],
    # lib/texmfmp.c is textually included by texextra.c (in the binary).
    # textual_hdrs exposes it via the dep graph so preprocessor finds it.
    textual_hdrs = ["lib/texmfmp.c"],
    deps = [
        ":md5",
        ":web2c_lib",
        "//bazel:msvc_shim",
        "//texk/kpathsea",
        "@zlib",
    ],
)

cc_binary(
    name = "tex",
    srcs = ["texextra.c"],
    copts = TEXLIVE_COPTS,
    linkopts = MATH_LINKOPTS,
    local_defines = TEX_ENGINE_DEFINES + [
        "TeX",
        "__SyncTeX__",
    ],
    tags = ["manual"],
    visibility = ["//visibility:public"],
    deps = [":libtex"],
)

# =============================================================================
# NOTE: classic 7-bit bibtex is not built here — it needs cvtbib.sed
# post-processing (jmp_buf/setjmp translation of Pascal `goto`s) that
# our web2c_convert rule doesn't yet support. Consumers should use
# `//texk/bibtex-x:bibtex8` (the extended 8-bit bibtex) instead.
# =============================================================================

# =============================================================================
# WEB helper utilities — plain tangle → web2c → cc_binary pipeline. See
# the `web_utility` macro in //bazel:texlive.bzl. Every entry matches
# `nodist_<name>_SOURCES = <name>.c <name>.h` in texk/web2c/am/web.am.
# All tagged manual: consumers reach them via explicit label.
# =============================================================================

[
    web_utility(name = name)
    for name in [
        "dvicopy",
        "dvitype",
        "gftopk",
        "gftype",
        "mft",
        "patgen",
        "pktogf",
        "pktype",
        "pltotf",
        "pooltype",
        "tftopl",
        "vftovp",
        "vptovf",
        "weave",
    ]
]

# gftodvi's dist_gftodvi_SOURCES pulls in an extra header (gftodmem.h)
# that gftodvi.c #includes but the WEB tangle doesn't emit.
web_utility(
    name = "gftodvi",
    extra_srcs = ["gftodmem.h"],
)

# =============================================================================
# omegaware/ — Omega/Aleph WEB helpers. odvicopy/odvitype use the plain
# `tangle` path (their .web + .ch sit under omegaware/). The other four
# (ofm2opl, opl2ofm, ovf2ovp, ovp2ovf, otangle) need `otangle` + `tie -m`
# merges upstream — deferred pending a Bazel port of that chain.
# =============================================================================

[
    web_utility(
        name = name,
        ch = "omegaware/" + name + ".ch",
        web = "omegaware/" + name + ".web",
    )
    for name in [
        "odvicopy",
        "odvitype",
    ]
]

