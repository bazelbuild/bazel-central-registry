# =============================================================================
# Web2c config headers (w2c/config.h + w2c/c-auto.h)
# =============================================================================

# Upstream `configure.ac` does
#   AC_DEFINE_UNQUOTED([WEB2CVERSION], [" (TeX Live ...)"])
# but the c-auto.in template ships with `#define WEB2CVERSION
# "REPLACE-WITH-WEB2CVERSION"` (NOT `#undef`), so autoconf_hdr's
# substitution can't touch it. Rewrite the literal here to `#undef
# WEB2CVERSION` so the AC_BUILD_SETTING -> :web2c_version_banner wiring
# in //:configure can fill the actual value.
expand_template(
    name = "c_auto_in_substituted",
    out = "c-auto.in.substituted",
    substitutions = {
        "#define WEB2CVERSION \"REPLACE-WITH-WEB2CVERSION\"": "#undef WEB2CVERSION",
    },
    template = "c-auto.in",
)

autoconf_hdr(
    name = "w2c_c_auto_h",
    out = "w2c/c-auto.h",
    template = ":c_auto_in_substituted",
    deps = ["//:configure"],
)

cc_library(
    name = "w2c_config",
    hdrs = [
        "cpascal.h",
        "help.h",
        "texmfmem.h",
        "texmfmp.h",
        "texmfmp-help.h",
        "w2c/config.h",
        ":w2c_c_auto_h",
    ],
    includes = ["."],
    visibility = ["//:__subpackages__"],
    deps = ["//texk/kpathsea"],
)

