# =============================================================================
# TeX engine (plain TeX)
# =============================================================================

# TODO(web2c): The TeX engines require a tangle→web2c→compile pipeline.
# The tangle step produces a .p file from .web + .ch, then web2c converts
# the Pascal to C, fixwrites cleans it up, and splitup splits large files.
# This is complex and depends on the bootstrap tools in web2c/.
#
# For now, we declare the targets but the full genrule pipeline for each
# engine needs the exact .web/.ch file mappings which vary per engine.
# The pattern for each WEB-based engine is:
#
#   genrule(tangle .web+.ch -> .p)
#   genrule(web2c+fixwrites+splitup .p -> .c files)
#   cc_binary(compile .c files)
#
# C-native engines (luatex, xetex, hitex) are simpler: just cc_binary
# with their source directories.

# =============================================================================
# pdftex - PDF-producing TeX engine
# =============================================================================
#
# WEB pipeline scaffold. The macros (combine_changes, tangle_web,
# web2c_convert, makecpool_pool) are wired end-to-end in
# //bazel:texlive.bzl and have been verified against pdftex:
#
#   * `tie` builds via `ctangle_cweb` from tie.w + tie-w2c.ch (lifts
#     max_file_index to 32 so 18+ change files fit).
#   * `combine_changes` produces pdftex-final.ch successfully (40,000+
#     lines written, no errors).
#   * `tangle_web(program="pdftex", emit_pool=True)` runs to completion
#     (13,000+ Pascal lines, 1,849 string-pool entries) but tangle exits
#     non-zero with "Pardon me, but I think I spotted something wrong"
#     — the change-file stack still has unresolved conflicts to debug.
#
# Concrete pdftex targets are NOT instantiated here yet: `tags=["manual"]`
# does not prevent `bazel build //...` from building these through the
# dep chain. Next debugging step: find which .ch in the stack
# (probably one of the synctex .ch0 files vs. pdftexdir/pdftex.ch)
# patches the same WEB section twice. The full recipe to plug in once
# tangle is clean:
#
#   combine_changes(name = "pdftex_final_ch", web = "pdftexdir/pdftex.web",
#       out = "pdftex-final.ch",
#       changes = [
#           "pdftexdir/tex.ch0", "tex.ch", "tracingstacklevels.ch",
#           "partoken-102.ch", "partoken.ch", "locnull-optimize.ch",
#           "showstream.ch", "zlib-fmt.ch",
#           "enctexdir/enctex1.ch", "enctexdir/enctex-pdftex.ch",
#           "enctexdir/enctex2.ch", "unbalanced-braces.ch",
#           "synctexdir/synctex-def.ch0", "synctexdir/synctex-mem.ch0",
#           "synctexdir/synctex-e-mem.ch0",
#           "pdftexdir/pdftex.ch", "pdftexdir/char-warning-pdftex.ch",
#           "tex-binpool.ch",
#       ])
#   tangle_web(name = "pdftex_p", web = "pdftexdir/pdftex.web",
#       ch = ":pdftex_final_ch", program = "pdftex", emit_pool = True)
#   web2c_convert(name = "pdftex_c_gen", src = ":pdftex_p",
#       program = "pdftex", header = "texmfmp.h",
#       is_tex_engine = True, use_splitup = True,
#       defines = [
#           "//texk/web2c/web2c:common.defines",
#           "//texk/web2c/web2c:texmf.defines",
#           "synctexdir/synctex.defines",
#           "pdftexdir/pdftex.defines",
#       ],
#       coerce_tail = "//texk/web2c/web2c:coerce.h",
#       outs = ["pdftex0.c", "pdftexini.c", "pdftexd.h", "pdftexcoerce.h"])
#   makecpool_pool(name = "pdftex_pool_c", pool = ":pdftex_p", program = "pdftex")
#   cc_library(name = "libpdftex",
#       srcs = glob(["pdftexdir/*.c"], exclude = ["pdftexdir/ttf2afm.c"]) +
#              [":pdftex_c_gen", ":pdftex_pool_c"],
#       hdrs = glob(["pdftexdir/*.h"]),
#       local_defines = TEXLIVE_LOCAL_DEFINES + ["pdfTeX"],
#       deps = [":md5", ":web2c_lib", "//texk/kpathsea",
#               "@libpng//:png", "@xpdf", "@zlib"])

# Debug-only targets: tagged manual AND NOT depended-on by anything, so
# `bazel build //...` ignores them. Run explicitly with:
#   bazel build @texlive//texk/web2c:pdftex_p
combine_changes(
    name = "pdftex_final_ch",
    out = "pdftex-final.ch",
    changes = [
        "pdftexdir/tex.ch0",
        "tex.ch",
        "tracingstacklevels.ch",
        "partoken-102.ch",
        "partoken.ch",
        "locnull-optimize.ch",
        "showstream.ch",
        "zlib-fmt.ch",
        "enctexdir/enctex1.ch",
        "enctexdir/enctex-pdftex.ch",
        "enctexdir/enctex2.ch",
        "unbalanced-braces.ch",
        # pdftex SyncTeX stack, mirrors synctexdir/am/synctex.am's
        # PDFTEX_SYNCTEX block. Order matters: the .ch1/.ch2 files
        # clear the "REMOVE ME" sentinels left by the .ch0 files.
        "synctexdir/synctex-def.ch0",
        "synctexdir/synctex-mem.ch0",
        "synctexdir/synctex-e-mem.ch0",
        "synctexdir/synctex-e-mem.ch1",
        "synctexdir/synctex-rec.ch0",
        "synctexdir/synctex-rec.ch1",
        "synctexdir/synctex-e-rec.ch0",
        "synctexdir/synctex-pdf-rec.ch2",
        "pdftexdir/pdftex.ch",
        "pdftexdir/char-warning-pdftex.ch",
        "tex-binpool.ch",
    ],
    tags = ["manual"],
    web = "pdftexdir/pdftex.web",
)

tangle_web(
    name = "pdftex_p",
    ch = ":pdftex_final_ch",
    emit_pool = True,
    program = "pdftex",
    tags = ["manual"],
    web = "pdftexdir/pdftex.web",
)

web2c_convert(
    name = "pdftex_c_gen",
    src = ":pdftex_p",
    outs = [
        "pdftex0.c",
        "pdftexcoerce.h",
        "pdftexd.h",
        "pdftexini.c",
    ],
    coerce_tail = "//texk/web2c/web2c:coerce.h",
    defines = [
        "//texk/web2c/web2c:common.defines",
        "//texk/web2c/web2c:texmf.defines",
        "synctexdir/synctex.defines",
        "pdftexdir/pdftex.defines",
    ],
    header = "texmfmp.h",
    is_tex_engine = True,
    program = "pdftex",
    tags = ["manual"],
    use_splitup = True,
)

makecpool_pool(
    name = "pdftex_pool_c",
    pool = ":pdftex_p",
    program = "pdftex",
    tags = ["manual"],
)

cc_library(
    name = "libpdftex",
    srcs = glob(
        ["pdftexdir/*.c"],
        exclude = [
            # macnames.c is textually included by writettf.c.
            "pdftexdir/macnames.c",
            # ttf2afm.c is a separate binary upstream.
            "pdftexdir/ttf2afm.c",
            # pdftexextra.c is the canonical *definition* site for all
            # EXTERN-declared engine globals (it #defines EXTERN as empty
            # before including pdftexd.h). It must live in the cc_binary
            # exactly once, not be compiled into the shared library too —
            # otherwise the linker sees duplicate definitions.
            "pdftexdir/pdftexextra.c",
        ],
    ) + [
        # pdftoepdf.cc is the xpdf glue for embedded-PDF inclusion. It
        # links against //libs/xpdf (texlive's bundled, TL-patched xpdf
        # 4.06 with the no-arg `GlobalParams()` ctor), NOT against the
        # BCR @xpdf which lacks those patches.
        "pdftexdir/pdftoepdf.cc",
        # synctex.c must be compiled with the engine's pdftexd.h on the
        # include path AND with -DSYNCTEX_ENGINE_H="synctex-pdftex.h" so
        # synctex.h pulls in the right per-engine type definitions. It
        # cannot live in a shared synctex_lib for the same reason.
        "synctexdir/synctex.c",
        ":pdftex_c_gen",
        ":pdftex_pool_c",
    ],
    hdrs = glob(["pdftexdir/*.h"]) + glob(["synctexdir/*.h"]),
    # `macnames.c` references NULL without including any header. Upstream
    # picks it up via the autoconf-generated config.h chain; we force
    # stdlib.h to avoid patching the source. The MSVC shim neutralises
    # __attribute__((format(printf, ...))) etc. in pdftex-common.h.
    copts = TEXLIVE_COPTS + force_include_copts("stdlib.h") +
            MSVC_ATTRIBUTE_SHIM_COPTS,
    # pdftexdir/ptexlib.h does `#include "pdftexd.h"` and `pdftexd.h` is
    # generated into texk/web2c/. Surface that dir on the include path so
    # those quote-includes resolve. synctex headers live in synctexdir/.
    includes = [
        ".",
        "synctexdir",
    ],
    local_defines = TEX_ENGINE_DEFINES + [
        "pdfTeX",
        "__SyncTeX__",
        # SYNCTEX_ENGINE_H needs to be a quoted C string at the
        # preprocessor — `\\"` escapes through to `\"` in the emitted
        # -D / /D flag, which both gcc and cl.exe accept.
        "SYNCTEX_ENGINE_H=\\\"synctex-pdftex.h\\\"",
    ],
    tags = ["manual"],
    # pdftexdir/utils.c uses POSIX <regex.h> (REG_EXTENDED, regcomp,
    # regexec — driving `\pdfmatch`). MSVC ships no POSIX regex and
    # we don't vendor a shim. MinGW gets it via msys2's libc, so the
    # gate is on cl.exe / clang-cl rather than os:windows.
    target_compatible_with = select({
        "@rules_cc//cc/compiler:clang-cl": ["@platforms//:incompatible"],
        "@rules_cc//cc/compiler:msvc-cl": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    # `lib/texmfmp.c` is textually included by pdftexextra.c, and
    # `pdftexdir/macnames.c` by writettf.c — these must NOT be compiled
    # standalone (textual_hdrs gives them to the preprocessor only).
    textual_hdrs = [
        "lib/texmfmp.c",
        "pdftexdir/macnames.c",
    ],
    deps = [
        ":md5",
        ":web2c_lib",
        "//:xpdf",
        "//bazel:msvc_shim",
        "//texk/kpathsea",
        "@libpng//:png",
        "@zlib",
    ],
)

cc_binary(
    name = "pdftex",
    srcs = ["pdftexdir/pdftexextra.c"],
    copts = TEXLIVE_COPTS,
    linkopts = MATH_LINKOPTS,
    # pdftexextra.c is the EXTERN definition site AND the textual host
    # for `lib/texmfmp.c`. Both `pdfTeX` and `__SyncTeX__` must be set
    # here (matching libpdftex) so that the engine-specific glue and
    # SyncTeX functions actually get a definition in the binary.
    local_defines = TEX_ENGINE_DEFINES + [
        "pdfTeX",
        "__SyncTeX__",
    ],
    tags = ["manual"],
    # Inherits MSVC-incompatibility from libpdftex (POSIX <regex.h>).
    target_compatible_with = select({
        "@rules_cc//cc/compiler:clang-cl": ["@platforms//:incompatible"],
        "@rules_cc//cc/compiler:msvc-cl": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    visibility = ["//visibility:public"],
    deps = [":libpdftex"],
)

