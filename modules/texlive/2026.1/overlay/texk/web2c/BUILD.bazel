# Upstream's own pdftex smoke: runs `pdftex --version` and `--help` to
# verify the binary loads and the version banner prints. Cheap, no
# texmf data needed — the more substantive end-to-end test is
# `bazel build @texlive//:pdflatex_fmt`, which compiles the LaTeX
# kernel and only succeeds if pdftex + texmf-dist work together.
sh_texlive_test(
    name = "pdftex_test",
    bin = ":pdftex",
    main = "pdftexdir/pdftex.test",
    target_compatible_with = select({
        "@platforms//os:windows": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
)
