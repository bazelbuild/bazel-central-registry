cc_library(
    name = "web2c_lib",
    srcs = [
        "lib/basechsuffix.c",
        "lib/chartostring.c",
        "lib/coredump.c",
        "lib/eofeoln.c",
        "lib/fprintreal.c",
        "lib/input2int.c",
        "lib/inputint.c",
        "lib/main.c",
        "lib/openclose.c",
        "lib/printversion.c",
        "lib/setupvar.c",
        "lib/uexit.c",
        "lib/usage.c",
        "lib/version.c",
        "lib/zround.c",
    ],
    hdrs = ["lib/lib.h"],
    copts = TEXLIVE_COPTS,
    # NO_MF_ASM on Windows routes texmfmp.c's `#include "lib/mfmpw32.c"`
    # to the portable C fallback ("Hobby's floating-point code").
    # mfmpw32.c uses MSVC `__asm` blocks that only compile on x86, not
    # x64 — upstream's i386-MinGW build is the only one that ever
    # exercised that branch.
    local_defines = TEXLIVE_LOCAL_DEFINES + select({
        "@platforms//os:windows": ["NO_MF_ASM"],
        "//conditions:default": [],
    }),
    strip_include_prefix = "lib",
    visibility = ["//:__subpackages__"],
    deps = [
        ":w2c_config",
        "//texk/kpathsea",
        "@zlib",
    ],
)

