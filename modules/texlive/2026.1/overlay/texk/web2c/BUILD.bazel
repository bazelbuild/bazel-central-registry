    strip_include_prefix = "synctexdir",
    tags = ["manual"],
    visibility = ["//:__subpackages__"],
    deps = [
        "//texk/kpathsea",
        "@zlib",
    ],
)

cc_binary(
    name = "synctex",
    srcs = ["synctexdir/synctex_main.c"],
    copts = TEXLIVE_COPTS,
    local_defines = TEXLIVE_LOCAL_DEFINES,
    tags = ["manual"],
    visibility = ["//visibility:public"],
    deps = [":synctex_lib"],
