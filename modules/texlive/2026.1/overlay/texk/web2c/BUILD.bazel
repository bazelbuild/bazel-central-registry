# =============================================================================
# luatex - Lua-scriptable TeX engine
# =============================================================================

# libunilib (the bundled FontForge unilib) expects a config.h that upstream
# generates via autoconf. We provide a minimal stub: <stdbool.h> for
# true/false, <stdint.h> for uint*_t, and <kpathsea/lib.h> for the
# xmalloc/xrealloc/xstrdup/xcalloc declarations the unilib sources use
# (older GCC silently warned on the implicit decls; Debian 13's GCC
# treats `-Wimplicit-function-declaration` as a hard error).
write_file(
    name = "libunilib_config_h_gen",
    out = "luatexdir/unilib/config.h",
    content = [
        "#ifndef _LIBUNILIB_CONFIG_H",
        "#define _LIBUNILIB_CONFIG_H",
        "#include <stdbool.h>",
        "#include <stdint.h>",
        "#include <kpathsea/lib.h>",
        "#endif",
        "",
    ],
)

# Private config.h wrapper kept out of libunilib's public surface so
# downstream consumers (libluatex etc.) do not see <config.h> from here.
cc_library(
    name = "libunilib_config",
    hdrs = [":libunilib_config_h_gen"],
    strip_include_prefix = "luatexdir/unilib",
    deps = ["//texk/kpathsea"],
)

cc_library(
    name = "libunilib",
    srcs = glob(["luatexdir/unilib/*.c"]),
    hdrs = glob(["luatexdir/unilib/*.h"]),
    copts = TEXLIVE_COPTS + force_include_copts("config.h"),
    implementation_deps = [":libunilib_config"],
    strip_include_prefix = "luatexdir/unilib",
)

cc_library(
    name = "libluatex",
    srcs = glob(
        [
            "luatexdir/**/*.c",
            "luatexdir/**/*.h",
        ],
        exclude = [
            "luatexdir/unilib/**",
            "luatexdir/luatex.c",
        ],
    ),
    copts = TEXLIVE_COPTS,
    local_defines = TEX_ENGINE_DEFINES + ["LuaTeX"],
    tags = ["manual"],
    deps = [
        ":libunilib",
        ":md5",
        ":web2c_lib",
        "//texk/kpathsea",
        "@libpng//:png",
        "@lua//:liblua",
        "@pplib",
        "@zlib",
        "@zziplib",
    ],
)

cc_binary(
    name = "luatex",
    srcs = ["luatexdir/luatex.c"],
    copts = TEXLIVE_COPTS,
    linkopts = MATH_LINKOPTS,
    local_defines = TEX_ENGINE_DEFINES + ["LuaTeX"],
