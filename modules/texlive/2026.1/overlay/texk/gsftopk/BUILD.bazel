load("//bazel:texlive.bzl", "force_include_copts", "texk_program")

# gsftopk references kpathsea_version_string in an unguarded way without
# including kpathsea/version.h. Needs source patches; tagged manual.
texk_program(
    name = "gsftopk",
    srcs = glob(["*.c"]),
    hdrs = glob(["*.h"]),
    copts = force_include_copts("texlive-c-auto.h"),
    local_defines = ["HAVE_CONFIG_H"],
    tags = ["manual"],
    deps = ["//:common_config"],
)
