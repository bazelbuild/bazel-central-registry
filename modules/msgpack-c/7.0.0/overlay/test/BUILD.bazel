    cc_test(
        name = src.removesuffix(".cpp"),
        srcs = [src] + glob(["*.hpp"]),
        deps = [
            "@boost.test//:boost.test",
            "@boost.test//:unit_test_main",
            "@msgpack-c//:msgpack",
            "@zlib",
        ],
    )
    for src in [
        "array_ref.cpp",
        "boost_fusion.cpp",
        "boost_optional.cpp",
        "boost_string_ref.cpp",
        "boost_string_view.cpp",
        "buffer.cpp",
        "carray.cpp",
        "cases.cpp",
        "convert.cpp",
        "fixint.cpp",
        "json.cpp",
        "limit.cpp",
        "msgpack_basic.cpp",
        "msgpack_container.cpp",
        "msgpack_stream.cpp",
        "msgpack_tuple.cpp",
        "msgpack_vref.cpp",
        "object.cpp",
        "object_with_zone.cpp",
        "pack_unpack.cpp",
        "raw.cpp",
        "reference.cpp",
        "size_equal_only.cpp",
        "streaming.cpp",
        "user_class.cpp",
        "version.cpp",
        "visitor.cpp",
        "zone.cpp",
    ]
]
