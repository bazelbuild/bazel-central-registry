load(
    "@bazel_skylib//rules:common_settings.bzl",
    "bool_flag",
    "string_flag",
)
load("@rules_cc//cc:cc_binary.bzl", "cc_binary")
load("@rules_cc//cc:cc_library.bzl", "cc_library")
load("@rules_cc//cc:cc_test.bzl", "cc_test")
load(
    "@rules_cc_autoconf//autoconf:defs.bzl",
    "autoconf",
    "autoconf_hdr",
    "checks",
    "macros",
    "package_info",
