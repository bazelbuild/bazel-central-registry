################################################################################
# Feature flags (matching configure.ac --enable/--disable options)
################################################################################

bool_flag(
    name = "enable_microsoft_extensions",
    build_setting_default = True,
    visibility = ["//visibility:public"],
)

bool_flag(
    name = "enable_mslanman",
    build_setting_default = False,
    visibility = ["//visibility:public"],
)

bool_flag(
    name = "enable_cbcp",
    build_setting_default = False,
    visibility = ["//visibility:public"],
)

bool_flag(
    name = "enable_ipv6cp",
    build_setting_default = True,
    visibility = ["//visibility:public"],
)

bool_flag(
    name = "enable_multilink",
    build_setting_default = False,
    visibility = ["//visibility:public"],
)

bool_flag(
    name = "enable_plugins",
    build_setting_default = True,
    visibility = ["//visibility:public"],
)

bool_flag(
    name = "enable_eaptls",
    build_setting_default = True,
    visibility = ["//visibility:public"],
)

bool_flag(
    name = "enable_peap",
    build_setting_default = True,
    visibility = ["//visibility:public"],
)

bool_flag(
    name = "enable_filter",
    build_setting_default = True,
    visibility = ["//visibility:public"],
)

bool_flag(
    name = "enable_openssl",
    build_setting_default = True,
    visibility = ["//visibility:public"],
)

bool_flag(
    name = "enable_openssl_engine",
    build_setting_default = True,
    visibility = ["//visibility:public"],
)

bool_flag(
    name = "enable_systemd",
    build_setting_default = False,
    visibility = ["//visibility:public"],
)

################################################################################
# String flags (matching configure.ac --with-* path options)
################################################################################

string_flag(
    name = "sysconfdir",
    build_setting_default = "/etc",
    visibility = ["//visibility:public"],
)

string_flag(
    name = "runtime_dir",
    build_setting_default = "/run/pppd",
    visibility = ["//visibility:public"],
)

string_flag(
    name = "logfile_dir",
    build_setting_default = "/var/log/ppp",
    visibility = ["//visibility:public"],
)

string_flag(
    name = "plugin_dir",
    build_setting_default = "/usr/lib/pppd/2.5.2",
    visibility = ["//visibility:public"],
)

string_flag(
    name = "system_ca_path",
    build_setting_default = "/etc/ssl/certs",
    visibility = ["//visibility:public"],
)

################################################################################
# Config settings for select()
################################################################################

config_setting(
    name = "microsoft_extensions_enabled",
    flag_values = {":enable_microsoft_extensions": "True"},
)

config_setting(
    name = "mslanman_enabled",
    flag_values = {
        ":enable_microsoft_extensions": "True",
        ":enable_mslanman": "True",
    },
)

config_setting(
    name = "cbcp_enabled",
    flag_values = {":enable_cbcp": "True"},
)

config_setting(
    name = "ipv6cp_enabled",
    flag_values = {":enable_ipv6cp": "True"},
)

config_setting(
    name = "multilink_enabled",
    flag_values = {":enable_multilink": "True"},
)

config_setting(
    name = "plugins_enabled",
    flag_values = {":enable_plugins": "True"},
)

config_setting(
    name = "eaptls_enabled",
    flag_values = {":enable_eaptls": "True"},
)

config_setting(
    name = "peap_enabled",
    flag_values = {
        ":enable_microsoft_extensions": "True",
        ":enable_peap": "True",
    },
)

config_setting(
    name = "openssl_enabled",
    flag_values = {":enable_openssl": "True"},
)

config_setting(
    name = "openssl_engine_disabled",
    flag_values = {":enable_openssl_engine": "False"},
)

config_setting(
    name = "systemd_enabled",
    flag_values = {":enable_systemd": "True"},
)

config_setting(
    name = "filter_enabled",
    flag_values = {":enable_filter": "True"},
)

config_setting(
    name = "peap_without_eaptls",
    flag_values = {
        ":enable_eaptls": "False",
        ":enable_microsoft_extensions": "True",
        ":enable_peap": "True",
    },
)

################################################################################
# Autoconf configuration
################################################################################

package_info(
    name = "package_info",
    aliases = {
        "PPPD_VERSION": "PACKAGE_VERSION",
        "VERSION": "PACKAGE_VERSION",
    },
    module_bazel = "MODULE.bazel",
    package_bugreport = "https://github.com/ppp-project/ppp",
)

autoconf(
    name = "configure_ac",
    checks = (
        macros.AC_CHECK_HEADERS([
            "asm/types.h",
            "crypt.h",
            "paths.h",
            "shadow.h",
            "stddef.h",
            "stdarg.h",
            "sys/dlpi.h",
            "sys/ioctl.h",
            "sys/socket.h",
            "sys/time.h",
            "sys/uio.h",
            "time.h",
            "unistd.h",
            "utmp.h",
        ]) + macros.AC_CHECK_HEADERS([
            "net/bpf.h",
            "net/if.h",
            "net/if_types.h",
            "net/if_arp.h",
            "linux/if.h",
            "linux/if_ether.h",
            "linux/if_packet.h",
            "netinet/if_ether.h",
            "netpacket/packet.h",
        ]) + macros.AC_CHECK_FUNCS([
            "mmap",
            "logwtmp",
            "strerror",
        ]) + [
            checks.AC_CHECK_SIZEOF(
                "unsigned int",
                define = "SIZEOF_UNSIGNED_INT",
            ),
            checks.AC_CHECK_SIZEOF(
                "unsigned long",
                define = "SIZEOF_UNSIGNED_LONG",
            ),
            checks.AC_CHECK_SIZEOF(
                "unsigned short",
                define = "SIZEOF_UNSIGNED_SHORT",
            ),
            checks.AC_CHECK_LIB("util", "logwtmp"),
            checks.AC_CHECK_LIB("crypt", "crypt"),
            checks.AC_TRY_COMPILE(
                name = "ac_cv_struct_sockaddr_ll",
                code = """\
#include <linux/if_packet.h>
int main(void) { (void)sizeof(struct sockaddr_ll); return 0; }
""",
                define = "HAVE_STRUCT_SOCKADDR_LL",
            ),
            checks.AC_DEFINE("STDC_HEADERS", 1),
        ] + select({
            ":openssl_enabled": [
                checks.AC_DEFINE("PPP_WITH_OPENSSL", 1),
                checks.AC_DEFINE("OPENSSL_HAVE_MD5", 1),
                checks.AC_DEFINE("OPENSSL_HAVE_DES", 1),
                checks.AC_DEFINE("OPENSSL_HAVE_SHA", 1),
            ],
            "//conditions:default": [],
        }) + select({
            ":filter_enabled": [
                checks.AC_DEFINE("PPP_WITH_FILTER", 1),
            ],
            "//conditions:default": [],
        }) +
        select({
            ":microsoft_extensions_enabled": [
                checks.AC_DEFINE("PPP_WITH_CHAPMS", 1),
                checks.AC_DEFINE("PPP_WITH_MPPE", 1),
            ],
            "//conditions:default": [],
        }) +
        select({
            ":mslanman_enabled": [
                checks.AC_DEFINE("PPP_WITH_MSLANMAN", 1),
            ],
            "//conditions:default": [],
        }) +
        select({
            ":cbcp_enabled": [
                checks.AC_DEFINE("PPP_WITH_CBCP", 1),
            ],
            "//conditions:default": [],
        }) +
        select({
            ":ipv6cp_enabled": [
                checks.AC_DEFINE("PPP_WITH_IPV6CP", 1),
            ],
            "//conditions:default": [],
        }) +
        select({
            ":multilink_enabled": [
                checks.AC_DEFINE("PPP_WITH_MULTILINK", 1),
                checks.AC_DEFINE("PPP_WITH_TDB", 1),
            ],
            "//conditions:default": [],
        }) +
        select({
            ":plugins_enabled": [
                checks.AC_DEFINE("PPP_WITH_PLUGINS", 1),
            ],
            "//conditions:default": [],
        }) +
        select({
            ":eaptls_enabled": [
                checks.AC_DEFINE("PPP_WITH_EAPTLS", 1),
            ],
            "//conditions:default": [],
        }) +
        select({
            ":peap_enabled": [
                checks.AC_DEFINE("PPP_WITH_PEAP", 1),
            ],
            "//conditions:default": [],
        }) +
        select({
            ":openssl_engine_disabled": [
                checks.AC_DEFINE("OPENSSL_NO_ENGINE", 1),
            ],
            "//conditions:default": [],
        }) +
        select({
            ":systemd_enabled": [
                checks.AC_DEFINE("SYSTEMD", 1),
            ],
            "//conditions:default": [],
        })
    ),
    deps = [":package_info"],
)

################################################################################
# Generated headers
################################################################################

autoconf_hdr(
    name = "pppd_config_h",
    out = "pppd/config.h",
    template = "pppd/config.h.in",
    deps = [":configure_ac"],
)

autoconf_hdr(
    name = "pppd_pppdconf_h",
    out = "pppd/pppdconf.h",
    template = "pppd/pppdconf.h.in",
    deps = [":configure_ac"],
)

cc_library(
    name = "pppd_config",
    hdrs = [
        ":pppd_config_h",
        ":pppd_pppdconf_h",
    ],
    includes = ["pppd"],
)

autoconf_hdr(
    name = "pppoe_config_h",
    out = "pppoe_autoconf/config.h",
    template = "pppd/plugins/pppoe/config.h.in",
    deps = [":configure_ac"],
)

cc_library(
    name = "pppoe_config",
    hdrs = [":pppoe_config_h"],
    includes = ["pppoe_autoconf"],
)

################################################################################
# Compiler options
################################################################################

COPTS = select({
    "@rules_cc//cc/compiler:clang": ["-w"],
    "@rules_cc//cc/compiler:gcc": ["-w"],
    "//conditions:default": [],
})

PPPD_LOCAL_DEFINES = [
    "HAVE_CONFIG_H",
    'SYSCONFDIR=\\"/etc\\"',
    'PPPD_RUNTIME_DIR=\\"/run/pppd\\"',
    'PPPD_LOGFILE_DIR=\\"/var/log/ppp\\"',
    'SYSTEM_CA_PATH=\\"/etc/ssl/certs\\"',
] + select({
    ":plugins_enabled": [
        'PPPD_PLUGIN_DIR=\\"/usr/lib/pppd/2.5.2\\"',
    ],
    "//conditions:default": [],
})

PLUGIN_CPPFLAGS = [
    "HAVE_CONFIG_H",
]

################################################################################
# Internal crypto library (libppp_crypto)
################################################################################

cc_library(
    name = "pppd_crypto",
    srcs = [
        "pppd/crypto.c",
        "pppd/ppp-des.c",
        "pppd/ppp-md4.c",
        "pppd/ppp-md5.c",
        "pppd/ppp-sha1.c",
    ],
    hdrs = [
        "pppd/crypto.h",
        "pppd/crypto-priv.h",
    ],
    copts = COPTS,
    includes = ["pppd"],
    local_defines = ["HAVE_CONFIG_H"],
    deps = [
        ":pppd_headers",
    ] + select({
        ":openssl_enabled": ["@openssl//:crypto"],
        "//conditions:default": [],
    }),
)

################################################################################
# pppd headers (for plugins that #include <pppd/pppd.h>)
################################################################################

cc_library(
    name = "pppd_headers",
    hdrs = glob(
        ["pppd/*.h"],
        exclude = [
            "pppd/config.h",
            "pppd/pppdconf.h",
        ],
    ),
    copts = COPTS,
    includes = [
        ".",
        "pppd",
    ],
    local_defines = ["HAVE_CONFIG_H"],
    deps = [":pppd_config"],
)

################################################################################
# pppd binary
################################################################################

alias(
    name = "pppd",
    actual = "bin/pppd",
    visibility = ["//visibility:public"],
)

cc_binary(
    name = "bin/pppd",
    srcs = [
        "pppd/auth.c",
        "pppd/ccp.c",
        "pppd/chap.c",
        "pppd/chap-md5.c",
        "pppd/demand.c",
        "pppd/eap.c",
        "pppd/ecp.c",
        "pppd/fsm.c",
        "pppd/ipcp.c",
        "pppd/lcp.c",
        "pppd/magic.c",
        "pppd/main.c",
        "pppd/options.c",
        "pppd/session.c",
        "pppd/sys-linux.c",
        "pppd/tty.c",
        "pppd/upap.c",
        "pppd/utils.c",
    ] + glob(
        ["pppd/*.h"],
        exclude = [
            "pppd/config.h",
            "pppd/pppdconf.h",
        ],
    ) + select({
        ":microsoft_extensions_enabled": [
            "pppd/chap_ms.c",
            "pppd/crypto_ms.c",
            "pppd/mppe.c",
        ],
        "//conditions:default": [],
    }) + select({
        ":cbcp_enabled": ["pppd/cbcp.c"],
        "//conditions:default": [],
    }) + select({
        ":multilink_enabled": [
            "pppd/multilink.c",
            "pppd/spinlock.c",
            "pppd/tdb.c",
        ],
        "//conditions:default": [],
    }) + select({
        ":ipv6cp_enabled": [
            "pppd/eui64.c",
            "pppd/ipv6cp.c",
        ],
        "//conditions:default": [],
    }) + select({
        ":eaptls_enabled": [
            "pppd/eap-tls.c",
            "pppd/tls.c",
        ],
        "//conditions:default": [],
    }) + select({
        ":peap_without_eaptls": ["pppd/tls.c"],
        "//conditions:default": [],
    }) + select({
        ":peap_enabled": ["pppd/peap.c"],
        "//conditions:default": [],
    }),
    copts = COPTS,
    includes = ["pppd"],
    linkopts = [
        "-lcrypt",
    ] + select({
        ":plugins_enabled": [
            "-ldl",
            "-Wl,-E",
        ],
        "//conditions:default": [],
    }),
    local_defines = PPPD_LOCAL_DEFINES,
    visibility = ["//visibility:public"],
    deps = [
        ":pppd_crypto",
    ] + select({
        ":openssl_enabled": ["@openssl//:ssl"],
        "//conditions:default": [],
    }) + select({
        ":filter_enabled": ["@libpcap"],
        "//conditions:default": [],
    }),
)

################################################################################
# Utility binaries
################################################################################

cc_binary(
    name = "chat",
