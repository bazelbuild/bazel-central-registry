cc_library(
    name = "ogre-main-macos",
    srcs = [
        "OgreMain/src/OSX/OgreConfigDialog.cc",
        "OgreMain/src/OSX/OgreErrorDialog.cc",
        "OgreMain/src/OSX/macUtils.cc",
