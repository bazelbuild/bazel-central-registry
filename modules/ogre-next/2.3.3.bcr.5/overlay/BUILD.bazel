        },
        "//conditions:default": {
            "#cmakedefine OGRE_GLSUPPORT_USE_GLX": "/* undef OGRE_GLSUPPORT_USE_GLX */",
            "#cmakedefine OGRE_GLSUPPORT_USE_WGL": "/* undef OGRE_GLSUPPORT_USE_WGL */",
