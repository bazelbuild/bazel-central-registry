)

# ==============================================================================
# Multi-platform Build Structure for OgreNext (OgreMain & RenderSystem_GL3Plus)
# ==============================================================================
#
# 1. OgreMain Compilation Split:
#    - Native 'cc_library' rules in Bazel strictly forbid compile-ready Objective-C++
#      ('.mm') files in the 'srcs' list.
#    - To bypass this limitation, macOS-specific Objective-C++ implementation files
#      (OgreErrorDialog.mm, macUtils.mm, OgreConfigDialog.mm) are first copied to
#      '.cc' extensions via genrules, then compiled inside the 'ogre-main-macos'
#      'cc_library' target using the '-x objective-c++' flag.
#    - All other core C++ source files are compiled inside 'ogre-main-cpp' ('cc_library').
#    - The public 'ogre-main' alias routes dependency requests based on the target OS:
#      * macOS: Resolves to 'ogre-main-macos' (which compiles the macOS windowing code
#        and transitively depends on 'ogre-main-cpp').
#      * Others: Resolves directly to 'ogre-main-cpp'.
#
# 2. RenderSystem_GL3Plus Windowing & API Selection:
#    - Linux, and other non-macOS systems build headless EGL rendering support
#      unconditionally by including EGL/PBuffer sources directly in the main target.
#    - macOS targets compile Cocoa-specific windowing code (OSX/*.mm) inside a helper
#      'RenderSystem_GL3Plus_macos' 'cc_library' target (using the same .cc rename trick).
#    - 'RenderSystem_GL3Plus.so' links with 'RenderSystem_GL3Plus_macos' on macOS and
#      adds required system Apple frameworks (-framework OpenGL, -framework Cocoa, etc.).
# ==============================================================================
main_srcs = glob(
    [
        "OgreMain/src/*.cpp",
        "OgreMain/src/*.inl",
        "OgreMain/src/Animation/*.cpp",
        "OgreMain/src/CommandBuffer/*.cpp",
        "OgreMain/src/Compositor/**/*.cpp",
        "OgreMain/src/Compute/*.cpp",
        "OgreMain/src/Hash/*.cpp",
        "OgreMain/src/Math/Array/*.cpp",
        "OgreMain/src/Math/Simple/C/*.cpp",
        "OgreMain/src/Vao/*.cpp",
    ],
    exclude = [
        "OgreMain/src/OgreConfigDialogNoOp.cpp",
        "OgreMain/src/OgreFileSystemLayerNoOp.cpp",
        "OgreMain/src/OgrePVRTCCodec.cpp",
        "OgreMain/src/OgreZip.cpp",
        "OgreMain/src/OgreSTBICodec.cpp",
    ],
) + select({
    "@platforms//cpu:x86_64": glob(["OgreMain/src/Math/Array/SSE2/Single/*.cpp"]),
    "@platforms//cpu:aarch64": glob(["OgreMain/src/Math/Array/NEON/Single/*.cpp"]),
    "//conditions:default": glob(["OgreMain/src/Math/Array/C/*.cpp"]),
}) + select({
    "@platforms//os:macos": [
        "OgreMain/src/OSX/OgreTimer.cpp",
        "OgreMain/src/OSX/OgreFileSystemLayer.cpp",
    ],
    "@platforms//os:linux": [
        "OgreMain/src/GLX/OgreTimer.cpp",
        "OgreMain/src/GLX/OgreErrorDialog.cpp",
        "OgreMain/src/GLX/OgreFileSystemLayer.cpp",
    ],
    "//conditions:default": [],
}) + [
    "OgreMain/src/Threading/OgreDefaultWorkQueueStandard.cpp",
    "OgreMain/src/Threading/OgreBarrierPThreads.cpp",
    "OgreMain/src/Threading/OgreLightweightMutexPThreads.cpp",
    "OgreMain/src/Threading/OgreThreadsPThreads.cpp",
    "OgreMain/src/Threading/OgreWaitableEvent.cpp",
]

