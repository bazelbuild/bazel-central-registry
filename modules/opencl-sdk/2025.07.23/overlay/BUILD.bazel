load("@bazel_skylib//rules:common_settings.bzl", "bool_flag")
load("@bazel_skylib//rules:write_file.bzl", "write_file")
load("@rules_cc//cc:cc_library.bzl", "cc_library")
load("@rules_cc//cc:cc_test.bzl", "cc_test")

# =============================================================================
# ICD Loader
# =============================================================================

bool_flag(
    name = "ENABLE_OPENCL_LAYERS",
    build_setting_default = True,
    visibility = ["//visibility:public"],
)

config_setting(
    name = "layers_enabled",
    flag_values = {":ENABLE_OPENCL_LAYERS": "True"},
)

bool_flag(
    name = "ENABLE_OPENCL_LOADER_MANAGED_DISPATCH",
    build_setting_default = True,
    visibility = ["//visibility:public"],
)

config_setting(
    name = "managed_dispatch_enabled",
    flag_values = {":ENABLE_OPENCL_LOADER_MANAGED_DISPATCH": "True"},
)

