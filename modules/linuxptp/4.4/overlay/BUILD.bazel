# --- Feature detection (mirrors incdefs.sh) ---
#
# The original Makefile runs incdefs.sh at parse time to probe system headers
# and emit -D flags directly into CFLAGS. In Bazel, autoconf checks run as
# build actions which cannot influence the analysis phase, so the detected
# values cannot be passed as -D flags in copts. Instead, the results are
# written to a generated config header (linuxptp_config.h) which is
# force-included via -include and is expected to contain all the same defines
# that incdefs.sh would have produced.

write_file(
    name = "linuxptp_config_h_in",
    out = "linuxptp_config.h.in",
    content = [
        "#undef HAVE_CLOCK_ADJTIME",
        "#undef HAVE_IF_TEAM",
        "#undef HAVE_ONESTEP_P2P",
        "#undef HAVE_ONESTEP_SYNC",
        "#undef HAVE_POSIX_SPAWN",
        "#undef HAVE_VCLOCKS",
        "",
    ],
)

autoconf(
    name = "autoconf",
    checks = [
        checks.AC_DEFINE("_GNU_SOURCE"),
    ] + select({
        ":have_clock_adjtime_false": [checks.AC_FAIL(
            "HAVE_CLOCK_ADJTIME",
        )],
        ":have_clock_adjtime_true": [checks.AC_DEFINE(
            "HAVE_CLOCK_ADJTIME",
        )],
        "//conditions:default": [
            checks.AC_CHECK_DECL(
                "clock_adjtime",
                compile_defines = ["_GNU_SOURCE"],
                includes = ["#include <time.h>"],
            ),
            checks.AC_DEFINE(
                "HAVE_CLOCK_ADJTIME",
                requires = ["ac_cv_have_decl_clock_adjtime==1"],
            ),
        ],
    }) + select({
        ":have_onestep_sync_false": [checks.AC_FAIL(
            "HAVE_ONESTEP_SYNC",
        )],
        ":have_onestep_sync_true": [checks.AC_DEFINE(
            "HAVE_ONESTEP_SYNC",
        )],
        "//conditions:default": [
            checks.AC_CHECK_DECL(
                "HWTSTAMP_TX_ONESTEP_SYNC",
                includes = ["#include <linux/net_tstamp.h>"],
            ),
            checks.AC_DEFINE(
                "HAVE_ONESTEP_SYNC",
                requires = ["ac_cv_have_decl_hwtstamp_tx_onestep_sync==1"],
            ),
        ],
    }) + select({
        ":have_onestep_p2p_false": [checks.AC_FAIL(
            "HAVE_ONESTEP_P2P",
        )],
        ":have_onestep_p2p_true": [checks.AC_DEFINE(
            "HAVE_ONESTEP_P2P",
        )],
        "//conditions:default": [
            checks.AC_CHECK_DECL(
                "HWTSTAMP_TX_ONESTEP_P2P",
                includes = ["#include <linux/net_tstamp.h>"],
            ),
            checks.AC_DEFINE(
                "HAVE_ONESTEP_P2P",
                requires = ["ac_cv_have_decl_hwtstamp_tx_onestep_p2p==1"],
            ),
        ],
    }) + select({
        ":have_vclocks_false": [checks.AC_FAIL(
            "HAVE_VCLOCKS",
        )],
        ":have_vclocks_true": [checks.AC_DEFINE(
            "HAVE_VCLOCKS",
        )],
        "//conditions:default": [
            checks.AC_CHECK_DECL(
                "SOF_TIMESTAMPING_BIND_PHC",
                includes = [
                    "#include <linux/ethtool_netlink.h>",
                    "#include <linux/net_tstamp.h>",
                ],
            ),
            checks.AC_DEFINE(
                "HAVE_VCLOCKS",
                requires = ["ac_cv_have_decl_sof_timestamping_bind_phc==1"],
            ),
        ],
    }) + select({
        ":have_if_team_false": [checks.AC_FAIL(
            "HAVE_IF_TEAM",
        )],
        ":have_if_team_true": [checks.AC_DEFINE(
            "HAVE_IF_TEAM",
        )],
        "//conditions:default": [
            checks.AC_CHECK_DECL(
                "TEAM_GENL_NAME",
                includes = ["#include <linux/if_team.h>"],
            ),
            checks.AC_DEFINE(
                "HAVE_IF_TEAM",
                requires = ["ac_cv_have_decl_team_genl_name==1"],
            ),
        ],
    }) + select({
        ":have_posix_spawn_false": [checks.AC_FAIL(
            "HAVE_POSIX_SPAWN",
        )],
        ":have_posix_spawn_true": [checks.AC_DEFINE(
            "HAVE_POSIX_SPAWN",
        )],
        "//conditions:default": [
            checks.AC_CHECK_DECL(
                "posix_spawn",
                compile_defines = ["_GNU_SOURCE"],
                includes = ["#include <spawn.h>"],
            ),
            checks.AC_DEFINE(
                "HAVE_POSIX_SPAWN",
                requires = ["ac_cv_have_decl_posix_spawn==1"],
            ),
        ],
    }),
)

autoconf_hdr(
    name = "linuxptp_config_h",
    out = "linuxptp_config.h",
    template = "linuxptp_config.h.in",
    deps = [":autoconf"],
)

# --- Common settings ---

# Makefile: CFLAGS = -Wall $(VER) $(incdefs) $(DEBUG) $(EXTRA_CFLAGS)
LINUXPTP_COPTS = [
    "-D_GNU_SOURCE",
    "-DVER={}".format(VERSION),
    "-include",
    "$(execpath :linuxptp_config_h)",
]

# Makefile: LDLIBS = -lm -lrt -pthread $(EXTRA_LDFLAGS)
LINUXPTP_LINKOPTS = [
    "-lm",
    "-lrt",
    "-pthread",
]

# --- Headers ---

cc_library(
    name = "hdrs",
    hdrs = glob(["*.h"]) + [":linuxptp_config_h"],
)

# --- Libraries matching Makefile variable groups ---

cc_library(
    name = "system_openssl",
    linkopts = ["-lcrypto"],
)

# Makefile: SECURITY = sad.o [+ conditional crypto backend]
cc_library(
    name = "security",
    srcs = [
        "sad.c",
        ":linuxptp_config_h",
    ] + select({
        ":crypto_gnupg": ["sad_gnupg.c"],
        ":crypto_gnutls": ["sad_gnutls.c"],
        ":crypto_nettle": ["sad_nettle.c"],
        ":crypto_openssl": ["sad_openssl.c"],
        ":crypto_openssl_system": ["sad_openssl.c"],
        "//conditions:default": [],
    }),
    copts = LINUXPTP_COPTS,
    linkopts = select({
        ":crypto_gnupg": ["-lgcrypt"],
        ":crypto_gnutls": ["-lgnutls"],
        ":crypto_nettle": ["-lnettle"],
        "//conditions:default": [],
    }),
    local_defines = select({
        ":crypto_gnupg": ["HAVE_GNUPG"],
        ":crypto_gnutls": ["HAVE_GNUTLS"],
        ":crypto_nettle": ["HAVE_NETTLE"],
        ":crypto_openssl": ["HAVE_OPENSSL"],
        ":crypto_openssl_system": ["HAVE_OPENSSL"],
        "//conditions:default": [],
    }),
    deps = [
        ":core",
        ":hdrs",
        ":protocol",
    ] + select({
        ":crypto_openssl": ["@openssl//:crypto"],
        ":crypto_openssl_system": [":system_openssl"],
        "//conditions:default": [],
    }),
)

