        build_setting_default = "auto",
        values = [
            "auto",
            "True",
            "False",
        ],
        visibility = ["//visibility:public"],
    )
    for feat in AUTOCONF_FEATURES
]

[
    config_setting(
        name = feat + "_true",
        flag_values = {":" + feat: "true"},
    )
    for feat in AUTOCONF_FEATURES
]

[
    config_setting(
