# --- Build flags ---

AUTOCONF_FEATURES = {
    "have_clock_adjtime": "HAVE_CLOCK_ADJTIME",
    "have_if_team": "HAVE_IF_TEAM",
    "have_onestep_p2p": "HAVE_ONESTEP_P2P",
