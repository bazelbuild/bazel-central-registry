# Tests that come with a `.awk` driver. Some upstream test names ship only a
# `.ok` (driven by special `-v` invocations or shell scripts we don't model
# here) — those are filtered out below.
_AWK_FILES = {f[:-len(".awk")]: f for f in glob(
    ["*.awk"],
    allow_empty = True,
)}

# Set of test names that ship a `.ok` golden output. Built once at BUILD-load
# time rather than re-globbing per test.
_OK_TESTS = {f[:-len(".ok")]: True for f in glob(
    ["*.ok"],
    allow_empty = True,
)}

# ---------------------------------------------------------------------------
# Generate tests via the awk_test macro (defined in awk_test.bzl).
# ---------------------------------------------------------------------------

# Per-test overrides for `target_compatible_with`. Each entry maps a test
# name to the `config_setting` that, when matched, marks the test
# incompatible (so it skips cleanly under that flag config rather than
# diff-failing against a baseline that no longer applies).
_PER_TEST_INCOMPAT = {
    # These tests enumerate gawk's built-in functions via `SYMTAB`,
    # `FUNCTAB`, or `--dump-variables`. `--//:builtin_intdiv0=true` adds
    # `intdiv0` to the built-in set via `SUPPLY_INTDIV=1`, shifting the
    # listing and breaking the baseline.
    "asortsymtab": "//:_builtin_intdiv0_setting",
    "functab5": "//:_builtin_intdiv0_setting",
    "id": "//:_builtin_intdiv0_setting",
    # Built-in lint warnings (e.g. "function `foo' called but never
    # defined") fire without `--lint` because gawk's underlying check
    # isn't gated on the option — but `--//:disable_lint=true` strips the
    # whole lint code path via `NO_LINT=1`, so those warnings vanish too.
    "lint": "//:_disable_lint_setting",
    "lintset": "//:_disable_lint_setting",
    "nsidentifier": "//:_builtin_intdiv0_setting",
}

# Tests that pipe to/from Unix-only commands (`cat`, `sort`, `true`,
# `false`) via `"cmd" | getline` / `print | "cmd"`. Windows's `cmd.exe`
# doesn't have these built in, so gawk's `_spawnl` fails with
# "command not found" (exit 127) and the diff fails. Skip on Windows
# rather than maintain Windows-specific `.ok` baselines.
_WINDOWS_INCOMPAT = [
    "childin",  # cat
    "clos1way",  # sort
    "elemnew2",  # true / false
    "exitval2",  # `read` (bash builtin, no cmd.exe equivalent)
    "funstack",  # date
    "getline",  # echo via subprocess; Bazel sandbox strips ComSpec
    "id",  # sort
    "iobug1",  # cat, true
    "regexprange",  # true / false
    "sortu",  # cat
    "spacere",  # sort
    "symtab12",  # sort
    "tweakfld",  # date
]

# MSVC support is best-effort (gawk's upstream doesn't ship MSVC code
# paths; we route through MinGW-gated source via patches). To keep
# CI green and verification focused, run only a curated core set on
# MSVC — enough to verify the awk language fundamentals work, not the
# full ~450-test suite. Anything not on this list gets
# `target_compatible_with` incompatible on MSVC.
_MSVC_CORE_TESTS = [
    # Arithmetic / numeric conversion
    "math",
    "hex",
    "intprec",
    "divzero",
    "negexp",
    "convfmt",
    "ofmt",
    # String operations
    "substr",
    "strcat1",
    "gsubtest",
    "gsubasgn",
    "subback",
    # Regex
    "anchor",
    "anchgsub",
    "match4",
    "regeq",
    # Arrays
    "arrayparm",
    "arrayref",
    "arryref2",
    "fordel",
    # printf / print
    "printf1",
    "printfchar",
    "hsprint",
    # getline (only the subprocess-free ones; `getline` itself pipes
    # from `echo` which needs `cmd.exe` reachable from gawk's
    # `_spawnl`, and Bazel's test sandbox strips `ComSpec`)
    "getline2",
    "getline5",
    "inputred",
    # Field splitting / record handling
    "fldchg",
    "nfldstr",
    "fsbs",
    "parsefld",
    "rs",
    "rstest1",
    # Control flow
    "forsimp",
    "exitval3",
    "exit2",
    # Functions
    "callparam",
    "fnmisc",
    "paramdup",
    "fcall_exit",
    # Misc fundamentals
    "nasty",
    "escapebrace",
    "defref",
]

[
    awk_test(
        name = t,
        awk = _AWK_FILES[t],
        input = _INPUT_FILES.get(t),
        ok = t + ".ok",
        target_compatible_with = (
            (incompat_if(_PER_TEST_INCOMPAT[t]) if t in _PER_TEST_INCOMPAT else []) +
            (incompat_if("@platforms//os:windows") if t in _WINDOWS_INCOMPAT else []) +
            ([] if t in _MSVC_CORE_TESTS else incompat_if("@rules_cc//cc/compiler:msvc-cl"))
        ),
    )
    for t in BASIC_TESTS + GAWK_EXT_TESTS + MACHINE_TESTS
    if t not in _TESTS_WITH_FLAGS and t not in SKIPPED and t in _AWK_FILES and t in _OK_TESTS
]

# Tests whose category depends on a feature that can itself be flagged
# off. Skip those tests when their feature is disabled instead of letting
# them diff-fail with the wrong baseline.
_FLAG_INCOMPATIBILITIES = {
    # `--lint` / `--lint-old` become no-ops when gawk is built with
    # `NO_LINT=1` (i.e. `--//:disable_lint=true`), so the expected lint
    # warnings never appear and the .ok diff fails.
    "--lint": "//:_disable_lint_setting",
    "--lint-old": "//:_disable_lint_setting",
}

[
    awk_test(
        name = t,
        awk = _AWK_FILES[t],
        category = flag.lstrip("-").replace("-", "_"),
        extra_args = flag,
        input = _INPUT_FILES.get(t),
        ok = t + ".ok",
        # Flag-category tests aren't in the MSVC core set; skip them
        # all on MSVC for the same reason as `_MSVC_CORE_TESTS` above.
        target_compatible_with = (
            (incompat_if(_FLAG_INCOMPATIBILITIES[flag]) if flag in _FLAG_INCOMPATIBILITIES else []) +
            incompat_if("@rules_cc//cc/compiler:msvc-cl")
        ),
    )
    for flag, tests in FLAG_CATEGORIES.items()
    for t in tests
    if t not in SKIPPED and t in _AWK_FILES and t in _OK_TESTS
]

# ---------------------------------------------------------------------------
# Shell-driven tests (gawk's RUN_SHELL set).
#
# The wrapper builds a per-test tmp directory, symlinks every sibling
# (`.sh`, `.awk`, `.in`, `.ok`) into it, sets `GAWK`/`AWK` to absolute paths,
# `chdir`s into the tmp dir, and exec's the upstream script. Putting the
# script in a writable directory rather than the read-only runfiles tree
# lets upstream tests create scratch files alongside their inputs.
# ---------------------------------------------------------------------------

write_file(
    name = "wrapper",
    out = "wrapper.sh",
    content = """\
#!/usr/bin/env bash

set -euo pipefail

# --- begin runfiles.bash initialization v3 ---
# Copy-pasted from the Bazel Bash runfiles library v3.
set -uo pipefail; set +e; f=bazel_tools/tools/bash/runfiles/runfiles.bash
# shellcheck disable=SC1090
source "${RUNFILES_DIR:-/dev/null}/$f" 2>/dev/null || \\
  source "$(grep -sm1 "^$f " "${RUNFILES_MANIFEST_FILE:-/dev/null}" | cut -f2- -d' ')" 2>/dev/null || \\
  source "$0.runfiles/$f" 2>/dev/null || \\
  source "$(grep -sm1 "^$f " "$0.runfiles_manifest" | cut -f2- -d' ')" 2>/dev/null || \\
  source "$(grep -sm1 "^$f " "$0.exe.runfiles_manifest" | cut -f2- -d' ')" 2>/dev/null || \\
  { echo>&2 "ERROR: cannot find $f"; exit 1; }; f=; set -e
# --- end runfiles.bash initialization v3 ---

SCRIPT=$(rlocation "$1"); shift
export GAWK=$(rlocation "$1"); shift
export AWK="$GAWK"

# `TEST_UNDECLARED_OUTPUTS_DIR` is set by Bazel for every test and is
# captured as `outputs.zip` on failure — using it instead of a tmp dir
# lets you inspect any scratch files the upstream script left behind.
cd "${TEST_UNDECLARED_OUTPUTS_DIR:?required by the bazel test environment}"

# Copy (not symlink) every sibling of the script into the cwd so the
# script can reach its .awk / .in / .ok inputs via plain basename. We
# can't symlink because Bazel validates `TEST_UNDECLARED_OUTPUTS_DIR`
# after the test exits and rejects symlinks pointing at runfile-tree
# paths that don't survive the sandbox teardown (they end up "dangling").
for f in "$@"; do
  abs=$(rlocation "$f") || true
  [ -n "$abs" ] && [ -f "$abs" ] && cp "$abs" "$(basename "$abs")"
done

exec "$SCRIPT"
""".splitlines(),
    is_executable = True,
)

# Reuse the precomputed `_AWK_FILES` / `_INPUT_FILES` / `_OK_TESTS`
# dicts (built once above via `glob()`) for membership tests rather
# than re-globbing per test × per extension.
_RUN_SHELL_SIBLINGS = {
    t: [
        f
        for f in [
            _AWK_FILES.get(t),
            _INPUT_FILES.get(t),
            (t + ".ok") if t in _OK_TESTS else None,
        ]
        if f
    ]
    for t in RUN_SHELL
}

[
    sh_test(
        name = t,
        srcs = ["wrapper.sh"],
        args = [
            "$(rlocationpath {}.sh)".format(t),
            "$(rlocationpath //:gawk)",
        ] + [
            "$(rlocationpath {})".format(f)
            for f in _RUN_SHELL_SIBLINGS[t]
        ],
        data = [
            "{}.sh".format(t),
            "//:gawk",
            "@rules_shell//shell/runfiles",
        ] + _RUN_SHELL_SIBLINGS[t],
        # RUN_SHELL tests are upstream gawk `.sh` driver scripts that
        # call Unix tools (`cat`, `tr`, `sort`, etc.) absent from
        # Windows `cmd.exe`. Skip on MSVC; they're outside the core
        # MSVC support surface.
        target_compatible_with = incompat_if("@rules_cc//cc/compiler:msvc-cl"),
    )
    for t in RUN_SHELL
]

# ---------------------------------------------------------------------------
# Extension-dependent tests (subset of upstream SHLIB_TESTS).
#
# Each needs a gawk binary bundled with the right extension(s) on AWKLIBPATH;
# the gawk_tool rule handles that wiring. Only tests that work without extra
# input files or sandbox-incompatible operations are included here.
# ---------------------------------------------------------------------------

gawk_tool(
    name = "gawk_filefuncs",
    extensions = ["//extension:filefuncs"],
)

FILEFUNCS_TESTS = [
    # apiterm uses gawk's filefuncs extension to inspect APIs.
    "apiterm",
    # fts walks a fixture directory tree (works in sandbox).
    "fts",
    # functab4/5 print bytes that include extension function names.
    "functab4",
    "functab5",
]

[
    awk_test(
        name = t,
        awk = _AWK_FILES[t],
        gawk = ":gawk_filefuncs",
        input = _INPUT_FILES.get(t),
        ok = t + ".ok",
        # When extensions are compiled out (`--//:disable_extensions=true`),
        # gawk's `dlopen()` path isn't wired in and these tests print
        # "dynamic loading of libraries is not supported" instead of the
        # expected output. Skip them cleanly rather than diff-fail. Some
        # filefuncs tests (e.g. `functab5`) also enumerate built-ins, so
        # they pick up `_PER_TEST_INCOMPAT` entries on top.
        target_compatible_with = incompat_if("//:_disable_extensions_setting") + (
            incompat_if(_PER_TEST_INCOMPAT[t]) if t in _PER_TEST_INCOMPAT else []
        ),
    )
    for t in FILEFUNCS_TESTS
    if t in _AWK_FILES and t in _OK_TESTS
]
