# ---------------------------------------------------------------------------
# Shell wrapper for the .awk test suite.
#
# Generated via `write_file` (not a checked-in `.sh`) so the BCR overlay
# mechanism — which strips +x bits from raw overlay files — still produces
# an executable wrapper. Each `awk_test(...)` declaration runs this wrapper
# via `sh_test`; it sources `runfiles.bash` (rlocation), runs gawk with
# absolute paths, then sed-normalizes the output so error messages
# (which include the .awk path) match the basenames baked into the
# upstream `.ok` files.
#
# Absolute paths (not `cp` + `cd` + relative basename) because on Windows
# MSYS bash's `cd` doesn't always propagate to the Windows CWD that
# native `gawk.exe` inherits when bash spawns it — leading to gawk
# reporting "cannot open source file `aadelete1.awk'" even after `cp`
# placed the file in bash's CWD. The sed normalization happens on all
# platforms (a no-op on outputs that contain no path).
# ---------------------------------------------------------------------------

write_file(
    name = "run_awk_test",
    out = "run_awk_test.sh",
    content = """\
#!/usr/bin/env bash

set -euo pipefail

# --- begin runfiles.bash initialization v3 ---
# Copy-pasted from the Bazel Bash runfiles library v3.
set -uo pipefail; set +e; f=bazel_tools/tools/bash/runfiles/runfiles.bash
# shellcheck disable=SC1090
source "${RUNFILES_DIR:-/dev/null}/$f" 2>/dev/null || \\
  source "$(grep -sm1 "^$f " "${RUNFILES_MANIFEST_FILE:-/dev/null}" | cut -f2- -d' ')" 2>/dev/null || \\
  source "$0.runfiles/$f" 2>/dev/null || \\
  source "$(grep -sm1 "^$f " "$0.runfiles_manifest" | cut -f2- -d' ')" 2>/dev/null || \\
  source "$(grep -sm1 "^$f " "$0.exe.runfiles_manifest" | cut -f2- -d' ')" 2>/dev/null || \\
  { echo>&2 "ERROR: cannot find $f"; exit 1; }; f=; set -e
# --- end runfiles.bash initialization v3 ---

GAWK=$(rlocation "$1"); shift
OK=$(rlocation "$1"); shift
AWK_FILE=$(rlocation "$1"); shift
IN_FILE=
if [ "$1" != "__no_input__" ]; then
  IN_FILE=$(rlocation "$1")
fi
shift

# `TEST_UNDECLARED_OUTPUTS_DIR` is set by Bazel for every test and is
# captured as `outputs.zip` on failure — using it as scratch space lets
# you inspect `_out` (and `_out_raw`, pre-normalization) from a flaky
# run without re-running the test.
cd "${TEST_UNDECLARED_OUTPUTS_DIR:?required by the bazel test environment}"
BASE=$(basename "$AWK_FILE" .awk)
set +e
if [ -n "$IN_FILE" ]; then
  "$GAWK" "$@" -f "$AWK_FILE" < "$IN_FILE" > _out_raw 2>&1
else
  "$GAWK" "$@" -f "$AWK_FILE" > _out_raw 2>&1
fi

RC=$?

set -e
# Strip the absolute-path prefix gawk echoes in its error messages so
#   gawk: /abs/path/aadelete1.awk:3: fatal: ...
# normalizes to
#   gawk: aadelete1.awk:3: fatal: ...
# matching the basenames baked into the upstream `.ok` files.
#
# Two-pass substitution — one for the POSIX form of AWK_FILE and one
# for the Windows-backslash variant — because gawk's error output may
# legitimately contain other backslashes (regex-escape descriptions
# like backslash-8) that a blanket translation would mangle. Match
# only the AWK_FILE path itself in each form.
#
# The `cat ; printf x` + `%x` sentinel preserves trailing newlines
# that `$(...)` would otherwise strip. Unquoted vars in the patterns
# are required for bash 3.2 (macOS), which takes quotes inside
# `${var//"$pat"/...}` literally; safe here because paths contain no
# glob metachars (`*`/`?`/`[`). The backslash variant pattern uses
# four backslashes per separator so bash's glob engine sees two
# (which matches a single literal backslash).
out=$(cat _out_raw; printf x); out="${out%x}"
# On Windows, gawk's stdio runs in text mode and translates LF to
# CRLF on output. The upstream `.ok` files end every line with LF
# only, so without this `diff` reports every line as different even
# when the visible content matches. Replace CRLF only (not lone
# CRs) so any legitimate CR inside a record is preserved.
out="${out//$'\\r\\n'/$'\\n'}"
out="${out//$AWK_FILE/$BASE.awk}"
AWK_FILE_BS="${AWK_FILE//\\//\\\\\\\\}"
out="${out//$AWK_FILE_BS/$BASE.awk}"
# Same normalization for the gawk binary path itself — on Windows
# `argv[0]` is the absolute path used to launch it (e.g.
# C:\\...\\gawk.exe) and shows up at the start of error messages;
# upstream `.ok` files bake in just `gawk`. `basename ... .exe`
# strips the suffix when present (no-op on POSIX).
GAWK_NAME=$(basename "$GAWK" .exe)
out="${out//$GAWK/$GAWK_NAME}"
GAWK_BS="${GAWK//\\//\\\\\\\\}"
out="${out//$GAWK_BS/$GAWK_NAME}"
printf '%s' "$out" > _out

if [ "$RC" != "0" ]; then
  echo "EXIT CODE: $RC" >> _out
fi

diff -u "$OK" _out
""".splitlines(),
    is_executable = True,
)

