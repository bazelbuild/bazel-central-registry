# CDR tests

load("@rules_cc//cc:cc_test.bzl", "cc_test")

[
    cc_test(
        name = name,
        srcs = srcs + ["xcdr/utility.hpp"],
        deps = [
            "@fastcdr",
            "@googletest//:gtest",
            "@googletest//:gtest_main",
        ],
    )
    for name, srcs in {
        "FixedSizeStringTests": ["cdr/fixed_size_string.cpp"],
        "ArrayAsSTDVectorTests": ["cdr/array_as_std_vector.cpp"],
        "UnitTests": [
            "cdr/ResizeTest.cpp",
            "cdr/SimpleTest.cpp",
        ],
    }.items()
]

# XCDR tests

cc_test(
    name = "xcdr_tests",
    srcs = glob([
        "xcdr/*.hpp",
        "xcdr/*.cpp",
    ]),
    deps = [
        "@fastcdr",
        "@googletest//:gtest",
        "@googletest//:gtest_main",
    ],
)
