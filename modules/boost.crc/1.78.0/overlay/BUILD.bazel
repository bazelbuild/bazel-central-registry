load("@rules_cc//cc:defs.bzl", "cc_library", "cc_test")

cc_library(
    name = "boost.crc",
    hdrs = glob(["include/**/*.hpp"]),
    features = ["parse_headers"],
    includes = ["include"],
    visibility = ["//visibility:public"],
    deps = [
        "@boost.array",
        "@boost.integer",
    ],
)

cc_test(
    name = "crc_test",
    srcs = ["test/crc_test.cpp"],
    local_defines = select({
        "@platforms//os:windows": ["BOOST_ALL_NO_LIB"],
        "//conditions:default": [],
    }),
    deps = [
        ":boost.crc",
        "@boost.config",
        "@boost.core",
        "@boost.integer",
        "@boost.timer",
    ],
)

cc_test(
    name = "crc2_test",
    srcs = ["test/crc_test2.cpp"],
    deps = [
        ":boost.crc",
        "@boost.core",
        "@boost.integer",
    ],
)

