cc_library(
    name = "private_hdrs",
    hdrs = glob(
        ["lib/*.h"],
        exclude = ["lib/zip.h"],
    ) + [
        ":lib/config.h",
    ],
    includes = ["lib"],
)

cc_library(
    name = "libzip",
    srcs = ZIP_SOURCES,
    hdrs = [
        "lib/zip.h",
        ":lib/zipconf.h",
    ],
    copts = select({
        "@platforms//os:windows": ["/w"],
        "//conditions:default": ["-w"],
    }),
    implementation_deps = [
        ":private_hdrs",
        "@zlib",
    ] + select({
        ":openssl_enabled": ["@boringssl//:crypto"],
        "//conditions:default": [],
    }) + select({
        ":bzip2_enabled": ["@bzip2//:bz2"],
        "//conditions:default": [],
    }) + select({
        ":lzma_enabled": ["@xz//:lzma"],
        "//conditions:default": [],
    }) + select({
        ":zstd_enabled": ["@zstd"],
        "//conditions:default": [],
    }),
    includes = ["lib"],
    linkopts = select({
        "@platforms//os:windows": [
            "advapi32.lib",
        ],
        "//conditions:default": [],
    }),
    visibility = ["//visibility:public"],
)

exports_files(
