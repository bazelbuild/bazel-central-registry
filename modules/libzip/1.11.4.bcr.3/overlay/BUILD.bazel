        {
            "//:ssl_no_ssl": [],
            "//:ssl_boringssl": [
                "lib/zip_crypto_openssl.c",
                "lib/zip_source_winzip_aes_decode.c",
                "lib/zip_source_winzip_aes_encode.c",
