                "lib/zip_crypto_openssl.c",
                "lib/zip_source_winzip_aes_decode.c",
                "lib/zip_source_winzip_aes_encode.c",
                "lib/zip_winzip_aes.c",
            ],
        },
        no_match_error = "Invalid //:ssl value. Use one of: no_ssl, boringssl, openssl.",
    ) + [
        "lib/zip_algorithm_zstd.c",
    ],
    hdrs = glob(["lib/*.h"]) + [
        "//bazel:config.h",
        "//bazel:zipconf.h",
    ],
    includes = [
        "bazel",
        "lib",
    ],
    linkopts = select({
        ":windows_msvc": ["-defaultlib:advapi32.lib"],
        "@platforms//os:windows": ["-ladvapi32"],
        "//conditions:default": [],
    }),
    local_defines = select(
        {
            "//:ssl_no_ssl": [],
            "//:ssl_boringssl": [
                "HAVE_CRYPTO",
                "HAVE_OPENSSL",
            ],
            "//:ssl_openssl": [
                "HAVE_CRYPTO",
                "HAVE_OPENSSL",
            ],
        },
        no_match_error = "Invalid //:ssl value. Use one of: no_ssl, boringssl, openssl.",
    ),
    deps = [
        "@zlib",
        "@zstd",
    ] + select(
        {
            "//:ssl_no_ssl": [],
            "//:ssl_boringssl": ["@boringssl//:crypto"],
            "//:ssl_openssl": ["@openssl//:crypto"],
        },
        no_match_error = "Invalid //:ssl value. Use one of: no_ssl, boringssl, openssl.",
    ),
)

cc_test(
    name = "zip_smoke_test",
    srcs = ["//bazel:zip_smoke_test.c"],
    deps = [":zip"],
)

cc_binary(
    name = "libzip_pkg_zip_tool",
    srcs = ["//bazel:pkg_zip_tool.c"],
    deps = [":zip"],
)

libzip_pkg_zip(
    name = "pkg_zip_smoke_dep",
    srcs = [
        "LICENSE",
    ],
    out = "pkg_zip_smoke_dep.zip",
    package_dir = "libzip-1.11.4",
)

libzip_pkg_zip(
    name = "pkg_zip_smoke",
    srcs = [
        "README.md",
    ],
    out = "pkg_zip_smoke.zip",
    package_dir = "libzip-1.11.4",
    deps = [":pkg_zip_smoke_dep"],
)
