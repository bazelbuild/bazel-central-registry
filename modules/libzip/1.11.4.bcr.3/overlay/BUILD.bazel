autoconf_hdr(
    name = "config",
    out = "lib/config.h",
    template = ":autoconf_template",
    deps = [":config_checks"],
)

expand_template(
    name = "zipconf",
    out = "lib/zipconf.h",
    substitutions = {
        # Pass along the version number from our MODULE.bazel.
        "${libzip_VERSION}": module_version(),
        "${libzip_VERSION_MAJOR}": module_version().split(".")[0],
        "${libzip_VERSION_MINOR}": module_version().split(".")[1],
        "${libzip_VERSION_PATCH}": module_version().split(".")[2],
        # We're not building a dll.
        "#cmakedefine ZIP_STATIC": "#define ZIP_STATIC 1",
        # Use standard integers.
        "${LIBZIP_TYPES_INCLUDE}": "#include <stdint.h>",
        "${ZIP_INT16_T}": "int16_t",
        "${ZIP_INT32_T}": "int32_t",
        "${ZIP_INT64_T}": "int64_t",
        "${ZIP_INT8_T}": "int8_t",
        "${ZIP_UINT16_T}": "uint16_t",
        "${ZIP_UINT32_T}": "uint32_t",
        "${ZIP_UINT64_T}": "uint64_t",
        "${ZIP_UINT8_T}": "uint8_t",
    },
    template = "zipconf.h.in",
)

