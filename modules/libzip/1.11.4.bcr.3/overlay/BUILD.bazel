load("@bazel_skylib//rules:common_settings.bzl", "bool_flag")
load("@bazel_skylib//rules:expand_template.bzl", "expand_template")
load("@rules_cc//cc:cc_library.bzl", "cc_library")
load("@rules_cc_autoconf//autoconf:autoconf.bzl", "autoconf")
load("@rules_cc_autoconf//autoconf:autoconf_hdr.bzl", "autoconf_hdr")
load("@rules_cc_autoconf//autoconf:checks.bzl", "checks")
load("@rules_license//rules:license.bzl", "license")

package(
    default_applicable_licenses = [":license"],
    default_visibility = ["//visibility:private"],
)

license(
    name = "license",
    package_name = "libzip",
    license_text = "LICENSE",
    visibility = ["//visibility:public"],
)

filegroup(
    name = "all_srcs",
    srcs = glob(["**"]),
    visibility = ["//visibility:public"],
)

bool_flag(
    name = "enable_openssl",  # Per upstream ENABLE_OPENSSL.
    build_setting_default = True,
    visibility = ["//visibility:public"],
)

bool_flag(
    name = "enable_bzip2",  # Per upstream ENABLE_BZIP2.
    build_setting_default = True,
    visibility = ["//visibility:public"],
)

bool_flag(
    name = "enable_lzma",  # Per upstream ENABLE_LZMA.
    build_setting_default = True,
    visibility = ["//visibility:public"],
)

bool_flag(
    name = "enable_zstd",  # Per upstream ENABLE_ZSTD.
    build_setting_default = True,
    visibility = ["//visibility:public"],
)

config_setting(
    name = "openssl_enabled",
    flag_values = {":enable_openssl": "true"},
)

config_setting(
    name = "bzip2_enabled",
    flag_values = {":enable_bzip2": "true"},
)

config_setting(
    name = "lzma_enabled",
    flag_values = {":enable_lzma": "true"},
)

config_setting(
    name = "zstd_enabled",
    flag_values = {":enable_zstd": "true"},
)

# We'll be using rules_cc_autoconf to sense platform-specific details, which
# means we'll need an autoconf-flavored config.h (instead of CMake-flavored).
expand_template(
    name = "autoconf_template",
    out = "autoconf_config.h.in",
    substitutions = {
        # Provide the CMake project name and version.
        "@CMAKE_PROJECT_NAME@": "libzip",
        "@CMAKE_PROJECT_VERSION@": module_version(),
        # Re-spell from CMake-flavored to autoconf-flavored.
        "#cmakedefine": "#undef",
        " ${SIZEOF_OFF_T}": "",
        " ${SIZEOF_SIZE_T}": "",
    },
    template = "config.h.in",
)

