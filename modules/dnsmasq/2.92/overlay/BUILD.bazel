    visibility = ["//visibility:public"],
)

bool_flag(
    name = "tftp",
    build_setting_default = True,
    visibility = ["//visibility:public"],
)

bool_flag(
    name = "script",
    build_setting_default = True,
    visibility = ["//visibility:public"],
)

bool_flag(
    name = "auth",
    build_setting_default = True,
    visibility = ["//visibility:public"],
)

bool_flag(
    name = "ipset",
    build_setting_default = True,
    visibility = ["//visibility:public"],
)

bool_flag(
    name = "loop",
    build_setting_default = True,
    visibility = ["//visibility:public"],
)

bool_flag(
    name = "dumpfile",
    build_setting_default = True,
    visibility = ["//visibility:public"],
)

bool_flag(
    name = "inotify",
    build_setting_default = True,
    visibility = ["//visibility:public"],
)

bool_flag(
    name = "largefile",
    build_setting_default = True,
    visibility = ["//visibility:public"],
