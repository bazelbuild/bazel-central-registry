From c00810a98b377746131472d7a14949cc7b300fb9 Mon Sep 17 00:00:00 2001
From: clintmorris <clintmorris@google.com>
Date: Thu, 9 Apr 2026 03:38:05 +0000
Subject: [PATCH] Add Bazel build and fix C++20/OpenVDB 11 compatibility

---
 BUILD.bazel     | 72 +++++++++++++++++++++++++++++++++++++++++++++++++
 MODULE.bazel    | 14 ++++++++++
 main.cpp        |  8 +++---
 src/io.cpp      |  8 +++---
 src/io.h        |  8 +++---
 src/logger.h    | 10 +++----
 src/process.cpp |  4 +--
 src/process.h   |  2 +-
 8 files changed, 106 insertions(+), 20 deletions(-)
 create mode 100644 BUILD.bazel
 create mode 100644 MODULE.bazel

diff --git a/BUILD.bazel b/BUILD.bazel
new file mode 100644
index 0000000..202a92a
--- /dev/null
+++ b/BUILD.bazel
@@ -0,0 +1,72 @@
+load("@rules_cc//cc:defs.bzl", "cc_binary", "cc_library")
+
+SHARED_COPTS = select({
+    "@platforms//os:windows": [
+        "/std:c++20",
+        "/bigobj",
+        "/W0",
+        "/openmp",
+    ],
+    "//conditions:default": [
+        "-std=c++20",
+        "-Wall",
+        "-fpermissive",
+        "-Wno-error=stringop-overflow",
+        "-Wno-int-in-bool-context",
+        "-Wsign-compare",
+        "-fopenmp",
+    ],
+})
+
+SHARED_LINKOPTS = select({
+    "@platforms//os:windows": [],
+    "//conditions:default": [
+        "-fopenmp",
+        "-pthread",
+    ],
+})
+
+cc_library(
+    name = "coacd_lib",
+    srcs = glob([
+        "src/**/*.cc",
+        "src/**/*.cpp",
+        "public/coacd.cpp",
+    ], allow_empty = True),
+    hdrs = glob([
+        "public/**/*.h",
+        "src/**/*.h",
+        "src/**/*.hpp",
+        "3rd/cdt/CDT/**/*.h",
+        "3rd/cdt/CDT/**/*.hpp",
+    ], allow_empty = True),
+    includes = [
+        "public",
+        "3rd/cdt/CDT",
+    ],
+    defines = [
+        "WITH_3RD_PARTY_LIBS=1",
+        "_USE_MATH_DEFINES",
+    ],
+    copts = SHARED_COPTS,
+    linkopts = SHARED_LINKOPTS,
+    deps = [
+        "@openvdb//:openvdb",
+        "@spdlog//:spdlog",
+        "@fmt//:fmt",
+    ],
+    visibility = ["//visibility:public"],
+)
+
+cc_binary(
+    name = "main",
+    srcs = ["main.cpp"],
+    copts = SHARED_COPTS,
+    linkopts = SHARED_LINKOPTS,
+    deps = [
+        ":coacd_lib",
+        "@openvdb//:openvdb",
+        "@spdlog//:spdlog",
+        "@fmt//:fmt",
+    ],
+)
diff --git a/MODULE.bazel b/MODULE.bazel
new file mode 100644
index 0000000..9e4c3a1
--- /dev/null
+++ b/MODULE.bazel
@@ -0,0 +1,14 @@
+module(
+    name = "coacd",
+    version = "1.0.9",
+    compatibility_level = 1,
+)
+
+bazel_dep(name = "rules_cc", version = "0.2.17")
+bazel_dep(name = "platforms", version = "1.0.0")
+
+bazel_dep(name = "openvdb", version = "11.0.0")
+bazel_dep(name = "spdlog", version = "1.14.1")
+bazel_dep(name = "fmt", version = "11.0.2")
+bazel_dep(name = "onetbb", version = "2022.0.0")
+bazel_dep(name = "zlib", version = "1.3.1.bcr.5")
