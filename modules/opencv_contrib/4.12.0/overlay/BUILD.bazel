        allow_empty = True,
    ),
    hdrs = glob(
        [
            "modules/signal/include/**/*.hpp",
            "modules/signal/include/**/*.h",
        ],
        allow_empty = True,
    ),
    copts = OPENCV_COPTS + OPENCV_OPTIMIZATION_COPTS + select(BASELINE_COPTS) + select(SANITIZATION_COPTS),
