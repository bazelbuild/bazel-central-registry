load("@bazel_skylib//rules:common_settings.bzl", "bool_flag")
load("@bazel_skylib//rules:write_file.bzl", "write_file")
load(
    "@opencv//:opencv.bzl",
    "OPENCV_COPTS",
    "OPENCV_OPTIMIZATION_COPTS",
)
load("@rules_cc//cc:defs.bzl", "cc_library")
load("@rules_license//rules:license.bzl", "license")

package(
    default_applicable_licenses = [":license"],
)

license(
    name = "license",
    license_kinds = ["@rules_license//licenses/spdx:Apache-2.0"],
    license_text = "LICENSE",
)

exports_files([
    "LICENSE",
])

config_setting(
    name = "ubsan_enabled",
    values = {
        "features": "ubsan",
    },
)

config_setting(
    name = "debug_build",
    values = {"compilation_mode": "dbg"},
)

bool_flag(
    name = "enable_nonfree",
    build_setting_default = False,
)

config_setting(
    name = "nonfree_enabled",
    flag_values = {":enable_nonfree": "true"},
)

# Custom base headers target that wraps opencv core to resolve ":_base_headers" dependency
cc_library(
    name = "_base_headers",
    deps = ["@opencv//:core"],
)

BASELINE_COPTS = {
    "@platforms//cpu:x86_64": [
        "-msse",
        "-msse2",
        "-msse3",
    ],
    "@platforms//cpu:armv7": ["-mfpu=neon"],
    "@platforms//cpu:arm64": [],
    "//conditions:default": [],
}

SANITIZATION_COPTS = {
    ":ubsan_enabled": [
        "-fno-sanitize=alignment",
    ],
    "//conditions:default": [],
}

cc_library(
    name = "signal",
    srcs = glob(
        [
            "modules/signal/src/**/*.cpp",
            "modules/signal/src/**/*.hpp",
            "modules/signal/src/**/*.h",
            "modules/signal/src/**/*.inc",
            "modules/signal/src/**/*.inl",
