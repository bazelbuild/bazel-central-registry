cc_library(
    name = "redis_cli_lib",
    srcs = [
        "src/adlist.c",
        "src/ae.c",
        "src/anet.c",
        "src/cli_commands.c",
        "src/cli_common.c",
        "src/crc16.c",
        "src/crc64.c",
        "src/crccombine.c",
        "src/crcspeed.c",
        "src/dict.c",
        "src/monotonic.c",
        "src/mt19937-64.c",
        "src/redis-cli.c",
        "src/redisassert.c",
        "src/release.c",
        "src/siphash.c",
        "src/strl.c",
        "src/zmalloc.c",
    ] + glob(["src/*.h"]) + [
        "release.h",
    ],
    includes = [
        "deps/hiredis",  # Ensure <sds.h> resolves to hiredis to avoid symbol redefinitions.
        "src",
    ],
    textual_hdrs = select({
        "@platforms//os:linux": ["src/ae_epoll.c"],
        "@platforms//os:osx": ["src/ae_kqueue.c"],
    }) + [
        "src/commands.def",
    ],
    deps = [
        ":hdr_histogram",
        ":hiredis",
        ":linenoise",
        ":lua",
        ":xxhash",
    ],
)

cc_binary(
    name = "redis-cli",
    visibility = ["//visibility:public"],
    deps = ["redis_cli_lib"],
)

cc_binary(
    name = "redis-server",
    linkopts = select({
        "@platforms//os:linux": [
            "-ldl",
            "-lpthread",
        ],
        "@platforms//os:osx": [],
    }),
    visibility = ["//visibility:public"],
    deps = [":redis_lib"],
)

filegroup(
    name = "redis",
    srcs = [
        ":redis-cli",
        ":redis-server",
    ],
    visibility = ["//visibility:public"],
)
