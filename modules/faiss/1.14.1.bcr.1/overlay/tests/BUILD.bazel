load("@rules_cc//cc:defs.bzl", "cc_test")
load("@rules_cuda//cuda:defs.bzl", "requires_cuda")

# Smoke test for the faiss C API (`@faiss//:faiss_c`), exercising the public
# <faiss/c_api/...> headers and the C ABI.
cc_test(
    name = "test_c_api",
    size = "small",
    srcs = ["test_c_api.cpp"],
    deps = [
        "@faiss//:faiss_c",
        "@googletest//:gtest_main",
    ],
)

# GPU counterpart of the C API smoke test. `requires_cuda()` makes it compatible
# only when CUDA is enabled and a toolchain is configured, so `bazel test //...`
# builds and runs it locally but the CPU-only BCR CI skips it as incompatible.
# It also needs a GPU at run time (skips gracefully otherwise). On Bazel >= 9,
# build with `--features=external_include_paths` (see faiss/gpu/BUILD.bazel).
cc_test(
    name = "test_c_api_gpu",
    size = "small",
    srcs = ["test_c_api_gpu.cpp"],
    tags = ["requires-gpu"],
    target_compatible_with = requires_cuda(),
    deps = [
        "@faiss//:faiss_c",
        "@googletest//:gtest_main",
    ],
)

# The upstream C++ unit tests, mirroring `FAISS_TEST_SRC` in
# tests/CMakeLists.txt (upstream builds them all into a single `faiss_test`
# binary linked against gtest_main). The SVS-only (test_svs.cpp) and
# dynamic-dispatch-only (test_simd_perf.cpp, test_simd_levels_x86_*.cpp)
# sources are excluded, matching the default CMake configuration.
#
# gtest supports Bazel's test sharding natively, so the single binary is
# sharded to keep per-shard runtime reasonable.
cc_test(
    name = "faiss_test",
    # The slowest shard takes ~7 min on a fast 20-core machine; leave ample
    # headroom for the slower CI workers.
    size = "enormous",
    srcs = [
        "test_NSG_compressed_graph.cpp",
        "test_RCQ_cropping.cpp",
        "test_approx_topk.cpp",
        "test_binary_flat.cpp",
        "test_callback.cpp",
        "test_common_ivf_empty_index.cpp",
        "test_cppcontrib_sa_decode.cpp",
        "test_cppcontrib_uintreader.cpp",
        "test_custom_result_handler.cpp",
        "test_dealloc_invlists.cpp",
        "test_disable_pq_sdc_tables.cpp",
        "test_distances_simd.cpp",
        "test_factory_tools.cpp",
        "test_fast_scan_distance_to_code.cpp",
        "test_fastscan_perf.cpp",
        "test_hamming.cpp",
        "test_heap.cpp",
        "test_hnsw.cpp",
        "test_ivf_index.cpp",
        "test_ivfpq_codec.cpp",
        "test_ivfpq_indexing.cpp",
        "test_lowlevel_ivf.cpp",
        "test_merge.cpp",
        "test_omp_threads.cpp",
        "test_ondisk_ivf.cpp",
        "test_pairs_decoding.cpp",
        "test_params_override.cpp",
        "test_partitioning.cpp",
        "test_pq_code_distance.cpp",
        "test_pq_encoding.cpp",
        "test_pqfs_unaligned.cpp",
        "test_scalar_quantizer.cpp",
        "test_simd_levels.cpp",
        "test_simdlib.cpp",
        "test_sliding_ivf.cpp",
        "test_threaded_index.cpp",
        "test_transfer_invlists.cpp",
        "test_utils.cpp",
        "test_zerocopy.cpp",
        # Shared test helper (Tempfilename etc.).
        "test_util.h",
    ] + select({
        # faiss::MmappedFileMappingOwner only supports Linux, FreeBSD and
        # Windows (see faiss/impl/mapped_io.cpp); it throws "Not implemented"
        # on other platforms such as macOS.
        "@platforms//os:macos": [],
        "//conditions:default": ["test_mmap.cpp"],
    }),
    shard_count = 10,
    deps = [
        "@faiss",
        "@googletest//:gtest_main",
    ],
)
