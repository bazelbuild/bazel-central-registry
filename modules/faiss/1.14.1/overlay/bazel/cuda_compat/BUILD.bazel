load("@rules_cc//cc:defs.bzl", "cc_library")

# Header-only compatibility shims for headers that some CUDA toolkit
# distributions (notably the hermetic CUDA 13.x redistributable) do not ship.
# See cuda_profiler_api.h for details.
cc_library(
    name = "cuda_compat",
    hdrs = ["cuda_profiler_api.h"],
    strip_include_prefix = ".",
    visibility = ["//faiss/gpu:__pkg__"],
)
