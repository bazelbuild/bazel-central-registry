load("@rules_cc//cc:defs.bzl", "cc_library")

package(
    default_package_metadata = ["//:package_metadata"],
    default_visibility = ["//visibility:public"],
)

# OpenMP handling.
#
# The OpenMP runtime is always the hermetic LLVM libomp from the @openmp
# module, which also supplies <omp.h>; there is deliberately NO `-fopenmp` at
# link time, so the toolchain's own runtime (e.g. GCC's libgomp) is never
# pulled in and binaries carry no libgomp.so dependency. The compile-time flag
# is still required to expand the `#pragma omp` directives: `-fopenmp` for
# GCC/Clang on Linux (the generated GOMP_* calls resolve against libomp's GCC
# compatibility layer) and `-Xclang -fopenmp` for Apple Clang on macOS.
OMP_COPTS = select({
    "@platforms//os:linux": ["-fopenmp"],
    "@platforms//os:macos": [
        "-Xclang",
        "-fopenmp",
    ],
    "//conditions:default": [],
})

OMP_DEPS = ["@openmp//:openmp"]

