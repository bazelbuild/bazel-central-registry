# =========================================================================
# ARM NEON SIMD (baseline on aarch64).
# =========================================================================
cc_library(
    name = "faiss_simd_neon",
    srcs = [
        "impl/scalar_quantizer/sq-neon.cpp",
        "utils/simd_impl/distances_aarch64.cpp",
    ],
    hdrs = FAISS_HEADERS,
    copts = ["-DCOMPILE_SIMD_ARM_NEON"] + OMP_COPTS,
    includes = [".."],
    target_compatible_with = ["@platforms//cpu:aarch64"],
    deps = OMP_DEPS,
)

# =========================================================================
# ARM SVE SIMD.
# =========================================================================
cc_library(
    name = "faiss_simd_sve",
    srcs = [
        "impl/pq_code_distance/pq_code_distance-sve.cpp",
        "utils/simd_impl/distances_arm_sve.cpp",
    ],
    hdrs = FAISS_HEADERS,
    copts = [
        "-march=armv8.2-a+sve",
        "-DCOMPILE_SIMD_ARM_SVE",
    ] + OMP_COPTS,
    includes = [".."],
    target_compatible_with = ["@platforms//cpu:aarch64"],
    deps = OMP_DEPS,
)

# =========================================================================
# x86_64 AVX2 SIMD.
# =========================================================================
cc_library(
    name = "faiss_simd_avx2",
    srcs = [
        "impl/pq_code_distance/pq_code_distance-avx2.cpp",
        "impl/scalar_quantizer/sq-avx2.cpp",
        "utils/simd_impl/distances_avx2.cpp",
    ],
    hdrs = FAISS_HEADERS,
    copts = [
        "-mavx2",
        "-mfma",
        "-mf16c",
        "-mpopcnt",
        "-DCOMPILE_SIMD_AVX2",
    ] + OMP_COPTS,
    includes = [".."],
    target_compatible_with = ["@platforms//cpu:x86_64"],
    deps = OMP_DEPS,
)

# =========================================================================
# x86_64 AVX512 SIMD.
# =========================================================================
cc_library(
    name = "faiss_simd_avx512",
    srcs = [
        "impl/pq_code_distance/pq_code_distance-avx512.cpp",
        "impl/scalar_quantizer/sq-avx512.cpp",
        "utils/simd_impl/distances_avx512.cpp",
    ],
    hdrs = FAISS_HEADERS,
    copts = [
        "-mavx512f",
        "-mavx512cd",
        "-mavx512vl",
        "-mavx512dq",
        "-mavx512bw",
        "-mfma",
        "-mf16c",
        "-mpopcnt",
        "-DCOMPILE_SIMD_AVX2",
        "-DCOMPILE_SIMD_AVX512",
    ] + OMP_COPTS,
    includes = [".."],
    target_compatible_with = ["@platforms//cpu:x86_64"],
    deps = OMP_DEPS,
)

# =========================================================================
# Main library: CPU-only. BLAS/LAPACK come from the overridable //:blas
# label_flag; the OpenMP runtime is the hermetic libomp from @openmp.
# =========================================================================
cc_library(
    name = "faiss",
    srcs = FAISS_SRCS,
    hdrs = FAISS_HEADERS,
    copts = ["-DFINTEGER=int"] + OMP_COPTS,
    defines = ["FINTEGER=int"],
    includes = [".."],
    deps = [
        "//:blas",
    ] + OMP_DEPS + select({
        "@platforms//cpu:aarch64": [
            ":faiss_simd_neon",
            ":faiss_simd_sve",
        ],
        "@platforms//cpu:x86_64": [
            ":faiss_simd_avx2",
            ":faiss_simd_avx512",
        ],
        "//conditions:default": [],
    }),
)
