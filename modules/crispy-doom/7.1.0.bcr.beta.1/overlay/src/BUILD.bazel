load("@rules_cc//cc:defs.bzl", "cc_binary", "cc_library")
load("@rules_cc_autoconf//autoconf:autoconf.bzl", "autoconf")
load("@rules_cc_autoconf//autoconf:autoconf_hdr.bzl", "autoconf_hdr")
load(":crispy_config_checks.bzl", "CRISPY_CONFIG_CHECKS")

package(
    default_applicable_licenses = ["//:license"],
)

package_group(
    name = "core_headers_consumers",
    packages = [
        "//opl",
        "//pcsound",
        "//src/doom",
        "//src/heretic",
        "//src/hexen",
        "//src/setup",
        "//src/strife",
        "//textscreen",
    ],
)

package_group(
    name = "setup_consumers",
    packages = ["//src/setup"],
)

package_group(
    name = "game_consumers",
    packages = [
        "//src/doom",
        "//src/heretic",
        "//src/hexen",
        "//src/strife",
    ],
)

cc_library(
    name = "core_headers",
    hdrs = [
        "doomkeys.h",
        ":config_h",
    ],
    strip_include_prefix = ".",
    visibility = [":core_headers_consumers"],
)

autoconf(
    name = "config_checks",
    checks = CRISPY_CONFIG_CHECKS,
)

autoconf_hdr(
    name = "config_h",
    out = "config.h",
    template = "config.h.in",
    deps = [":config_checks"],
)

cc_library(
    name = "common",
    srcs = [
        "crispy.c",
        "i_main.c",
        "i_system.c",
        "m_argv.c",
        "m_misc.c",
    ],
    hdrs = [
        "crispy.h",
        "d_event.h",
        "d_ticcmd.h",
        "doomtype.h",
        "i_system.h",
        "m_argv.h",
        "m_misc.h",
    ],
    copts = select({
        "@platforms//os:windows": ["-DSDL_MAIN_HANDLED"],
        "//conditions:default": [],
    }),
    strip_include_prefix = ".",
    visibility = [
        ":game_consumers",
        ":setup_consumers",
    ],
    deps = [
        ":core_headers",
        ":setup_engine",
        "@sdl2",
    ],
)

cc_library(
    name = "setup_engine",
    srcs = [
        "d_iwad.c",
        "d_mode.c",
        "deh_str.c",
        "i_timer.c",
        "m_config.c",
        "m_controls.c",
