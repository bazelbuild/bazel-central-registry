        "net_sdl.h",
        "net_structrw.h",
        "sha1.h",
        "w_file.h",
        "w_wad.h",
        "z_zone.h",
    ],
    strip_include_prefix = ".",
    visibility = [
        ":game_consumers",
        ":setup_consumers",
    ],
    deps = [
        ":core_headers",
        "@sdl2",
    ],
)

cc_library(
    name = "dehacked",
    srcs = [
        "deh_io.c",
        "deh_main.c",
        "deh_mapping.c",
        "deh_text.c",
    ],
    hdrs = [
        "deh_defs.h",
        "deh_io.h",
        "deh_main.h",
        "deh_mapping.h",
    ],
    strip_include_prefix = ".",
    visibility = [":game_consumers"],
    deps = [
        ":core_headers",
        ":setup_engine",
    ],
)

