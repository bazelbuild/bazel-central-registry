Replace the unconditional `#include <strings.h>` with a Windows-aware
shim. MSVC does not ship POSIX <strings.h>; its case-insensitive string
comparison lives in <string.h> as `_stricmp`. Gating the POSIX include
with `#ifndef _WIN32` and providing a `strcasecmp` alias on Windows
lets libpaper compile under MSVC without any other code changes —
`strcasecmp` is the only symbol libpaper actually consumes from
<strings.h>.

--- a/lib/libpaper.c.in.in
+++ b/lib/libpaper.c.in.in
@@ -28,7 +28,12 @@
 #include <stdio.h>
 #include <errno.h>
 #include <string.h>
+#ifdef _WIN32
+/* MSVC has _stricmp in <string.h>; POSIX strcasecmp is in <strings.h>. */
+#define strcasecmp _stricmp
+#else
 #include <strings.h>
+#endif
 #include <ctype.h>
 #include <locale.h>
 #if defined _GNU_SOURCE && defined LC_PAPER && defined HAVE_NL_PAPER_CONSTANTS
