    ":x86_64": LIBVPX_X86_64_SRCS,
    "//conditions:default": [],
})

_COMMON_COPTS = select({
    "@platforms//os:windows": ["/I."],
    "//conditions:default": ["-iquote."],
}) + select({
    "@platforms//os:windows": [],
    "//conditions:default": [
        "-Wno-conversion",
        "-Wno-parentheses-equality",
        "-Wno-unused-function",
    ],
})

_COMMON_DEFINES = [
    "VPX_MAX_ALLOCABLE_MEMORY=((1ULL<<31)-(1<<21))",
]

_NASM_HDRS = glob([
    "third_party/x86inc/*.asm",
    "vp8/common/x86/*.asm",
    "vp8/encoder/x86/*.asm",
    "vp9/common/x86/*.asm",
    "vp9/encoder/x86/*.asm",
    "vpx_dsp/x86/*.asm",
    "vpx_ports/*.asm",
])

