+  typedef struct _ivl_dir { HANDLE h; WIN32_FIND_DATAA fd; struct dirent de; int first; } DIR;
+  static __inline DIR *opendir(const char *name) {
+    char path[MAX_PATH]; DIR *d;
+    snprintf(path, MAX_PATH, "%s\*", name);
+    d = (DIR*)calloc(1, sizeof(DIR));
+    d->h = FindFirstFileA(path, &d->fd);
+    if (d->h == INVALID_HANDLE_VALUE) { free(d); return NULL; }
+    d->first = 1; return d;
+  }
+  static __inline struct dirent *readdir(DIR *d) {
+    if (d->first) d->first = 0;
+    else if (!FindNextFileA(d->h, &d->fd)) return NULL;
+    strncpy(d->de.d_name, d->fd.cFileName, MAX_PATH);
+    return &d->de;
+  }
+  static __inline int closedir(DIR *d) { FindClose(d->h); free(d); return 0; }
+  static __inline char *strndup(const char *s, size_t n) {
+    size_t l = strlen(s); if (l > n) l = n;
+    char *r = (char*)malloc(l + 1); if (r) { memcpy(r, s, l); r[l] = 0; }
+    return r;
+  }
