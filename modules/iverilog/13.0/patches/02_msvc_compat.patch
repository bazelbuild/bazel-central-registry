diff -ruN a/compat/getopt.h b/compat/getopt.h
--- a/compat/getopt.h	1970-01-01 00:00:00.000000000 +0000
+++ b/compat/getopt.h	2026-04-17 19:06:47.133129549 +0000
@@ -0,0 +1,28 @@
+#ifndef IVL_compat_getopt_H
+#define IVL_compat_getopt_H
+/*
+ * Minimal getopt for systems lacking <getopt.h> and <unistd.h> (e.g. MSVC).
+ * This header is included conditionally by iverilog sources that need
+ * command-line option parsing.
+ */
+#if !defined(HAVE_GETOPT_H) && !defined(HAVE_UNISTD_H)
+#include <string.h>
+static int optind = 1;
+static const char *optarg = 0;
+static int getopt(int argc, char *argv[], const char *fmt) {
+    const char *p;
+    int c;
+    if (optind >= argc || argv[optind][0] != '-' || argv[optind][1] == 0)
+        return -1;
+    c = argv[optind][1];
+    p = strchr(fmt, c);
+    if (!p) { optind++; return '?'; }
+    if (p[1] == ':') {
+        if (argv[optind][2]) { optarg = &argv[optind][2]; optind++; }
+        else if (optind + 1 < argc) { optarg = argv[++optind]; optind++; }
+        else { optind++; return '?'; }
+    } else { optind++; }
+    return c;
+}
+#endif
+#endif /* IVL_compat_getopt_H */
