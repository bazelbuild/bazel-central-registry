diff --git a/driver/main.c b/driver/main.c
--- a/driver/main.c
+++ b/driver/main.c
@@ -1006,6 +1006,18 @@
 static void find_ivl_root(void)
 {
+      /* Allow the IVL_BASE environment variable to override the
+         compiled-in path. This is used by Bazel and other build
+         systems to point the driver at an assembled directory. */
+      {
+            const char *ivl_base_env = getenv("IVL_BASE");
+            if (ivl_base_env != 0) {
+                  strncpy(ivl_root, ivl_base_env, sizeof(ivl_root) - 1);
+                  ivl_root[sizeof(ivl_root) - 1] = '\0';
+                  return;
+            }
+      }
+
 #ifdef __MINGW32__
       const char *ivl_lib_prefix = "\\lib";
       const char *ivl_lib_suffix = "\\ivl" IVL_SUFFIX;
 #else
