        "//tgt-null:null-s.conf": "null-s.conf",
        "//tgt-null:null.conf": "null.conf",
        "//tgt-null:null_tgt": "null.tgt",
        "//tgt-pcb:pcb-s.conf": "pcb-s.conf",
        "//tgt-pcb:pcb.conf": "pcb.conf",
        "//tgt-pcb:pcb_tgt": "pcb.tgt",
        "//tgt-sizer:sizer-s.conf": "sizer-s.conf",
        "//tgt-sizer:sizer.conf": "sizer.conf",
        "//tgt-sizer:sizer_tgt": "sizer.tgt",
        "//tgt-stub:stub-s.conf": "stub-s.conf",
        "//tgt-stub:stub.conf": "stub.conf",
        "//tgt-stub:stub_tgt": "stub.tgt",
        "//tgt-vhdl:vhdl-s.conf": "vhdl-s.conf",
