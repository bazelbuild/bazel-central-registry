# =============================================================================
# IVL Base Directory
# =============================================================================
# Assembles the flat directory that the iverilog driver expects at IVL_BASE.
# Contains the compiler backend, preprocessor, target code generators,
# VPI modules, config files, and include headers.

ivl_base(
    name = "ivl_base",
    files = {
        # Include files
        "//:constants.vams": "include/constants.vams",
        "//:disciplines.vams": "include/disciplines.vams",
        # Binaries
        "//:ivl": "ivl",
        "//ivlpp:ivlpp": "ivlpp",
        "//tgt-blif:blif-s.conf": "blif-s.conf",
        "//tgt-blif:blif.conf": "blif.conf",
