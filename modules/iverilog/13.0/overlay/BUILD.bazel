    name = "ivl_alloc",
    hdrs = ["ivl_alloc.h"],
    visibility = ["//:__subpackages__"],
)

cc_library(
    name = "compat_getopt",
    hdrs = ["compat/getopt.h"],
    includes = ["."],
    visibility = ["//:__subpackages__"],
)

# --- _pli_types.h ---

autoconf_hdr(
    name = "gen_pli_types_h",
    out = "_pli_types.h",
    # Refactor legacy autoconf style to modern `#undef`
    substitutions = {
        "# define SIZEOF_UNSIGNED 4": "# undef SIZEOF_UNSIGNED",
        "# define SIZEOF_UNSIGNED_LONG 8": "# undef SIZEOF_UNSIGNED_LONG",
        "# define SIZEOF_UNSIGNED_LONG_LONG 8": "# undef SIZEOF_UNSIGNED_LONG_LONG",
    },
    template = "_pli_types.h.in",
    deps = [":autoconf"],
)

cc_library(
    name = "pli_types",
    hdrs = [":gen_pli_types_h"],
)

# --- version_tag.h ---

package_info(
    name = "package_info",
    module_bazel = "MODULE.bazel",
    strip_bcr_version = True,
)

write_file(
    name = "gen_version_tag_h_in",
    out = "version_tag.h.in",
    content = [
        "#define VERSION_TAG \"v@PACKAGE_VERSION@\"",
        "",
    ],
)

autoconf_hdr(
    name = "gen_version_tag_h_ac",
    out = "version_tag.h.ac",
    template = ":gen_version_tag_h_in",
    deps = [":package_info"],
)

expand_template(
    name = "gen_version_tag_h",
    out = "version_tag.h",
    substitutions = {".": "_"},
    template = ":gen_version_tag_h_ac",
)

cc_library(
    name = "version_tag",
    hdrs = [
        "version_base.h",
        ":gen_version_tag_h",
    ],
    visibility = ["//:__subpackages__"],
)

