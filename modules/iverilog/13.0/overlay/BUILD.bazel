# On Windows, DLLs must resolve all symbols at link time.  The upstream
# Makefile handles this by building ivl.exe with --out-implib, generating
# an import library that tgt plugins link against.  cc_shared_library is
# the Bazel equivalent: it produces a shared library + interface library
# (import lib on Windows).  tgt plugins use dynamic_deps to link against
# the interface library only, avoiding code duplication.
cc_shared_library(
    name = "libivl",
    exports_filter = ["//:__subpackages__"],
    visibility = ["//:__subpackages__"],
    win_def_file = "ivl.def",
    deps = [":lib/ivl"],
)

cc_binary(
    name = "ivl",
    linkopts = PLUGIN_HOST_LINKOPTS,
    visibility = ["//visibility:public"],
    deps = [":lib/ivl"],
)

