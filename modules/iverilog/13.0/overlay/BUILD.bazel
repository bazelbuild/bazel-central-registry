# =============================================================================
# ivl - Core Compiler
# =============================================================================
# The ivl sources are in a cc_library so that tgt plugins can link against it
# on Windows.  On Windows, DLLs cannot have unresolved symbols; the upstream
# Makefile handles this by building ivl.exe with --out-implib and having tgt
# plugins link against the resulting import library.  In Bazel, win_def_file
# on the cc_library achieves the same effect: it produces an interface library
# that the tgt plugins link against, while ivl statically links the full code.

cc_library(
    name = "lib/ivl",
