# Single consolidated autoconf target with ALL checks from configure.ac.
# Each autoconf_hdr below references this target and only substitutes
# the #undef lines present in its own .h.in template.
autoconf(
    name = "autoconf",
    checks = macros.AC_CHECK_HEADERS([
        "alloca.h",
        "dlfcn.h",
        "dl.h",
        "getopt.h",
        "inttypes.h",
        "iosfwd",
        "libiberty.h",
        "stdint.h",
        "stdlib.h",
        "string.h",
        "strings.h",
        "sys/resource.h",
        "sys/stat.h",
        "sys/types.h",
        "sys/wait.h",
        "unistd.h",
    ]) + macros.AC_CHECK_FUNCS([
        "fchmod",
        "fmax",
        "fmin",
        "fopen64",
        "fseeko",
        "llround",
        "lround",
        "nan",
        "realpath",
        "times",
    ]) + [
        checks.AC_CHECK_SIZEOF(
            "unsigned long long",
            define = "SIZEOF_UNSIGNED_LONG_LONG",
        ),
        checks.AC_CHECK_SIZEOF(
            "unsigned long",
            define = "SIZEOF_UNSIGNED_LONG",
        ),
        checks.AC_CHECK_SIZEOF(
            "unsigned",
            define = "SIZEOF_UNSIGNED",
        ),
        checks.AC_CHECK_SIZEOF(
            "void *",
            define = "SIZEOF_VOID_P",
        ),
        checks.AC_CHECK_LIB("z", "compress"),
        checks.AC_CHECK_LIB("bz2", "BZ2_bzdopen"),
        checks.AC_CHECK_LIB("pthread", "pthread_create"),
        checks.AC_DEFINE("_LARGEFILE_SOURCE", 1),
        checks.AC_DEFINE("_LARGEFILE64_SOURCE", 1),
        checks.AC_DEFINE("STDC_HEADERS", 1),
        # Check whether uint64_t and unsigned long are the same type.
        # On macOS (Darwin), uint64_t is unsigned long long, so they
        # differ even though both are 64-bit.  On Linux, uint64_t is
        # unsigned long.  The vvp runtime uses this to avoid duplicate
        # template instantiations.
        checks.AC_TRY_COMPILE(
            code = """\
#include <inttypes.h>
template<class T,class U>struct same{enum{v=0};};
template<class T>struct same<T,T>{enum{v=1};};
int arr[same<uint64_t,unsigned long>::v ? 1 : -1];
""",
            define = "UINT64_T_AND_ULONG_SAME",
            language = "cpp",
        ),
        checks.AC_DEFINE(
            "LINUX",
            condition = "ac_cv_header_sys_resource_h",
            if_false = None,
            if_true = 1,
        ),
    ],
    visibility = ["//:__subpackages__"],
    deps = [
        "@rules_cc_autoconf//autoconf/macros/AC_C_BIGENDIAN",
    ],
)

