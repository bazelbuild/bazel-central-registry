load("@rules_cc//cc:cc_test.bzl", "cc_test")

_CXX_STD = select({
    "@rules_cc//cc/compiler:msvc-cl": ["/std:c++17"],
    "//conditions:default": ["-std=c++17"],
})

_SSE2_COPTS = _CXX_STD + select({
    "@platforms//cpu:x86_32": ["-msse2"],
    "@platforms//cpu:x86_64": ["-msse2"],
    "//conditions:default": [],
})

cc_test(
    name = "headertest",
    srcs = [
        "headertest/collision.cpp",
        "headertest/colors.cpp",
        "headertest/core.cpp",
        "headertest/main.cpp",
        "headertest/packed.cpp",
    ],
    copts = _SSE2_COPTS,
    deps = ["@directxmath"],
)

cc_test(
    name = "math3",
    srcs = [
        "math3/box.cpp",
        "math3/constexpr.cpp",
        "math3/frustum.cpp",
        "math3/math3.cpp",
        "math3/math3.h",
        "math3/math3tests.cpp",
        "math3/obox.cpp",
        "math3/shared.cpp",
        "math3/sphere.cpp",
        "math3/triangle.cpp",
        "math3/xmcolor.cpp",
        "math3/xmmat.cpp",
        "math3/xmquat.cpp",
        "math3/xmvec.cpp",
        "math3/xmvec234.cpp",
    ],
    copts = _SSE2_COPTS,
    # Upstream tests are Windows/MSVC-only. XMVector2TransformCoordStream has
    # a known precision failure on GCC.
    target_compatible_with = ["@platforms//os:windows"],
    deps = ["@directxmath"],
)

cc_test(
    name = "stacktest",
    srcs = ["stacktest/main.cpp"],
    copts = _SSE2_COPTS,
    deps = ["@directxmath//:matrixstack"],
)

cc_test(
    name = "xdsptest",
    srcs = ["xdsp/Test.cpp"],
    copts = _SSE2_COPTS,
    # xdsp/Test.cpp uses _aligned_malloc/<malloc.h>/std::aligned_alloc shims
    # that are broken on macOS and older Linux (debian 10/11).
    target_compatible_with = ["@platforms//os:windows"],
    deps = ["@directxmath//:xdsp"],
)

cc_test(
    name = "shmathtest",
    srcs = [
        "shmath/coeff.cpp",
        "shmath/test.cpp",
    ],
    copts = _SSE2_COPTS,
    deps = ["@directxmath//:shmath"],
)

cc_test(
    name = "testavx",
    srcs = ["ext/testavx.cpp"],
    copts = _CXX_STD + ["-mavx"],
    target_compatible_with = ["@platforms//cpu:x86_64"],
    deps = ["@directxmath//:extensions"],
)

cc_test(
    name = "testavx2",
    srcs = ["ext/testavx2.cpp"],
    copts = _CXX_STD + [
        "-mavx2",
        "-mfma",
        "-mf16c",
    ],
    target_compatible_with = ["@platforms//cpu:x86_64"],
    deps = ["@directxmath//:extensions"],
)

cc_test(
    name = "testsse3",
    srcs = ["ext/testsse3.cpp"],
    copts = _CXX_STD + ["-msse3"],
    target_compatible_with = ["@platforms//cpu:x86_64"],
    deps = ["@directxmath//:extensions"],
)

cc_test(
    name = "testsse4",
    srcs = ["ext/testsse4.cpp"],
    copts = _CXX_STD + ["-msse4.1"],
    target_compatible_with = ["@platforms//cpu:x86_64"],
    deps = ["@directxmath//:extensions"],
)

cc_test(
    name = "testf16c",
    srcs = ["ext/testf16c.cpp"],
    copts = _CXX_STD + ["-mf16c"],
    target_compatible_with = ["@platforms//cpu:x86_64"],
    deps = ["@directxmath//:extensions"],
)

cc_test(
    name = "testfma3",
    srcs = ["ext/testfma3.cpp"],
    copts = _CXX_STD + ["-mfma"],
    target_compatible_with = ["@platforms//cpu:x86_64"],
    deps = ["@directxmath//:extensions"],
)

cc_test(
    name = "testbe",
    srcs = ["ext/testbe.cpp"],
    copts = _CXX_STD + ["-mssse3"],
    target_compatible_with = ["@platforms//cpu:x86_64"],
    deps = ["@directxmath//:extensions"],
)

test_suite(
    name = "all",
    tests = [
        ":headertest",
        ":shmathtest",
        ":stacktest",
        ":testavx",
        ":testavx2",
        ":testbe",
        ":testf16c",
        ":testfma3",
        ":testsse3",
        ":testsse4",
    ],
    visibility = ["//visibility:public"],
)
