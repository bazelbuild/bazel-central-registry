+/** returns the flags that were used to build SCIP */
+const char* SCIPgetBuildFlags(
+   void
+   )
+{
+   return " ARCH=x86_64\n\
+ OSTYPE=Linux-6.18.14-1rodete3-amd64\n\
+ COMP=GNU 15.2.0\n\
+ BUILD=Release\n\
+ CHECKSTAGE=AUTO\n\
+ DEBUGSOL=OFF\n\
+ EXPRINT=none\n\
+ SYM=none\n\
+ GMP=OFF\n\
+ CONOPT=OFF\n\
+ IPOPT=OFF\n\
+ WORHP=OFF\n\
+ LPS=spx\n\
+ LPSCHECK=OFF\n\
+ LTO=OFF\n\
+ NOBLKBUFMEM=OFF\n\
+ NOBLKMEM=OFF\n\
+ NOBUFMEM=OFF\n\
+ THREADSAFE=ON;FORCE\n\
+ READLINE=OFF\n\
+ SANITIZE=OFF\n\
+ SHARED=OFF\n\
+ VERSION=10.0.3\n\
+ API_VERSION=156\n\
+ ZIMPL=OFF\n\
+ ZLIB=ON";
+}
