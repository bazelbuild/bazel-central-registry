+++ b/src/tinycthread/tinycthread.c	2026-05-27 10:13:40.162171965 +0200
@@ -893,7 +893,7 @@
 #endif /* _TTHREAD_EMULATE_TIMESPEC_GET_ */
 
 #if defined(_TTHREAD_WIN32_)
-void call_once(once_flag *flag, void (*func)(void))
+void TNY_call_once(TNY_once_flag *flag, void (*func)(void))
 {
   /* The idea here is that we use a spin lock (via the
      InterlockedCompareExchange function) to restrict access to the
diff -ruN a/src/tinycthread/tinycthread.h b/src/tinycthread/tinycthread.h
--- a/src/tinycthread/tinycthread.h	2025-07-18 10:30:46.000000000 +0200
