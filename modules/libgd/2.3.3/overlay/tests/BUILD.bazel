"""Tests for libgd using the upstream test framework."""

load("@rules_cc//cc:cc_library.bzl", "cc_library")
load("@rules_cc//cc:cc_test.bzl", "cc_test")

cc_library(
    name = "gdtest",
    testonly = True,
    srcs = ["gdtest/gdtest.c"] + select({
        "@platforms//os:windows": ["gdtest/readdir.c"],
        "//conditions:default": [],
    }),
    hdrs = ["gdtest/gdtest.h"] + select({
        "@platforms//os:windows": ["gdtest/readdir.h"],
        "//conditions:default": [],
    }),
    copts = select({
        "@rules_cc//cc/compiler:msvc-cl": ["/w"],
        "//conditions:default": ["-w"],
    }),
    includes = ["gdtest"],
    local_defines = [
        'GDTEST_TOP_DIR=\\".\\"',
        "HAVE_SYS_TYPES_H",
    ] + select({
        "@platforms//os:windows": [],
        "//conditions:default": [
            "HAVE_DIRENT_H",
            "HAVE_STDINT_H",
            "HAVE_SYS_STAT_H",
            "HAVE_UNISTD_H",
        ],
    }),
    deps = ["//:gd_internal"],
)

# Self-contained tests that exercise core libgd functionality without
# requiring optional format dependencies or reference image files.

cc_test(
    name = "bug00340_test",
    srcs = ["gdimagecreate/bug00340.c"],
    deps = [":gdtest"],
)

cc_test(
    name = "gdcolormaplookup_test",
    srcs = ["gdcolormaplookup/gdcolormaplookup.c"],
    deps = [":gdtest"],
)

cc_test(
    name = "gdimageclone_bug00300_test",
    srcs = ["gdimageclone/bug00300.c"],
    deps = [":gdtest"],
)

cc_test(
    name = "gdimagecrop_bug00432_test",
    srcs = ["gdimagecrop/bug00432.c"],
    deps = [":gdtest"],
)

cc_test(
    name = "gdimagefilledrectangle_bug00106_test",
    srcs = ["gdimagefilledrectangle/bug00106_gdimagefilledrectangle.c"],
    deps = [":gdtest"],
)

cc_test(
    name = "gdimagescale_overflow_test",
    srcs = ["gdimagescale/bug_overflow_large_new_size.c"],
    deps = [":gdtest"],
)
