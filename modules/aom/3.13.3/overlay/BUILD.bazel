# -- Compound conditions ---------------------------------------------------

selects.config_setting_group(
    name = "encoder_non_rt",
    match_all = [
        ":encoder_enabled",
        ":realtime_only_disabled",
    ],
)

selects.config_setting_group(
    name = "encoder_and_hbd",
    match_all = [
        ":encoder_enabled",
        ":highbitdepth_enabled",
    ],
)

selects.config_setting_group(
    name = "encoder_non_rt_and_hbd",
    match_all = [
        ":encoder_enabled",
        ":realtime_only_disabled",
        ":highbitdepth_enabled",
    ],
)

selects.config_setting_group(
    name = "x86_64_encoder",
    match_all = [
        "@platforms//cpu:x86_64",
        ":encoder_enabled",
    ],
)

selects.config_setting_group(
    name = "x86_64_highway",
    match_all = [
        "@platforms//cpu:x86_64",
        ":highway_enabled",
    ],
)

selects.config_setting_group(
    name = "aarch64_encoder",
    match_all = [
        "@platforms//cpu:aarch64",
        ":encoder_enabled",
    ],
)

# config_setting (not config_setting_group) so that the windows_*
# variants below are recognised as specialisations by select().
config_setting(
    name = "encoder_and_highway",
    flag_values = {
        ":CONFIG_AV1_ENCODER": "True",
        ":CONFIG_HIGHWAY": "True",
    },
)

selects.config_setting_group(
    name = "encoder_no_highway",
    match_all = [
        ":encoder_enabled",
        ":highway_disabled",
    ],
)

# MSVC /arch:AVX512 does not define the Ice Lake extension macros
# (__AVX512VNNI__ etc.) that Highway's HWY_AVX3_DL baseline requires,
# so highway AVX-512 sources cannot be compiled on Windows.
# These are config_setting (not config_setting_group) so Bazel
# recognises them as specialisations of highway_enabled /
# encoder_and_highway respectively.
config_setting(
    name = "windows_highway",
    constraint_values = ["@platforms//os:windows"],
    flag_values = {":CONFIG_HIGHWAY": "True"},
)

config_setting(
    name = "windows_encoder_and_highway",
    constraint_values = ["@platforms//os:windows"],
    flag_values = {
        ":CONFIG_AV1_ENCODER": "True",
        ":CONFIG_HIGHWAY": "True",
    },
)

