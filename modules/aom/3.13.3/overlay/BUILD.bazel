        ":encoder_enabled": [
            "aom_dsp/x86/fwd_txfm_ssse3_x86_64.asm",
            "aom_dsp/x86/quantize_ssse3_x86_64.asm",
            "aom_dsp/x86/subpel_variance_ssse3.asm",
        ],
        "//conditions:default": [],
    }),
    hdrs = _NASM_HDRS,
    copts = _NASM_COPTS,
    includes = ["."],
    preincs = [":aom_config_asm"],
    tags = ["manual"],
