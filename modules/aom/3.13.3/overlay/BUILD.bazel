# -- RTCD generated headers ------------------------------------------------

perl_binary(
    name = "rtcd_pl",
    srcs = ["build/cmake/rtcd.pl"],
    main = "build/cmake/rtcd.pl",
)

# MSVC /arch:AVX512 does not define the Ice Lake extension macros
# (__AVX512VNNI__ etc.) that Highway's HWY_AVX3_DL baseline requires.
# Disable AVX-512 RTCD dispatch on Windows so highway AVX-512 sources
# are not referenced.
_RTCD_DISABLE = [
    "sve",
    "sve2",
] + select({
    "@platforms//os:windows": ["avx512"],
    "//conditions:default": [],
})

rtcd_gen(
    name = "gen_aom_dsp_rtcd_h",
    out = "config/aom_dsp_rtcd.h",
    arch = select({
        "@platforms//cpu:aarch64": "arm64",
        "@platforms//cpu:x86_64": "x86_64",
    }),
    config = ":aom_config_h",
    defs = "aom_dsp/aom_dsp_rtcd_defs.pl",
    disable = _RTCD_DISABLE,
    rtcd_script = ":rtcd_pl",
    sym = "aom_dsp_rtcd",
)

rtcd_gen(
    name = "gen_aom_scale_rtcd_h",
    out = "config/aom_scale_rtcd.h",
    arch = select({
        "@platforms//cpu:aarch64": "arm64",
        "@platforms//cpu:x86_64": "x86_64",
    }),
    config = ":aom_config_h",
    defs = "aom_scale/aom_scale_rtcd.pl",
    disable = _RTCD_DISABLE,
    rtcd_script = ":rtcd_pl",
    sym = "aom_scale_rtcd",
)

rtcd_gen(
    name = "gen_av1_rtcd_h",
    out = "config/av1_rtcd.h",
    arch = select({
        "@platforms//cpu:aarch64": "arm64",
        "@platforms//cpu:x86_64": "x86_64",
    }),
    config = ":aom_config_h",
    defs = "av1/common/av1_rtcd_defs.pl",
    disable = _RTCD_DISABLE,
    rtcd_script = ":rtcd_pl",
    sym = "av1_rtcd",
)

# -- Source headers (not compiled, provides include paths) ------------------

cc_library(
    name = "aom_headers",
    hdrs = glob([
        "aom/**/*.h",
        "aom_dsp/**/*.h",
        "aom_mem/**/*.h",
        "aom_ports/**/*.h",
        "aom_scale/**/*.h",
        "aom_util/**/*.h",
        "av1/**/*.h",
        "av1/**/*.inc",
        "common/**/*.h",
        "third_party/fastfeat/*.h",
        "third_party/vector/*.h",
        "third_party/SVT-AV1/*.h",
    ]),
    includes = ["."],
)

# -- Config library (generated headers + aom_config.c) ---------------------

cc_library(
    name = "aom_config",
    srcs = [":aom_config_c"],
    hdrs = [
        ":aom_config_h",
        ":aom_version_h",
        ":gen_aom_dsp_rtcd_h",
        ":gen_aom_scale_rtcd_h",
        ":gen_av1_rtcd_h",
    ],
    includes = ["."],
    deps = [":aom_headers"],
)

# -- Common compiler options -----------------------------------------------

# C-only standard flag. Targets that contain C++ sources (.cc) must NOT
# use this — macOS Clang rejects -std=gnu11 for C++ compilation.
_C_STD = select({
    "@platforms//os:windows": [],
    "//conditions:default": ["-std=gnu11"],
})

_COPTS = select({
    "@platforms//os:macos": [
        "-w",
        "-UNDEBUG",
    ],
    "@platforms//os:windows": [
        "/w",
        "-D_WIN32_WINNT=0x0601",
        "-D_CRT_SECURE_NO_WARNINGS",
    ],
    "//conditions:default": [
        "-w",
    ],
})

_CONLYOPTS = _COPTS + _C_STD

_CXXOPTS = _COPTS

# MSVC enables SSE2-SSE4.2 by default on x86_64; only AVX/AVX2 need flags.
_SIMD_SSE2 = select({
    "@platforms//os:windows": [],
    "//conditions:default": ["-msse2"],
})

_SIMD_SSE3 = select({
    "@platforms//os:windows": [],
    "//conditions:default": ["-msse3"],
})

_SIMD_SSSE3 = select({
    "@platforms//os:windows": [],
    "//conditions:default": ["-mssse3"],
})

_SIMD_SSE4_1 = select({
    "@platforms//os:windows": [],
    "//conditions:default": ["-msse4.1"],
})

_SIMD_SSE4_2 = select({
    "@platforms//os:windows": [],
    "//conditions:default": ["-msse4.2"],
})

_SIMD_AVX = select({
    "@platforms//os:windows": ["/arch:AVX"],
    "//conditions:default": ["-mavx"],
})

_SIMD_AVX2 = select({
    "@platforms//os:windows": ["/arch:AVX2"],
    "//conditions:default": ["-mavx2"],
})

# =========================================================================
# NASM assembly targets (x86_64 only)
# =========================================================================

_NASM_COPTS = ["-DPIC"] + select({
    "@platforms//os:macos": ["-DPREFIX"],
    "//conditions:default": [],
})

_NASM_HDRS = [
    "aom_ports/x86_abi_support.asm",
    "third_party/x86inc/x86inc.asm",
]

nasm_library(
    name = "nasm_dsp_sse2",
    srcs = [
        # Common
        "aom_dsp/x86/intrapred_asm_sse2.asm",
    ] + select({
        ":highbitdepth_enabled": [
            # Common HBD
            "aom_dsp/x86/aom_high_subpixel_8t_sse2.asm",
            "aom_dsp/x86/aom_high_subpixel_bilinear_sse2.asm",
            "aom_dsp/x86/highbd_intrapred_asm_sse2.asm",
        ],
        "//conditions:default": [],
    }) + select({
        ":encoder_enabled": [
            "aom_dsp/x86/sad4d_sse2.asm",
            "aom_dsp/x86/sad_sse2.asm",
            "aom_dsp/x86/ssim_sse2_x86_64.asm",
            "aom_dsp/x86/subtract_sse2.asm",
        ],
        "//conditions:default": [],
    }) + select({
        ":encoder_and_hbd": [
            "aom_dsp/x86/highbd_sad4d_sse2.asm",
            "aom_dsp/x86/highbd_sad_sse2.asm",
            "aom_dsp/x86/highbd_subpel_variance_impl_sse2.asm",
            "aom_dsp/x86/highbd_variance_impl_sse2.asm",
        ],
        "//conditions:default": [],
    }),
    hdrs = _NASM_HDRS,
    copts = _NASM_COPTS,
    includes = ["."],
    preincs = [":aom_config_asm"],
    tags = ["manual"],
)

nasm_library(
    name = "nasm_dsp_ssse3",
    srcs = [
        # Common
        "aom_dsp/x86/aom_subpixel_8t_ssse3.asm",
