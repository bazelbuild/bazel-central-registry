load("@bazel_skylib//lib:selects.bzl", "selects")
load("@rules_cc//cc:cc_library.bzl", "cc_library")
load("@rules_cc//cc:cc_test.bzl", "cc_test")

_COPTS = select({
    "@platforms//os:windows": [
        "/w",
        "/std:c++17",
    ],
    "//conditions:default": [
        "-w",
        "-std=gnu++17",
    ],
})

# test_libaom.cc provides main() with RTCD initialization (runtime CPU
# dispatch table setup) — required before any SIMD-optimized function
# pointers can be called.
_TEST_MAIN = ["test_libaom.cc"]

_TEST_DEPS = [
    ":test_utils",
    "@aom",
    "@googletest//:gtest",
]

cc_library(
    name = "test_utils",
    testonly = True,
    srcs = [
        "av1_txfm_test.cc",
        "decode_test_driver.cc",
        "encode_test_driver.cc",
        "hiprec_convolve_test_util.cc",
        "test_vectors.cc",
        "warp_filter_test_util.cc",
    ],
    hdrs = [
        "acm_random.h",
        "av1_txfm_test.h",
        "codec_factory.h",
        "datarate_test.h",
        "decode_test_driver.h",
        "encode_test_driver.h",
        "function_equivalence_test.h",
        "hiprec_convolve_test_util.h",
        "i420_video_source.h",
        "ivf_video_source.h",
        "register_state_check.h",
        "simd_cmp_impl.inc",
        "simd_impl.h",
        "test_vectors.h",
        "transform_test_base.h",
        "util.h",
        "video_source.h",
        "warp_filter_test_util.h",
        "yuv_video_source.h",
    ],
    copts = _COPTS,
    include_prefix = "test",
    deps = [
        "@aom",
        "@googletest//:gtest",
    ],
)

cc_library(
    name = "simd_cmp_sse2",
    testonly = True,
    srcs = ["simd_cmp_sse2.cc"],
    copts = _COPTS + select({
        "@platforms//os:windows": [],
        "//conditions:default": ["-msse2"],
    }),
    tags = ["manual"],
    deps = [
        ":test_utils",
        "@aom",
        "@googletest//:gtest",
    ],
)

cc_library(
    name = "simd_cmp_ssse3",
    testonly = True,
    srcs = ["simd_cmp_ssse3.cc"],
    copts = _COPTS + select({
        "@platforms//os:windows": [],
        "//conditions:default": ["-mssse3"],
    }),
    tags = ["manual"],
    deps = [
        ":test_utils",
        "@aom",
        "@googletest//:gtest",
    ],
)

cc_library(
    name = "simd_cmp_sse4_1",
    testonly = True,
    srcs = ["simd_cmp_sse4.cc"],
    copts = _COPTS + select({
        "@platforms//os:windows": [],
        "//conditions:default": ["-msse4.1"],
    }),
    tags = ["manual"],
    deps = [
        ":test_utils",
        "@aom",
        "@googletest//:gtest",
    ],
)

cc_library(
    name = "simd_cmp_avx2",
    testonly = True,
    srcs = ["simd_cmp_avx2.cc"],
    copts = _COPTS + select({
        "@platforms//os:windows": ["/arch:AVX2"],
        "//conditions:default": ["-mavx2"],
    }),
    tags = ["manual"],
    deps = [
        ":test_utils",
        "@aom",
        "@googletest//:gtest",
    ],
)

