selects.config_setting_group(
    name = "gcc_aarch64",
    match_all = [
        "@rules_cc//cc/compiler:gcc",
        "@platforms//cpu:aarch64",
    ],
)

# GCC -O2 miscompiles cfl_predict_lbd_neon for 32-wide blocks on aarch64
# (GCC 11.x register allocation bug with NEON intrinsics).
cc_test(
    name = "cfl_test",
    size = "large",
    srcs = _TEST_MAIN + ["cfl_test.cc"],
    copts = _COPTS,
    target_compatible_with = select({
        ":gcc_aarch64": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    deps = _TEST_DEPS,
)

# -- Sharded tests (heavily parameterized, need parallel shards) -----------

_SHARDED_TESTS = [
    "av1_convolve_test",
    "av1_fwd_txfm2d_test",
    "av1_highbd_iht_test",
    "av1_inv_txfm2d_test",
    "av1_wedge_utils_test",
    "cdef_test",
    "cnn_test",
    "comp_mask_pred_test",
    "convolve_test",
    "frame_size_tests",
    "lpf_test",
    "quantize_func_test",
    "sad_test",
    "variance_test",
    "warp_filter_test",
]

[
    cc_test(
        name = test,
        size = "enormous",
        timeout = "long",
        srcs = _TEST_MAIN + [test + ".cc"],
        copts = _COPTS,
        shard_count = 10,
        deps = _TEST_DEPS,
    )
    for test in _SHARDED_TESTS
]

# -- x86_64 SSE4.1 intrinsic tests ----------------------------------------

[
    cc_test(
        name = test,
        size = "large",
        srcs = _TEST_MAIN + [test + ".cc"],
        copts = _COPTS + select({
            "@platforms//os:windows": [],
            "//conditions:default": ["-msse4.1"],
        }),
        target_compatible_with = ["@platforms//cpu:x86_64"],
        deps = _TEST_DEPS,
    )
    for test in [
        "av1_quantize_test",
        "corner_match_test",
    ]
]

