# C++17 flag selection based on the active C++ compiler. MSVC and clang-cl
# use the `/std:` form; GCC and clang use `-std=`. Keep this aligned with
# bazel/llvm_utils.bzl's _CXX_OPTS — that one is platform-keyed (Windows
# implies MSVC ABI) and is correct for the LLVM transition.
_CXX17_COPTS = select({
    "@rules_cc//cc/compiler:clang-cl": ["/std:c++17"],
    "@rules_cc//cc/compiler:msvc-cl": ["/std:c++17"],
    "//conditions:default": ["-std=c++17"],
})

# ===========================================================================
# Backend selection
#
# string_flag "backend" selects the ortho code generation backend:
#   mcode    (default) — custom x86 JIT code generator (x86-only)
#   llvm-jit — LLVM-based JIT via MCJIT (cross-architecture)
#
# Use the transition targets (ghdl_mcode, ghdl_llvm_jit) to build with
# a specific backend without passing flags on the command line.
#
# mcode emits x86 machine code at runtime, so on non-x86_64 CPUs we silently
# fall back to llvm-jit even when `--//:backend=mcode` is set (the keys below
# encode that: `_mcode_on_x86_64` requires both the flag AND the CPU; the
# generic `use_mcode` is kept for human reference but the build never reads
# it in a select). The mcode-only build targets are marked
# `target_compatible_with = ["@platforms//cpu:x86_64"]` so wildcard builds
# (`@ghdl//...`) skip them cleanly on arm64 / other CPUs.
# ===========================================================================

string_flag(
    name = "backend",
    build_setting_default = "mcode",
    values = [
        "llvm-jit",
        "mcode",
    ],
    visibility = ["//visibility:public"],
)

config_setting(
    name = "use_mcode",
    flag_values = {":backend": "mcode"},
)

config_setting(
    name = "use_llvm_jit",
    flag_values = {":backend": "llvm-jit"},
)

# Real key used by the alias / linkopts selects: backend=mcode AND CPU=x86_64.
# On any other CPU this never matches, so the build silently uses llvm-jit
# even with the default flag value.
config_setting(
    name = "_mcode_on_x86_64",
    constraint_values = ["@platforms//cpu:x86_64"],
    flag_values = {":backend": "mcode"},
)

