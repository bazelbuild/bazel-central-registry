# Force the entire LLVM dependency closure to be built with C++17.
# LLVM 17+ source uses `std::string_view` etc. which requires C++17,
# and the default toolchain on many platforms still picks C++14, so we
# transition rather than relying on a user-supplied --cxxopt.
cc_stdcc17_transitioned_library(
    name = "llvm_cbindings",
    target = ":_llvm_cbindings_raw",
)

# ===========================================================================
# Common Ada sources shared between backends
# ===========================================================================

_COMMON_SRCS = glob(
    [
        "src/*.ads",
        "src/*.adb",
        "src/ghdldrv/*.ads",
        "src/ghdldrv/*.adb",
        "src/grt/*.ads",
        "src/grt/*.adb",
        "src/psl/*.ads",
        "src/psl/*.adb",
        "src/simul/*.ads",
        "src/simul/*.adb",
        "src/synth/*.ads",
        "src/synth/*.adb",
        "src/verilog/*.ads",
        "src/verilog/*.adb",
        "src/vhdl/*.ads",
        "src/vhdl/*.adb",
        "src/vhdl/translate/*.ads",
        "src/vhdl/translate/*.adb",
    ],
    exclude = [
        # ----------------------------------------------------------------- #
        # Alternate driver mains. Each `ghdl_<backend>.adb` is a separate
        # program entry compiled into its own `ghdl` binary; including more
        # than one in a single Ada library duplicates `main`, alternative
        # entry symbols, and (for ghdl_rust) `__gnat_version`. We only build
        # ghdl_jit, so all other driver mains and their specs are excluded.
        # ----------------------------------------------------------------- #
        "src/ghdldrv/ghdl_gcc.adb",
        "src/ghdldrv/ghdl_gcc.ads",
        "src/ghdldrv/ghdl_jit.adb",
        "src/ghdldrv/ghdl_llvm.adb",
        "src/ghdldrv/ghdl_rust.adb",
        "src/ghdldrv/ghdl_rust.ads",
        "src/ghdldrv/ghdl_simul.adb",
        "src/ghdldrv/ghdlsimul.adb",
        "src/ghdldrv/ghdlsimul.ads",
        # ----------------------------------------------------------------- #
        # Alternate library entry points that re-export `__gnat_version`
        # via `pragma Export`. Including them in a binary library collides
        # with the gnatbind-generated `__gnat_version` in the binder file.
        # libghdlsynth in particular is only used as a standalone shared
        # library entry, not by the ghdl driver.
        # ----------------------------------------------------------------- #
        "src/synth/libghdlsynth.adb",
        "src/synth/libghdlsynth.ads",
        # ----------------------------------------------------------------- #
        # Standalone-simulator program entry. `grt/main.adb` defines `main`
        # and would clash with the binder's `main`; it only exists for the
        # bare-grt simulator build, not the JIT driver.
        # ----------------------------------------------------------------- #
        "src/grt/ghdl_main.adb",
        "src/grt/ghdl_main.ads",
        "src/grt/main.adb",
        "src/grt/main.ads",
        # ----------------------------------------------------------------- #
        # libbacktrace-based backtraces. We select `Grt.Backtraces.Jit` via
        # the generated `grt-backtraces-impl.ads` alias, so the gcc variant
        # is unused — but if its `.adb` is compiled into the library, the
        # final link pulls in `backtrace_create_state` / `backtrace_pcinfo`
        # from libbacktrace, which we don't link.
        # ----------------------------------------------------------------- #
        "src/grt/grt-backtraces-gcc.adb",
        "src/grt/grt-backtraces-gcc.ads",
        # ----------------------------------------------------------------- #
        # Analog-solver stub. `Simul.Vhdl_Simul` exports the real
        # `grt__analog_solver__*` symbols via `pragma Export`, and is
        # required transitively by `ghdlrun`. The stub in
        # `grt-no_analog_solver.adb` would collide on those symbols, and is
        # only `with`-ed by `ghdl_main.adb` (already excluded).
        # ----------------------------------------------------------------- #
        "src/grt/grt-no_analog_solver.adb",
        "src/grt/grt-no_analog_solver.ads",
        # ----------------------------------------------------------------- #
        # Misc files upstream excludes from the GHDL driver build.
        # ----------------------------------------------------------------- #
        "src/dyn_htables.adb",
        "src/dyn_htables.ads",
        "src/grt/grt-rtis_binding.ads",
        "src/psl/psl-tprint.adb",
        "src/psl/psl-tprint.ads",
        "src/vhdl/translate/trans-preelab.adb",
        "src/vhdl/translate/trans-preelab.ads",
        "src/vhdl/vhdl-scanner-directive_protect.adb",
        "src/vhdl/vhdl-scanner-scan_literal.adb",
    ],
)

_COMPILE_DATA = [
    "src/grt/grt-rtis_binding.ads",
    "src/vhdl/vhdl-scanner-directive_protect.adb",
    "src/vhdl/vhdl-scanner-scan_literal.adb",
]

_ORTHO_COMMON = [
    "src/ortho/ortho_front.ads",
    "src/ortho/ortho_jit.ads",
]

# ===========================================================================
# Mcode backend library (monolithic: common + ortho/mcode)
# ===========================================================================

# The Ada static archives are reused by both the `ghdl` binary and the
# `libghdl` shared library, so they must be PIC. Some platforms (e.g. Debian
# 12 with the bundled GNAT 15.1.0) default to non-PIC and the shared-library
# link fails with `relocation R_X86_64_PC32 ... can not be used when making a
# shared object`. Other platforms (e.g. Ubuntu 22.04 with a recent system
# GCC) happen to enable PIE/PIC by default and the link succeeds without
# the flag, but adding it explicitly avoids relying on that default.
_ADA_LIB_COPTS = [
    "-gnat12",
    "-fPIC",
]

ada_library(
    name = "ghdl_mcode_lib",
    srcs = _COMMON_SRCS + glob(
        [
            "src/ortho/mcode/*.ads",
            "src/ortho/mcode/*.adb",
        ],
        exclude = [
            "src/ortho/mcode/coffdump.adb",
            "src/ortho/mcode/elfdump.adb",
            "src/ortho/mcode/ortho_code_main.adb",
            "src/ortho/mcode/ortho_mcode.private.ads",
        ],
    ) + _ORTHO_COMMON + _GENERATED_COMMON + [
        ":default_paths_mcode_ads",
        ":elf_arch_ads",
        ":ortho_flags_ads",
        ":version_mcode_ads",
    ],
    compile_data = _COMPILE_DATA,
    copts = _ADA_LIB_COPTS,
    # mcode emits x86 instructions directly; building it for any other CPU
    # is meaningless, and wildcard builds on arm64 should skip it cleanly.
    target_compatible_with = ["@platforms//cpu:x86_64"],
    deps = [
        ":fst",
        ":grt_c",
        ":mcode_c",
    ],
)

# ===========================================================================
# LLVM backend library (monolithic: common + ortho/llvm6)
# ===========================================================================

ada_library(
    name = "ghdl_llvm_jit_lib",
    srcs = _COMMON_SRCS + glob(
        [
            "src/ortho/llvm6/*.ads",
            "src/ortho/llvm6/*.adb",
        ],
        exclude = [
            "src/ortho/llvm6/ortho_code_main.adb",
            "src/ortho/llvm6/ortho_llvm.private.ads",
        ],
    ) + _ORTHO_COMMON + _GENERATED_COMMON + [
        ":default_paths_llvm_ads",
        ":version_llvm_ads",
    ],
    compile_data = _COMPILE_DATA,
    copts = _ADA_LIB_COPTS,
    deps = [
        ":fst",
        ":grt_c",
        ":llvm_cbindings",
    ],
)

# ===========================================================================
# Backend alias — selects the active backend library
# ===========================================================================

alias(
    name = "ghdl_lib",
    actual = select({
        ":_mcode_on_x86_64": ":ghdl_mcode_lib",
        # Covers backend=llvm-jit on any CPU and backend=mcode on non-x86_64.
        "//conditions:default": ":ghdl_llvm_jit_lib",
    }),
)

# ===========================================================================
# ghdl binary (JIT — works with both mcode and LLVM backends)
# ===========================================================================

# Match upstream Makefile (src/grt/Makefile.inc:46) which links the ghdl
# binary with `-Wl,--export-dynamic` so VPI/VHPI entry points are visible
# in the dynamic symbol table for VPI plugins (e.g. cocotb's
# libcocotbvpi_ghdl.so) to resolve at dlopen time. `grt.ver` narrows the
# exported set to just the documented vpi_*/vhpi_* surface.
version_script(
    name = "_grt_version_script",
    script = "src/grt/grt.ver",
)

ada_binary(
    name = "ghdl",
    srcs = ["src/ghdldrv/ghdl_jit.adb"],
    copts = ["-gnat12"],
    linkopts = select({
        "@platforms//os:linux": [
            "-ldl",
            "-lm",
            "-shared-libgcc",
            "-Wl,--export-dynamic",
        ],
        "@platforms//os:macos": [
            "-shared-libgcc",
        ],
    }) + select({
        # Mirror the alias above — `-lstdc++` is only needed when ghdl_lib
        # resolves to ghdl_llvm_jit_lib (i.e. NOT mcode-on-x86_64).
        ":_mcode_on_x86_64": [],
        "//conditions:default": ["-lstdc++"],
    }),
    visibility = ["//visibility:public"],
    deps = [":ghdl_lib"] + select({
        "@platforms//os:linux": [":_grt_version_script"],
        "//conditions:default": [],
    }),
)

ghdl_with_backend(
    name = "ghdl_mcode",
    actual = ":ghdl",
    backend = "mcode",
    # mcode codegen is x86-only — see the comment on `ghdl_mcode_lib`.
    target_compatible_with = ["@platforms//cpu:x86_64"],
    visibility = ["//visibility:public"],
)

ghdl_with_backend(
    name = "ghdl_llvm_jit",
    actual = ":ghdl",
    backend = "llvm-jit",
    visibility = ["//visibility:public"],
)

# ===========================================================================
