            "RenderSystems/GLSupport/include/OSX",
        ],
        "//conditions:default": [],
    }),
    deps = [
        ":OgreMain_library",
        "@libx11",
        "@libxcb",
        "@libxrandr",
    ],
)

### RenderSystem: GL

OGRE_RENDERSYSTEM_GL_DEPS = {
