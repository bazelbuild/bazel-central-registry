cc_library(
    name = "OgreMain_library",
    srcs = glob(
        [
            "OgreMain/src/*.cpp",
            "OgreMain/src/*.h",
        ],
        allow_empty = True,
    ) + [
        "OgreMain/src/Threading/OgreDefaultWorkQueueStandard.cpp",
    ] + select({
        "@platforms//os:windows": glob(["OgreMain/src/WIN32/*.cpp"]),
        "@platforms//os:osx": glob([
            "OgreMain/src/OSX/*.cpp",
            "OgreMain/src/OSX/*.h",
        ]),
        "//conditions:default": [],
    }),
    hdrs = glob(
        [
            "OgreMain/include/*.h",
            "OgreMain/include/Threading/*.h",
