load("@rules_cc//cc:defs.bzl", "cc_test")

[
    cc_test(
        name = "test_" + test,
        srcs = [
            "{0}.c".format(test),
            "config.h",
            "tests.h",
        ],
        deps = [
            "@theora//:theoradec",
            "@theora//:theoraenc",
        ],
    )
    for test in [
        "noop",
        "comment",
        "granulepos",
    ]
]

[
    cc_test(
        name = "test_legacy_" + test,
        srcs = [
            "{0}_theora.c".format(test),
            "config.h",
            "tests.h",
        ],
        deps = [
            "@theora",
        ],
    )
    for test in [
        "noop",
        "comment",
        "granulepos",
    ]
]
