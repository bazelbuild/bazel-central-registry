load("@rules_cc//cc:defs.bzl", "cc_library", "cc_test")

package(default_visibility = ["//visibility:public"])

cc_library(
    name = "test_utils",
    hdrs = ["tests.h"],
    includes = ["."],
    local_defines = ["HAVE_CONFIG_H"],
    deps = ["//:hdrs"],
)

cc_test(
    name = "noop_theora",
    srcs = ["noop_theora.c"],
    deps = [
        ":test_utils",
        "//lib:theora",
        "@ogg//:libogg",
    ],
)

cc_test(
    name = "comment",
    srcs = ["comment.c"],
    deps = [
        ":test_utils",
        "//lib:theoradec",
        "@ogg//:libogg",
    ],
)

cc_test(
    name = "comment_theoradec",
    srcs = ["comment.c"],
    deps = [
        ":test_utils",
        "//lib:theoradec",
        "@ogg//:libogg",
    ],
)

cc_test(
    name = "comment_theora",
    srcs = ["comment_theora.c"],
    deps = [
        ":test_utils",
        "//lib:theora",
        "@ogg//:libogg",
    ],
)

cc_test(
    name = "noop",
    srcs = ["noop.c"],
    deps = [
        ":test_utils",
        "//lib:theoraenc",
        "@ogg//:libogg",
    ],
)

cc_test(
    name = "noop_theoraenc",
    srcs = ["noop_theora.c"],
    deps = [
        ":test_utils",
        "//lib:theoraenc",
        "@ogg//:libogg",
    ],
)

cc_test(
    name = "granulepos",
    srcs = ["granulepos.c"],
    linkopts = ["-lm"],
    deps = [
        ":test_utils",
        "//lib:theoraenc",
        "@ogg//:libogg",
    ],
)

cc_test(
    name = "granulepos_theoraenc",
    srcs = ["granulepos_theora.c"],
    linkopts = ["-lm"],
    deps = [
        ":test_utils",
        "//lib:theoraenc",
        "@ogg//:libogg",
    ],
)

cc_test(
    name = "granulepos_theora",
    srcs = ["granulepos_theora.c"],
    linkopts = ["-lm"],
    deps = [
        ":test_utils",
        "//lib:theora",
        "@ogg//:libogg",
    ],
)

# Decoder-only tests
test_suite(
    name = "decoder_tests",
    tests = [
        ":comment",
        ":comment_theoradec",
        ":comment_theora",
        ":noop_theora",
    ],
)

# Encoder tests
test_suite(
    name = "encoder_tests",
    tests = [
        ":granulepos",
        ":granulepos_theoraenc",
        ":granulepos_theora",
        ":noop",
        ":noop_theoraenc",
    ],
)

# All tests
test_suite(
    name = "all_tests",
    tests = [
        ":decoder_tests",
        ":encoder_tests",
    ],
)
