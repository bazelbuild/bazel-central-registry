/* config.h.in - Configuration header template for libtheora */

#ifndef CONFIG_H
#define CONFIG_H

/* Package information */
#define PACKAGE "libtheora"
#define PACKAGE_NAME "libtheora"
#define PACKAGE_STRING "libtheora 1.2.0"
#define PACKAGE_TARNAME "libtheora"
#define PACKAGE_VERSION "1.2.0"
#define VERSION "1.2.0"

/* Platform-specific assembly optimizations */
#undef OC_X86_ASM
#undef OC_X86_64_ASM
#undef OC_ARM_ASM
#undef OC_ARM_ASM_EDSP
#undef OC_ARM_ASM_MEDIA
#undef OC_ARM_ASM_NEON
#undef OC_C64X_ASM

/* Standard headers */
#undef HAVE_INTTYPES_H
#undef HAVE_STDINT_H
#undef HAVE_STDLIB_H
#undef HAVE_STRING_H
#undef HAVE_MEMORY_H
#undef HAVE_SYS_TYPES_H
#undef HAVE_SYS_STAT_H
#undef HAVE_UNISTD_H

/* OS-specific headers */
#undef HAVE_DLFCN_H
#undef HAVE_SYS_SOUNDCARD_H
#undef HAVE_SOUNDCARD_H
#undef HAVE_MACHINE_SOUNDCARD_H

/* Memory alignment support */
#undef HAVE_MEMORY_CONSTRAINT

/* Cairo support (debugging) */
#undef HAVE_CAIRO

/* Define to 1 if you have the ANSI C header files. */
#define STDC_HEADERS 1

/* Define if building universal (internal helper macro) */
#undef AC_APPLE_UNIVERSAL_BUILD

/* Enable encoding support */
#define THEORA_SUPPORT_ENCODE 1

#endif /* CONFIG_H */
