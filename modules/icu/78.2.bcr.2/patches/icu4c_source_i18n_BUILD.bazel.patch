BCR adjustments to icu4c/source/i18n/BUILD.bazel:

* :headers ‚Äî propagate `U_STATIC_IMPLEMENTATION` to consumers via
  `defines` on MSVC. Same rationale as the common-side patch
  (icu4c_source_common_BUILD.bazel.patch).

* :collation ‚Äî two changes:
  - Replace the upstream explicit srcs list with `glob(*.h, *.cpp)`
    so consumers don't need to chase the per-symbol cc_libraries.
  - `/utf-8` copts on MSVC: alphaindex.cpp etc. contain UTF-8 char
    literals (Greek letters) that MSVC misreads as multi-byte char
    constants (C2015) without the flag.

--- icu4c/source/i18n/BUILD.bazel
+++ icu4c/source/i18n/BUILD.bazel
@@ -34,40 +34,24 @@
     local_defines = [
         "U_I18N_IMPLEMENTATION",
     ],
+    defines = select({
+        "@rules_cc//cc/compiler:clang-cl": ["U_STATIC_IMPLEMENTATION"],
+        "@rules_cc//cc/compiler:msvc-cl": ["U_STATIC_IMPLEMENTATION"],
+        "//conditions:default": [],
+    }),
 )
 
 cc_library(
     name = "collation",
-    srcs = [
-        "bocsu.cpp",
-        "coleitr.cpp",
-        "coll.cpp",
-        "collation.cpp",
-        "collationcompare.cpp",
-        "collationdata.cpp",
-        "collationdatareader.cpp",
-        "collationdatawriter.cpp",
-        "collationfastlatin.cpp",
-        # collationfcd.cpp is generated by genuca;
-        # probably hard to build genuca without depending on the old version.
-        "collationfcd.cpp",
-        "collationiterator.cpp",
-        "collationkeys.cpp",
-        "collationroot.cpp",
-        "collationrootelements.cpp",
-        "collationsets.cpp",
-        "collationsettings.cpp",
-        "collationtailoring.cpp",
-        "rulebasedcollator.cpp",
-        "sortkey.cpp",
-        "ucol.cpp",
-        "ucol_res.cpp",
-        "ucol_sit.cpp",
-        "ucoleitr.cpp",
-        "uitercollationiterator.cpp",
-        "utf16collationiterator.cpp",
-        "utf8collationiterator.cpp",
-    ],
+    srcs = glob([
+        "*.h",
+        "*.cpp",
+    ]),
+    copts = select({
+        "@rules_cc//cc/compiler:clang-cl": ["/utf-8"],
+        "@rules_cc//cc/compiler:msvc-cl": ["/utf-8"],
+        "//conditions:default": [],
+    }),
     includes = ["."],
     deps = [
         ":headers",
