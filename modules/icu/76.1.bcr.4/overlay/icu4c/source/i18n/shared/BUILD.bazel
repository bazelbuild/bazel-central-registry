load("//icu4c/source:defs.bzl", "cc_shared_library")

# Shared-library variant of //icu4c/source/i18n:icui18n.
# Flips '//icu4c/source:enable-shared=true' under its transitive deps via the
# per-target transition wired into our custom 'cc_shared_library'.
cc_shared_library(
    name = "icui18n",
    dynamic_deps = ["//icu4c/source/common/shared:icuuc"],
    visibility = [
        "//:__pkg__",
        "//icu4c/source/io/shared:__pkg__",
    ],
    deps = ["//icu4c/source/i18n:icui18n"],
)
