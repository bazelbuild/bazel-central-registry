load("//icu4c/source:defs.bzl", "cc_shared_library")

# Shared-library variant of //icu4c/source/io:icuio.
# Flips '//icu4c/source:enable-shared=true' under its transitive deps via the
# per-target transition wired into our custom 'cc_shared_library'.
cc_shared_library(
    name = "icuio",
    dynamic_deps = [
        "//icu4c/source/common/shared:icuuc",
        "//icu4c/source/i18n/shared:icui18n",
    ],
    visibility = ["//:__pkg__"],
    deps = ["//icu4c/source/io:icuio"],
)
