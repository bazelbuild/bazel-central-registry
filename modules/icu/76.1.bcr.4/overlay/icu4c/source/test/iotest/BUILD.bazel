load("@rules_cc//cc:defs.bzl", "cc_test")

package(
    default_visibility = ["//visibility:public"],
)

cc_test(
    name = "iotest",
    timeout = "long",
    srcs = glob([
        "*.c",
        "*.cpp",
        "*.h",
    ]),
    data = [
        "//icu4c/source/test/testdata:testdata-dir",
    ],
    includes = ["."],
    local_defines = [
        "BAZEL_ICU_TESTDATA_SRC_DIR=\\\"$(rlocationpath //icu4c/source/test/testdata:testdata-dir)\\\"",
    ],
    deps = [
        "//icu4c/source/common:icuuc",
        "//icu4c/source/common:private_headers",
        "//icu4c/source/i18n:icui18n",
        "//icu4c/source/i18n:private_headers",
        "//icu4c/source/io:icuio",
        "//icu4c/source/test:bazel-runfiles",
        "//icu4c/source/test/testdata",
        "//icu4c/source/tools/ctestfw",
    ],
)
