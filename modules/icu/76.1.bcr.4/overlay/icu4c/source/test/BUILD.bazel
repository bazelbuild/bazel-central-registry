load("@rules_cc//cc:defs.bzl", "cc_library", "cc_test")

# ---------------------------------------------------------------------------
# bazel-runfiles: C-callable Bazel runfiles resolver used by all test targets.
# Provides icu_bazel_rlocation() so that C (cintltst) and C++ (intltest,
# iotest) test code can resolve runfiles paths without relying on TEST_SRCDIR.
# ---------------------------------------------------------------------------
cc_library(
    name = "bazel-runfiles",
    srcs = ["bazel_runfiles.cc"],
    hdrs = ["bazel_runfiles.h"],
    includes = ["."],
    visibility = ["//icu4c/source/test:__subpackages__"],
    deps = [
        # Pulled in for U_FILE_SEP_CHAR (via unicode/utypes.h) so we can
        # convert Bazel runfiles paths to native separators on Windows.
        "//icu4c/source/common:headers",
        "@rules_cc//cc/runfiles",
    ],
)

# ---------------------------------------------------------------------------
# break-iterator-test: exercises BreakIterator and locale resource loading.
# ---------------------------------------------------------------------------
cc_test(
    name = "break-iterator-test",
    srcs = ["break_iterator_test.cc"],
    deps = [
        "//icu4c/source/common:icuuc",
    ],
)

# ---------------------------------------------------------------------------
# collation-test: exercises the collation / i18n library.
# ---------------------------------------------------------------------------
cc_test(
    name = "collation-test",
    srcs = ["collation_test.cc"],
    deps = [
        "//icu4c/source/common:icuuc",
        "//icu4c/source/i18n:icui18n",
    ],
)

# ---------------------------------------------------------------------------
# locale-test: exercises resource-bundle / locale lookup.
# ---------------------------------------------------------------------------
cc_test(
    name = "locale-test",
    srcs = ["locale_test.cc"],
    deps = [
        "//icu4c/source/common:icuuc",
    ],
)
