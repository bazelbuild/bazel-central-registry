load("@rules_cc//cc:defs.bzl", "cc_library", "cc_test")

cc_test(
    name = "cintltst",
    timeout = "long",
    srcs = glob([
        "*.c",
        "*.h",
        "*.inc",
    ]),
    data = [
        "//icu4c/source/data:icudata-src-dir",
        "//icu4c/source/test/testdata:testdata-dir",
    ],
    includes = ["."],
    local_defines = [
        "BAZEL_ICU_TESTDATA_SRC_DIR=\\\"$(rlocationpath //icu4c/source/test/testdata:testdata-dir)\\\"",
        "BAZEL_ICU_DATA_SRC_DIR=\\\"$(rlocationpath //icu4c/source/data:icudata-src-dir)\\\"",
    ],
    deps = [
        "//icu4c/source/common:icuuc",
        "//icu4c/source/common:private_headers",
        "//icu4c/source/i18n:icui18n",
        "//icu4c/source/i18n:private_headers",
        "//icu4c/source/test:bazel-runfiles",
        "//icu4c/source/test/testdata",
        "//icu4c/source/tools/ctestfw",
        "//icu4c/source/tools/toolutil",
        "//icu4c/source/tools/toolutil:private_headers",
    ],
)

# Header-only library to allow 'intltest' resolve the following relative
# includes:
#   allcoll.cpp:  #include "../cintltst/calldata.h"
#   srchtest.cpp: #include "../cintltst/usrchdat.inc"
cc_library(
    name = "calldata",
    hdrs = ["calldata.h"],
    textual_hdrs = ["usrchdat.inc"],
    visibility = ["//icu4c/source/test/intltest:__pkg__"],
    deps = ["//icu4c/source/common:icuuc"],
)
