load("@rules_python//python:defs.bzl", "py_library")

# Package marker for icutools. Provides the top-level __init__.py so that
# Python can resolve icutools as a regular package (not a namespace package).
py_library(
    name = "icutools",
    srcs = ["__init__.py"],
    imports = [".."],
    visibility = ["//icu4c/source/python/icutools:__subpackages__"],
)
