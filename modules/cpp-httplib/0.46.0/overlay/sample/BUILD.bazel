load("@rules_cc//cc:cc_test.bzl", "cc_test")

cc_test(
    name = "server_test",
    srcs = ["server_test.cc"],
    deps = ["@cpp-httplib//:httplib"],
)

# this example shows how to activate one of the optional functionalities, in this case, zlib compression
cc_test(
    name = "server_zlib_test",
    srcs = ["server_zlib_test.cc"],
    local_defines = ["CPPHTTPLIB_ZLIB_SUPPORT"],
    deps = [
        "@cpp-httplib//:httplib",
        "@zlib",
    ],
)
