load("@rules_cc//cc:defs.bzl", "cc_library")

cc_library(
    name = "httplib",
    hdrs = ["httplib.h"],
    features = [
        "parse_headers",
    ],
    includes = ["."],
    deps = [
        "@boringssl//:ssl",
        "@zlib",
    ],
    local_defines = [
        "CPPHTTPLIB_OPENSSL_SUPPORT",
        "CPPHTTPLIB_ZLIB_SUPPORT",
    ],
    visibility = ["//visibility:public"],
)

alias(
    name = "cpp-httplib",
    actual = ":httplib",
    visibility = ["//visibility:public"],
)
