load("@rules_cc//cc:cc_library.bzl", "cc_library")
load("@rules_cc//cc:cc_test.bzl", "cc_test")

# =============================================================================
# Test support library
# =============================================================================

cc_library(
    name = "libfrtests",
    testonly = True,
    srcs = [
        "cmp_str.c",
        "memory.c",
        "random2.c",
        "rnd_mode.c",
        "tests.c",
    ],
    hdrs = ["mpfr-test.h"],
    copts = [
        "-DHAVE_CONFIG_H",
        "-DMPFR_BAZEL_TEST",
    ] + select({
        "@rules_cc//cc/compiler:msvc-cl": ["/w"],
        "//conditions:default": ["-w"],
    }),
    includes = ["."],
    deps = [
        "//:_mpfr_hdrs",
        "//:mpfr",
        "//bazel:runfiles_util",
    ],
)

# =============================================================================
# Test data files
# =============================================================================

filegroup(
    name = "test_data",
    srcs = [
        "inp_str.dat",
        "tfpif_r1.dat",
        "tfpif_r2.dat",
        "tmul.dat",
    ],
)

