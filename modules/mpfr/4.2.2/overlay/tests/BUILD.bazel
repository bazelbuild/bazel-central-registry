        name = test,
        srcs = [test + ".c"],
        copts = _MPFR_TEST_COPTS,
        data = [
            "inp_str.dat",
            ":test_data",
        ],
        env = {"MPFR_SRCDIR": "$(rlocationpath inp_str.dat)"},
        linkopts = select({
            "@platforms//os:windows": [],
            "//conditions:default": ["-lm"],
        }),
        deps = _MPFR_TEST_DEPS,
    )
    for test in _MPFR_TESTS
]

# Tests that require C99 features not available on MSVC.
_MPFR_TESTS_NO_WINDOWS = [
    "talloc",
]

[
    cc_test(
        name = test,
        srcs = [test + ".c"],
        copts = _MPFR_TEST_COPTS,
        data = [
            "inp_str.dat",
            ":test_data",
        ],
        env = {"MPFR_SRCDIR": "$(rlocationpath inp_str.dat)"},
        linkopts = select({
            "@platforms//os:windows": [],
            "//conditions:default": ["-lm"],
        }),
        target_compatible_with = select({
            "@platforms//os:windows": ["@platforms//:incompatible"],
            "//conditions:default": [],
        }),
        deps = _MPFR_TEST_DEPS,
    )
    for test in _MPFR_TESTS_NO_WINDOWS
]

# Tests for optional features (_Decimal64, _Decimal128, _Float128).
# These return exit code 77 ("skip") when the feature is not available,
# which Bazel treats as failure.  Tagged "manual" so they don't run
# with `bazel test //...`.
_MPFR_OPTIONAL_TESTS = [
    "tget_set_d64",
    "tget_set_d128",
    "tset_float128",
]

[
    cc_test(
        name = test,
        srcs = [test + ".c"],
        copts = _MPFR_TEST_COPTS,
        data = [
            "inp_str.dat",
            ":test_data",
        ],
        env = {"MPFR_SRCDIR": "$(rlocationpath inp_str.dat)"},
        linkopts = select({
            "@platforms//os:windows": [],
            "//conditions:default": ["-lm"],
        }),
        tags = ["manual"],
        deps = _MPFR_TEST_DEPS,
    )
    for test in _MPFR_OPTIONAL_TESTS
]
