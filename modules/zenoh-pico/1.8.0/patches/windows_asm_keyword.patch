+// MSVC lacks GNU-style inline asm, so ZP_ASM_NOP's __asm__("nop") call is shimmed
+// out as a real function here. Real GNU-style compilers (clang, gcc, including
+// clang targeting *-w64-windows-gnu) already treat __asm__ as the inline-asm
+// keyword, so defining it as a function conflicts with the parser on those.
+#if defined(_MSC_VER) && !defined(__clang__) && !defined(__GNUC__)
 inline void __asm__(char *instruction) { (void)(instruction); }
+#endif
 
