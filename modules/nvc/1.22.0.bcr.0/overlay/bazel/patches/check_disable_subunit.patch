Disable subunit detection in libcheck's CMake build.

When libsubunit is installed on the build host, libcheck's CMake build
detects it and compiles check_print.c with -DENABLE_SUBUNIT=1 while the
generated check.h enum is produced without CK_SUBUNIT, causing a
"'CK_SUBUNIT' undeclared" compile error.  Subunit output is not needed for
the NVC unit tests, so force it off for a consistent, host-independent build.

--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -393,7 +393,7 @@
   ADD_DEFINITIONS(-DHAVE_LIBRT=1)
 endif (HAVE_LIBRT)

-check_library_exists(subunit subunit_test_start "" HAVE_SUBUNIT)
+set(HAVE_SUBUNIT FALSE)
 if (HAVE_SUBUNIT)
   set(SUBUNIT "subunit")
   set(ENABLE_SUBUNIT 1)
