# Aggregate that exposes every shipped VHDL library, mirroring `make
# bootstrap`. Each entry is its own TreeArtifact whose basename is
# the NVC library identifier — same granularity an `apt`/`brew`
# install of nvc would lay out on disk under
# `<prefix>/lib/nvc/<library>/`.
filegroup(
    name = "vhdl_libs",
    srcs = [
        ":ieee",
        ":ieee.08",
        ":ieee.19",
        ":lib_nvc",
        ":lib_nvc.08",
        ":lib_nvc.19",
        ":std",
        ":std.08",
        ":std.19",
    ],
    visibility = ["//visibility:public"],
)

# ===========================================================================
# Smoke test — confirm the binary actually runs.
#
# Three-stage pipeline:
#
#   1. `write_file` emits a template (`nvc_version_expected.in`) with
#      `@PACKAGE_VERSION@` / `@LLVM_VERSION@` placeholders. The
#      template never has to be edited when bumping nvc or LLVM — the
#      version literals live at the top of this BUILD file.
#   2. `autoconf_hdr` renders the template via the same
#      `substitutions` machinery that produces `config.h`, so the
#      expected golden picks up the same constants the binary was
#      compiled with.
#   3. `genrule` redirects `nvc --version` into a file (no host-tool
#      pipelines like `head` or `sed`); the LLVM-on vs LLVM-off
#      difference is folded into the template via select() above
#      so the expected text matches whichever variant was built. The
#      `cmd_bat` mirrors the POSIX `cmd` for Windows action workers —
#      cmd.exe also redirects with `>`.
#   4. `diff_test` byte-compares actual vs expected.
# ===========================================================================

write_file(
    name = "nvc_version_template",
    out = "nvc_version_expected.in",
    content = select({
        ":_llvm_enabled": [
            "nvc @PACKAGE_VERSION@ (Using LLVM @LLVM_VERSION@)",
        ],
        "//conditions:default": [
            "nvc @PACKAGE_VERSION@",
        ],
    }) + [
        "Copyright (C) 2011-2026  Nick Gasson",
        "This program comes with ABSOLUTELY NO WARRANTY. This is free software, and",
        "you are welcome to redistribute it under certain conditions. See the GNU",
        "General Public Licence for details.",
        "",
    ],
)

autoconf_hdr(
    name = "nvc_version_expected_file",
    out = "nvc_version_expected.txt",
    mode = "subst",
    template = ":nvc_version_template",
    deps = [
        ":autoconf",
        ":package",
    ],
)

genrule(
    name = "nvc_version_output",
    srcs = [],
    outs = ["nvc_version_actual.txt"],
    cmd = "$(execpath :nvc) --version > $@",
    cmd_bat = "$(execpath :nvc) --version > $@",
    tools = [":nvc"],
)

diff_test(
    name = "nvc_version_test",
    file1 = ":nvc_version_output",
    file2 = ":nvc_version_expected_file",
)
