# Suppress the most noisy warnings that NVC's own source code triggers
# without `-Wno-*` flags from the upstream Makefile. The upstream
# build uses `-Wall` and relies on the compiler's defaults; Bazel's
# default strictness varies by toolchain. Keep this list minimal —
# anything not required for the build to succeed should be left out.
_LIBNVC_COPTS = [
    "-D_GNU_SOURCE",
    # AC_CONFIG_HEADERS([config.h]) in configure.ac causes automake to
    # emit -DHAVE_CONFIG_H on every compile; util.h keys its
    # `#include "config.h"` off this define, so without it none of the
    # autoconf-detected feature defines reach the rest of the code.
    "-DHAVE_CONFIG_H=1",
    "-Wno-unused-parameter",
    "-Wno-unused-variable",
    "-Wno-unused-function",
    "-Wno-unused-but-set-variable",
    "-Wno-implicit-fallthrough",
    "-Wno-missing-field-initializers",
    "-Wno-sign-compare",
    "-Wno-pointer-sign",
    "-fno-strict-aliasing",
    # The flex-generated lexer relies on these GCC-isms being
    # available without warnings.
    "-Wno-deprecated-declarations",
]

alias(
    name = "libnvc",
    actual = ":lib/nvc",
)

cc_library(
