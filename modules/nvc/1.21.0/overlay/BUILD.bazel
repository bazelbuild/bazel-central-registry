# Pure-aggregator cc_library that pulls in the LLVM C bindings we
# actually link `nvc` against (LLVMInitializeNativeTarget,
# LLVMCreateTargetMachine, LLVMTargetMachineEmitToMemoryBuffer, …).
# Tagged `manual` so wildcard builds don't compile it without the
# C++17 transition wrapper below — LLVM 17+ headers use
# `std::string_view` etc. and fail under the BCR CI's
# default `-std=c++14`.
cc_library(
    name = "_llvm_libs_raw",
    tags = ["manual"],
    deps = [
        "@llvm-project//llvm:AllTargetsAsmParsers",
        "@llvm-project//llvm:AllTargetsCodeGens",
        "@llvm-project//llvm:Analysis",
        "@llvm-project//llvm:BitWriter",
        "@llvm-project//llvm:Core",
        "@llvm-project//llvm:Support",
        "@llvm-project//llvm:Target",
        "@llvm-project//llvm:TargetParser",
    ],
)

# Force the entire LLVM dependency closure to be built with C++17.
# Without this every consumer of `:libnvc` (this build, plus anything
# downstream that depends on `@nvc//:nvc`) would have to set
# `--cxxopt=-std=c++17` / `--host_cxxopt=-std=c++17` manually.
cc_stdcc17_transitioned_library(
    name = "llvm_libs",
    target = ":_llvm_libs_raw",
)

# ===========================================================================
# nvc binary
# ===========================================================================

cc_binary(
    name = "nvc",
    srcs = ["src/nvc.c"],
    additional_linker_inputs = ["src/symbols.txt"],
    copts = _LIBNVC_COPTS,
    linkopts = select({
        # Match the upstream Makefile's `-Wl,--dynamic-list=...`,
        # which narrows the exported symbol set to those listed in
        # src/symbols.txt. Falls back to nothing on platforms whose
        # linker doesn't support the option (the symbols just default
        # to hidden).
        "@platforms//os:linux": ["-Wl,--dynamic-list=$(location src/symbols.txt)"],
        "//conditions:default": [],
    }),
    visibility = ["//visibility:public"],
    deps = [":libnvc"],
)

