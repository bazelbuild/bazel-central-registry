# ===========================================================================
# VHDL standard libraries (bootstrap)
#
# Source declarations use the standard `@rules_vhdl//vhdl:defs.bzl#vhdl_library`
# rule (just sources + metadata, no compilation). The matching
# `nvc_compile` rule (in //bazel:nvc_compile.bzl) consumes a
# `vhdl_library` target and runs `nvc -a` to produce a compiled
# library directory.
#
# Cyclic interleaving: per-standard the upstream Makefile interleaves
# cross-library dependencies that don't fit a strict DAG:
#   - STD.TEXTIO-body has `use nvc.polyfill.all;` (needs NVC)
#   - NVC.PSL_SUPPORT has `library ieee; use ieee.std_logic_1164.all;`
#     (needs IEEE.STD_LOGIC_1164)
#   - IEEE.*-body files have `library nvc;` (needs NVC)
#   - Every NVC.* unit transitively needs STD.STANDARD
# We resolve the cycle with a four-stage bootstrap per standard:
#   1. std_base    → STD.STANDARD + body + TEXTIO declaration only
#   2. ieee_decls  → IEEE package declarations only (no bodies) — deps std_base
#   3. lib_nvc     → all NVC.* including PSL_SUPPORT — deps std_base + ieee_decls
#   4. std         → seed std_base, add TEXTIO-body, ENV, REFLECTION — deps lib_nvc
#      ieee       → seed ieee_decls, add IEEE bodies + MATH_* + SYNOPSYS + VITAL
#                   — deps lib_nvc + std
#
# Three parallel sets are produced, one per VHDL standard: 1993
# (plain dir name), 2008 (`.08` suffix), 2019 (`.19` suffix).
# ===========================================================================

# Shared SYNOPSYS source list — upstream compiles these helpers into
# the IEEE library across every standard (so legacy code that says
# `use ieee.std_logic_arith;` works without an extra library).
_SYNOPSYS_SRCS = [
    "lib/synopsys/std_logic_arith.vhd",
    "lib/synopsys/std_logic_misc.vhd",
    "lib/synopsys/std_logic_signed.vhd",
    "lib/synopsys/std_logic_textio.vhd",
    "lib/synopsys/std_logic_unsigned.vhd",
]

# SYNOPSYS chain phases. Alphabetical order matches the required
# analysis order: std_logic_arith must come before std_logic_signed /
# std_logic_unsigned, which use it.
#
# `_SYNOPSYS_PHASE_93` includes std_logic_textio.vhd; `_SYNOPSYS_PHASE`
# (used by .08/.19) does not, because IEEE 2008/2019 provide their
# own `ieee.std_logic_textio` and the upstream Makefile excludes the
# Synopsys variant there. Compiling it triggers a known crash in nvc
# 1.21.0's semantic analyser (sem_check_array_ref / type_is_array)
# when seeded with the 2008/2019 IEEE library state.
_SYNOPSYS_PHASE_93 = ("synopsys", _SYNOPSYS_SRCS)

_SYNOPSYS_PHASE = (
    "synopsys",
    [s for s in _SYNOPSYS_SRCS if s != "lib/synopsys/std_logic_textio.vhd"],
)

# VITAL phases — each package declaration uses the ones that came
# before it (prmtvs_p uses timing, memory_p uses both), so they're
# split into per-package phases to give vhdl_chain a strict order
# that buildifier can't reshuffle. Bodies don't reference each other,
# so they stay in one phase.
_VITAL_PHASES = [
    (
        "vital_timing_decl",
        select({
            ":_vital_enabled": ["lib/vital/timing_p.vhdl"],
            "//conditions:default": [],
        }),
    ),
    (
        "vital_prmtvs_decl",
        select({
            ":_vital_enabled": ["lib/vital/prmtvs_p.vhdl"],
            "//conditions:default": [],
        }),
    ),
    (
        "vital_memory_decl",
        select({
            ":_vital_enabled": ["lib/vital/memory_p.vhdl"],
            "//conditions:default": [],
        }),
    ),
    (
        "vital_bodies",
        select({
            ":_vital_enabled": [
                "lib/vital/memory_b.vhdl",
                "lib/vital/prmtvs_b.vhdl",
                "lib/vital/timing_b.vhdl",
            ],
            "//conditions:default": [],
        }),
    ),
]

# --- VHDL-1993 ---

vhdl_chain(
    name = "std_base",
    bootstrap = True,
    library = "std",
    phases = [
        (
            "standard",
            ["lib/std/standard.vhd"],
        ),
        (
            "standard_body",
            ["lib/std/standard-body.vhd"],
        ),
        (
            "textio",
            ["lib/std/textio.vhd"],
        ),
    ],
    standard = "1993",
)

vhdl_chain(
    name = "ieee_decls",
    library = "ieee",
    phases = [
        # numeric_* declarations use ieee.std_logic_1164, so the logic
        # package must be a separate phase that runs first; bodies
        # likewise need their own phase because alphabetical sort puts
        # `*-body.vhdl` before `*.vhdl`.
        (
            "logic",
            ["lib/ieee/std_logic_1164.vhdl"],
        ),
        (
            "logic_body",
            ["lib/ieee/std_logic_1164-body.vhdl"],
        ),
        (
            "numeric_decls",
            [
                "lib/ieee/numeric_bit.vhdl",
                "lib/ieee/numeric_std.vhdl",
            ],
        ),
    ],
    standard = "1993",
    deps = [":std_base"],
)

vhdl_chain(
    # Bazel target name is `lib_nvc` to avoid colliding with the
    # `:nvc` cc_binary target above; the underlying VHDL library is
    # still named `nvc` via the `library` attr.
    name = "lib_nvc",
    library = "nvc",
    phases = [
        # All NVC.* package declarations — independent of one another,
        # so alphabetical order is fine.
        (
            "decls",
            [
                "lib/nvc/cover_pkg.vhd",
                "lib/nvc/polyfill.vhd",
                "lib/nvc/psl_support.vhd",
                "lib/nvc/random.vhd",
                "lib/nvc/sim_pkg.vhd",
                "lib/nvc/text_util.vhd",
                "lib/nvc/verilog.vhd",
            ],
        ),
        # All NVC.*-body files. text_util-body uses nvc.polyfill which
        # is already in the seeded `decls` phase.
        (
            "bodies",
            [
                "lib/nvc/cover_pkg-body.vhd",
                "lib/nvc/polyfill-body.vhd",
                "lib/nvc/psl_support-body.vhd",
                "lib/nvc/random-body.vhd",
                "lib/nvc/sim_pkg-body.vhd",
                "lib/nvc/text_util-body.vhd",
                "lib/nvc/verilog-body.vhd",
            ],
        ),
    ],
    standard = "1993",
    deps = [
        ":ieee_decls",
        ":std_base",
    ],
)

vhdl_chain(
    # Final STD library: extend std_base with STD.TEXTIO-body, which
    # needs NVC.POLYFILL.
    name = "std",
    library = "std",
    phases = [
        (
            "textio_body",
            ["lib/std/textio-body.vhd"],
        ),
    ],
    seed = ":std_base",
    standard = "1993",
    visibility = ["//visibility:public"],
    deps = [":lib_nvc"],
)

vhdl_chain(
    # Final IEEE library: extend ieee_decls with the bodies (which
    # need NVC.POLYFILL), math packages, SYNOPSYS shims, and
    # (optionally) VITAL.
    name = "ieee",
    library = "ieee",
    phases = [
        (
            "numeric_bodies",
            [
                "lib/ieee/numeric_bit-body.vhdl",
                "lib/ieee/numeric_std-body.vhdl",
            ],
        ),
        # math_complex declaration uses ieee.math_real, so math_real
        # must come first. Splitting into two phases prevents
        # buildifier from sorting them alphabetically (which would
        # put math_complex before math_real).
        (
            "math_real_decl",
            ["lib/ieee/math_real.vhdl"],
        ),
        (
            "math_complex_decl",
            ["lib/ieee/math_complex.vhdl"],
        ),
        (
            "math_bodies",
            [
                "lib/ieee/math_complex-body.vhdl",
                "lib/ieee/math_real-body.vhdl",
            ],
        ),
        _SYNOPSYS_PHASE_93,
    ] + _VITAL_PHASES,
    # vital prmtvs_b.vhdl violates LRM-1993 strict rules; upstream
    # invokes nvc with --relaxed for THAT file. Bazel rules don't yet
    # support per-source flags, so we apply --relaxed library-wide —
    # the other sources are unaffected by relaxed mode.
    relaxed = True,
    seed = ":ieee_decls",
    standard = "1993",
    visibility = ["//visibility:public"],
    deps = [
        ":lib_nvc",
        ":std",
    ],
)

# --- VHDL-2008 ---

vhdl_chain(
    name = "std_08_base",
    bootstrap = True,
    library = "std.08",
    phases = [
        (
            "standard",
            ["lib/std.08/standard.vhd"],
        ),
        # STANDARD-body.vhd is shared verbatim with 1993; the upstream
        # Makemodule.am for std.08 reuses lib/std/standard-body.vhd.
        (
            "standard_body",
            ["lib/std/standard-body.vhd"],
        ),
        (
            "textio",
            ["lib/std.08/textio.vhd"],
        ),
    ],
    standard = "2008",
)

vhdl_chain(
    name = "ieee_08_decls",
    library = "ieee.08",
    phases = [
        (
            "logic",
            ["lib/ieee.08/std_logic_1164.vhdl"],
        ),
        (
            "logic_body",
            ["lib/ieee.08/std_logic_1164-body.vhdl"],
        ),
        (
            "numeric_decls",
            [
                "lib/ieee.08/numeric_bit.vhdl",
                "lib/ieee.08/numeric_bit_unsigned.vhdl",
                "lib/ieee.08/numeric_std.vhdl",
                "lib/ieee.08/numeric_std_unsigned.vhdl",
            ],
        ),
    ],
    standard = "2008",
    deps = [":std_08_base"],
)

vhdl_chain(
    name = "lib_nvc.08",
    library = "nvc.08",
    phases = [
        (
            "decls",
            [
                "lib/nvc/cover_pkg.vhd",
                # 2008 uses a different polyfill (empty stub) — see
                # comment in lib/nvc.08/polyfill.vhd.
                "lib/nvc.08/polyfill.vhd",
                "lib/nvc/psl_support.vhd",
                "lib/nvc/random.vhd",
                "lib/nvc/sim_pkg.vhd",
                "lib/nvc/text_util.vhd",
                "lib/nvc/verilog.vhd",
            ],
        ),
        (
            # nvc.08/polyfill.vhd is an empty package with no body, so
            # only the original lib/nvc/* bodies appear here.
            "bodies",
            [
                "lib/nvc/cover_pkg-body.vhd",
                "lib/nvc/psl_support-body.vhd",
                "lib/nvc/random-body.vhd",
                "lib/nvc/sim_pkg-body.vhd",
                "lib/nvc/text_util-body.vhd",
                "lib/nvc/verilog-body.vhd",
            ],
        ),
    ],
    standard = "2008",
    deps = [
        ":ieee_08_decls",
        ":std_08_base",
    ],
)

vhdl_chain(
    name = "std.08",
    library = "std.08",
    phases = [
        # ENV first: STD.TEXTIO-body has a VHDL_VERSION>=2019 branch
        # that references std.env; the 2008 build never hits that
        # branch but keeping env earlier mirrors the 2019 chain.
        (
            "env",
            ["lib/std.08/env.vhd"],
        ),
        (
            "env_body",
            ["lib/std.08/env-body.vhd"],
        ),
        (
            "textio_body",
            ["lib/std/textio-body.vhd"],
        ),
    ],
    seed = ":std_08_base",
    standard = "2008",
    visibility = ["//visibility:public"],
    deps = [":lib_nvc.08"],
)

vhdl_chain(
    name = "ieee.08",
    library = "ieee.08",
    phases = [
        (
            "numeric_bodies",
            [
                "lib/ieee.08/numeric_bit-body.vhdl",
                "lib/ieee.08/numeric_bit_unsigned-body.vhdl",
                "lib/ieee.08/numeric_std-body.vhdl",
                "lib/ieee.08/numeric_std_unsigned-body.vhdl",
            ],
        ),
        # math_real / math_complex are shared with the 1993 set.
        # math_complex declaration uses ieee.math_real, so math_real
        # must come first. Splitting into two phases prevents
        # buildifier from sorting them alphabetically (which would
        # put math_complex before math_real).
        (
            "math_real_decl",
            ["lib/ieee/math_real.vhdl"],
        ),
        (
            "math_complex_decl",
            ["lib/ieee/math_complex.vhdl"],
        ),
        (
            "math_bodies",
            [
                "lib/ieee/math_complex-body.vhdl",
                "lib/ieee/math_real-body.vhdl",
            ],
        ),
        (
            "std_logic_textio",
            ["lib/ieee.08/std_logic_textio.vhdl"],
        ),
        # fixed_pkg / float_pkg are package instantiations of the
        # matching `_generic_pkg`s, and IEEE's elaboration rule
        # requires the generic's body to be analysed before any
        # instantiation. The order is therefore: types → generic-decl
        # → generic-body → instantiation. Two phases (decls / bodies)
        # aren't enough.
        (
            "fixed_float_types",
            ["lib/ieee.08/fixed_float_types.vhdl"],
        ),
        (
            "fixed_generic_pkg",
            ["lib/ieee.08/fixed_generic_pkg.vhdl"],
        ),
        (
            "fixed_generic_body",
            ["lib/ieee.08/fixed_generic_pkg-body.vhdl"],
        ),
        (
            "fixed_pkg",
            ["lib/ieee.08/fixed_pkg.vhdl"],
        ),
        (
            "float_generic_pkg",
            ["lib/ieee.08/float_generic_pkg.vhdl"],
        ),
        (
            "float_generic_body",
            ["lib/ieee.08/float_generic_pkg-body.vhdl"],
        ),
        (
            "float_pkg",
            ["lib/ieee.08/float_pkg.vhdl"],
        ),
        (
            "contexts",
            [
                "lib/ieee.08/ieee_bit_context.vhdl",
                "lib/ieee.08/ieee_std_context.vhdl",
            ],
        ),
        _SYNOPSYS_PHASE,
    ] + _VITAL_PHASES,
    relaxed = True,
    seed = ":ieee_08_decls",
    standard = "2008",
    visibility = ["//visibility:public"],
    deps = [
        ":lib_nvc.08",
        ":std.08",
    ],
)

