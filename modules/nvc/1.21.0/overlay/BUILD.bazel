"""Bazel build for nvc — a VHDL compiler and simulator."""

load("@bazel_skylib//rules:common_settings.bzl", "bool_flag", "string_flag")
load("@bazel_skylib//rules:diff_test.bzl", "diff_test")
load("@bazel_skylib//rules:write_file.bzl", "write_file")
load("@flex//:flex.bzl", "flex")
load("@rules_cc//cc:cc_binary.bzl", "cc_binary")
load("@rules_cc//cc:cc_library.bzl", "cc_library")
load("@rules_cc_autoconf//autoconf:autoconf.bzl", "autoconf")
load("@rules_cc_autoconf//autoconf:autoconf_hdr.bzl", "autoconf_hdr")
load("@rules_cc_autoconf//autoconf:checks.bzl", "checks", "macros")
load("@rules_cc_autoconf//autoconf:package_info.bzl", "package_info")
load("//bazel:css_header.bzl", "css_header")
load("//bazel:llvm_utils.bzl", "cc_stdcc17_transitioned_library")
load("//bazel:nvc_compile.bzl", "vhdl_chain")

_LLVM_VERSION = "17.0.4"

# ===========================================================================
# User-facing build flags. These mirror the meaningful `./configure`
# options that affect what code is compiled into the resulting `nvc`
# binary.
# ===========================================================================

# --enable-llvm (default yes upstream). When off, the LLVM ahead-of-time
# code generator (src/jit/jit-llvm.c) and its LLVM library dependencies
# are dropped. The remaining interpreter / x86 JIT backend still works.
bool_flag(
    name = "enable_llvm",
    build_setting_default = True,
    visibility = ["//visibility:public"],
)

config_setting(
    name = "_llvm_enabled",
    flag_values = {":enable_llvm": "True"},
)

# --enable-vital (default yes upstream). Controls whether the VITAL
# (Vital Initiative Timing) VHDL libraries are compiled as part of the
# bootstrap library set.
bool_flag(
    name = "enable_vital",
    build_setting_default = True,
    visibility = ["//visibility:public"],
)

config_setting(
    name = "_vital_enabled",
    flag_values = {":enable_vital": "True"},
)

# --enable-tcl (default no upstream). Compiles the TCL shell extension
# (src/tcl/*). TCL and readline must be available on the system; in
# this port they are not currently wired up, so the default stays off.
bool_flag(
    name = "enable_tcl",
    build_setting_default = False,
    visibility = ["//visibility:public"],
)

config_setting(
    name = "_tcl_enabled",
    flag_values = {":enable_tcl": "True"},
)

# --disable-default-paths (configure default: enabled). When on, the
# binary searches a compiled-in PREFIX-relative path for VHDL libraries
# in addition to user-supplied -L paths. Off matches upstream
# `--disable-default-paths`.
bool_flag(
    name = "enable_default_paths",
    build_setting_default = True,
    visibility = ["//visibility:public"],
)

config_setting(
    name = "_default_paths_enabled",
    flag_values = {":enable_default_paths": "True"},
)

# --enable-debug (default no upstream). When off, configure adds
# `-DNDEBUG=1`; when on, NDEBUG is omitted and extra runtime checks run.
bool_flag(
    name = "enable_debug",
    build_setting_default = False,
    visibility = ["//visibility:public"],
)

config_setting(
    name = "_debug_enabled",
    flag_values = {":enable_debug": "True"},
)

# Linux + x86_64 — the only platform where the elfutils BCR module
# currently compiles cleanly. Its aarch64 backend
# (`backends/aarch64_initreg.c`) redeclares `struct user_pac_mask`,
# which now conflicts with `<asm/ptrace.h>` on glibc kernel headers
# 5.x+. Until the elfutils module ships a fix, gate libdw use on this
# narrower platform; nvc's stacktrace path is already designed to
# degrade gracefully when libdw is absent (configure.ac treats it as
# optional via AC_CHECK_LIB).
config_setting(
    name = "_linux_x86_64",
    constraint_values = [
        "@platforms//os:linux",
        "@platforms//cpu:x86_64",
    ],
)

# Installation prefix used at runtime to locate the bundled VHDL
# standard libraries. The default mirrors GNU autoconf's
# `--prefix=/usr/local`. The lib/libexec/data subdirectories are
# derived in the AC_DEFINEs below by appending the conventional
# suffixes.
string_flag(
    name = "prefix",
    build_setting_default = "/usr/local",
    visibility = ["//visibility:public"],
)

# ===========================================================================
# Package metadata + autoconf feature detection
#
# `module_bazel = "MODULE.bazel"` resolves to the MODULE.bazel that
# Bazel's module resolver layers into the source tree from the
# registry — we don't need a second copy inside the overlay. The
# PACKAGE_NAME / PACKAGE_VERSION / PACKAGE_STRING / PACKAGE_TARNAME
# defines come straight from that file's `module(name = "nvc",
# version = "1.21.0")` and match what upstream's AC_INIT([nvc],
# [1.21.0], ...) would have produced.
# ===========================================================================

package_info(
    name = "package",
    aliases = {
        "PACKAGE": "PACKAGE_TARNAME",
        "VERSION": "PACKAGE_VERSION",
    },
    module_bazel = "MODULE.bazel",
    package_bugreport = "https://github.com/nickg/nvc/issues",
    package_url = "https://www.nickg.me.uk/nvc/",
)

# Autoconf checks that mirror the contents of `configure.ac`. Only the
# checks whose result the C code actually reads are included; cosmetic
# AC_PROG_* probes (compiler discovery, etc.) are handled by the Bazel
# cc_toolchain and so do not appear here.
#
# Platform-specific checks are gathered with select(). Linux is the
# primary supported target; macOS / BSD / Windows ports can be added
# by extending the selects without changing the toplevel structure.
autoconf(
    name = "autoconf",
    checks = macros.AC_CHECK_HEADERS([
        "sys/ptrace.h",
        "sys/prctl.h",
        "ucontext.h",
        "sys/ucontext.h",
        "stdio_ext.h",
        "stdio.h",
        "stdlib.h",
        "string.h",
        "strings.h",
        "inttypes.h",
        "stdint.h",
        "sys/stat.h",
        "sys/types.h",
        "unistd.h",
        "wchar.h",
    ]) + macros.AC_CHECK_FUNCS([
        "tcgetwinsize",
        "memmem",
        "strcasestr",
        "getline",
        "fseeko",
        "ftello",
        "fpurge",
        "__fpurge",
        "strchrnul",
        "strndup",
        "gettid",
        "popen",
    ]) + macros.AC_CHECK_MEMBERS(
        [
            "struct stat.st_mtimespec.tv_nsec",
            "struct stat.st_mtim.tv_nsec",
        ],
        includes = [
            "sys/stat.h",
            "sys/types.h",
        ],
    ) + [
        # configure.ac: AC_LINK_IFELSE around getcontext(). Gated on
        # the presence of <ucontext.h> via `requires=`, mirroring the
        # original AS_IF nesting.
        checks.AC_TRY_LINK(
            name = "ac_cv_func_getcontext",
            code = "ucontext_t uc; getcontext(&uc);",
            define = "HAVE_GETCONTEXT",
            includes = ["ucontext.h"],
            requires = ["HAVE_UCONTEXT_H"],
        ),
        checks.AC_C_RESTRICT(),
    ] + select({
        "@platforms//cpu:aarch64": [
            checks.AC_CHECK_C_COMPILER_FLAG(
                "-march=armv8-a+crypto",
                define = "HAVE_ARM_CRYPTO",
            ),
            checks.AC_CHECK_HEADER("arm_neon.h"),
        ],
        # x86_64-only vector/crypto probes — mirrors the
        # `case $target_cpu in x86_64|amd64) ... esac` block in
        # configure.ac. Gating on the CPU constraint (rather than
        # always probing) keeps thirdparty/sha1.c from including
        # `<x86intrin.h>` on aarch64, where gcc silently accepts
        # `-msha` as a no-op and would otherwise leave HAVE_SSE_SHA
        # defined.
        "@platforms//cpu:x86_64": [
            checks.AC_CHECK_C_COMPILER_FLAG(
                "-mavx2",
                define = "HAVE_AVX2",
            ),
            checks.AC_CHECK_C_COMPILER_FLAG(
                "-msse4.1",
                define = "HAVE_SSE41",
            ),
            checks.AC_CHECK_C_COMPILER_FLAG(
                "-msha",
                define = "HAVE_SSE_SHA",
            ),
            checks.AC_CHECK_C_COMPILER_FLAG(
                "-mpopcnt",
                define = "HAVE_POPCNT",
            ),
        ],
        "//conditions:default": [],
    }) + [
        # GCC function attribute probe. Used by util.h to annotate
        # allocator helpers with __attribute__((returns_nonnull)).
        checks.AC_TRY_COMPILE(
            name = "ax_gcc_func_attribute_returns_nonnull",
            code = """
                void *foo(void) __attribute__((returns_nonnull));
                void *foo(void) { return (void*)1; }
                int main(void) { return foo() == 0; }
            """,
            define = "HAVE_FUNC_ATTRIBUTE_RETURNS_NONNULL",
        ),
        # GCC __builtin_setjmp probe — used by jit-tramp.c for its
        # signal-safe long-jump implementation.
        checks.AC_TRY_LINK(
            name = "ax_gcc_builtin_setjmp",
            code = """
                int main(void) {
                    void *buf[5];
                    if (__builtin_setjmp(buf) == 0) __builtin_longjmp(buf, 1);
                    return 0;
                }
            """,
            define = "HAVE___BUILTIN_SETJMP",
        ),
        # Unconditional AC_DEFINE_UNQUOTED calls in configure.ac.
        checks.AC_DEFINE("FST_REMOVE_DUPLICATE_VC", 1),
        # Raw subst entry mirroring the PACKAGE_VERSION that
        # `:package` produces as a C string `#define`. Needed because
        # `package_info` only populates `define_results` — text-mode
        # templates (`@PACKAGE_VERSION@` in `nvc_version_template`)
        # need a `subst_results` entry too. Bumping the module's
        # version means changing MODULE.bazel and this line.
        checks.AC_SUBST("PACKAGE_VERSION", "1.21.0"),
        # AX_PTHREAD in configure.ac splits into two real probes here:
        #   HAVE_PTHREAD     — gates `#include <pthread.h>` in util.c
        #                      and similar; spelled `HAVE_PTHREAD`
        #                      rather than the conventional
        #                      `HAVE_PTHREAD_H` because the nvc source
        #                      reads the former name.
        #   HAVE_LIBPTHREAD  — gates the FST parallel writer
        #                      (thirdparty/fstapi.c). AC_CHECK_LIB
        #                      drives a real `-lpthread` link probe.
        checks.AC_CHECK_HEADER(
            "pthread.h",
            define = "HAVE_PTHREAD",
        ),
        checks.AC_CHECK_LIB("pthread", "pthread_create"),
    ] + select({
        ":_linux_x86_64": [checks.AC_DEFINE("HAVE_LIBDW", 1)],
        "//conditions:default": [],
    }) + select({
        ":_debug_enabled": [],
        "//conditions:default": [checks.AC_DEFINE("NDEBUG", 1)],
    }) + select({
        ":_default_paths_enabled": [checks.AC_DEFINE("ENABLE_DEFAULT_PATHS", 1)],
        "//conditions:default": [],
    }) + select({
        ":_llvm_enabled": [
            checks.AC_DEFINE("ENABLE_LLVM", 1),
            checks.AC_DEFINE("HAVE_LLVM", 1),
            # LLVM version-gated feature defines. These come from
            # m4/ax_llvm_c.m4 in the original tree, where they are
            # emitted based on the `llvm-config --version` of the
            # host LLVM. We pin to llvm-project 17.x via MODULE.bazel,
            # so the set is fixed: 17.x >= 100, 110, 120, 130, 150
            # but < 210.
            checks.AC_DEFINE("LLVM_HAVE_DI_SCOPE_GET_FILE", 1),
            checks.AC_DEFINE("LLVM_HAVE_SET_CURRENT_DEBUG_LOCATION_2", 1),
            checks.AC_DEFINE("LLVM_CREATE_CU_HAS_SYSROOT", 1),
            checks.AC_DEFINE("LLVM_HAS_PASS_BUILDER", 1),
            checks.AC_DEFINE("LLVM_HAS_LLJIT", 1),
            checks.AC_DEFINE("LLVM_HAS_OPAQUE_POINTERS", 1),
            checks.AC_DEFINE("LLVM_UWTABLE_HAS_ARGUMENT", 1),
            # String-valued LLVM defines. AC_DEFINE keeps the supplied
            # value verbatim, so the outer single-quotes wrap an inner
            # double-quoted C string literal — matching upstream's
            # `AC_DEFINE_UNQUOTED([LLVM_VERSION], ["$LLVM_VERSION"])`.
            checks.AC_DEFINE(
                "LLVM_VERSION",
                '"{}"'.format(_LLVM_VERSION),
            ),
            checks.AC_DEFINE("LLVM_OBJ_EXT", '"o"'),
            checks.AC_DEFINE("LLVM_CONFIG_BINDIR", '""'),
            # Raw (unquoted) subst entry so the version-test template
            # can interpolate `@LLVM_VERSION@` as `17.0.4` without the
            # surrounding C string quotes the AC_DEFINE above carries.
            checks.AC_SUBST("LLVM_VERSION", _LLVM_VERSION),
        ],
        "//conditions:default": [],
    }) + select({
        ":_tcl_enabled": [checks.AC_DEFINE("ENABLE_TCL", 1)],
        "//conditions:default": [],
    }) + [
        # String-valued path defines. configure.ac normally derives
        # these from --prefix; in the Bazel build the user can fork
        # the BUILD file (or override --//:prefix and the related
        # constants) to point elsewhere. As AC_DEFINEs they ride the
        # same #undef → #define replacement pass that the autoconf
        # check results use — no separate `substitutions` table on
        # autoconf_hdr below.
        checks.AC_DEFINE("DATADIR", '"/usr/local/share/nvc"'),
        checks.AC_DEFINE("DIFF_PATH", '"/usr/bin/diff"'),
        checks.AC_DEFINE("DIR_SEP", '"/"'),
        checks.AC_DEFINE("DLL_EXT", '"so"'),
        checks.AC_DEFINE("EXEEXT", '""'),
        checks.AC_DEFINE("LIBDIR", '"/usr/local/lib/nvc"'),
        checks.AC_DEFINE("LIBEXECDIR", '"/usr/local/libexec/nvc"'),
        checks.AC_DEFINE("PATH_SEP", '":"'),
        checks.AC_DEFINE("PREFIX", '"/usr/local"'),
        checks.AC_DEFINE("SH_PATH", '"/bin/sh"'),
        checks.AC_DEFINE("TARGET_SYSTEM", '"bazel"'),
        checks.AC_DEFINE("TESTDIR", '"test"'),
        # XMLLINT_PATH is used only by the regression test harness, so
        # leaving it #undef matches a configure run where xmllint is
        # absent.
    ],
    deps = [":package"],
)

# ===========================================================================
# config.h generation
#
# Every #undef in config.h.in is now resolved by autoconf_hdr against
# the AC_DEFINE/check results in the autoconf rule above — no manual
# substitutions table is needed.
# ===========================================================================

autoconf_hdr(
    name = "config",
    out = "config.h",
    template = "config.h.in",
    deps = [":autoconf"],
)

cc_library(
    name = "config_hdr",
    hdrs = [":config.h"],
    includes = ["."],
)

# ===========================================================================
# Generated source files
# ===========================================================================

# src/cov/cov-style.h: a single static const char[] of the contents of
# cov-style.css. Upstream uses a sed pipeline; the css_header rule (in
# bazel/css_header.bzl) wraps the same transformation in a C++
# wrapper invoked via ctx.actions.run, so the output is byte-for-byte
# identical with the autotools build.
css_header(
    name = "cov_style_h",
    src = "src/cov/cov-style.css",
    out = "src/cov/cov-style.h",
    varname = "cov_style",
)

# src/gitsha.h: configure.ac emits this only when building from a git
# tree (ENABLE_GIT_SHA). The tarball ships without a .git directory,
# so we use write_file to drop a static stub matching the autoconf
# "release tarball" path — HAVE_GIT_SHA is not defined, but the
# header is referenced unconditionally elsewhere so a stub keeps the
# include resolvable.
write_file(
    name = "gitsha_h",
    out = "src/gitsha.h",
    content = [
        '#define GIT_SHA ""',
        "",
    ],
)

# Flex-generated lexer. Upstream's Makefile.am sets `AM_LFLAGS = -o
# lex.yy.c`; we ask the flex module's rule for a single named output.
# The lexer source uses YY_INPUT / YY_USER_ACTION hooks defined in
# src/scan.h, so the generated .c is compiled as part of :libnvc.
flex(
    name = "lexer_c",
    srcs = ["src/lexer.l"],
    outs = ["src/lexer.c"],
    args = [
        "-o",
        "$(execpath src/lexer.c)",
        "$(execpath src/lexer.l)",
    ],
)

# ===========================================================================
# Header-only target carrying the project-wide include paths
# ===========================================================================

cc_library(
    name = "nvc_headers",
    hdrs = glob([
        "src/*.h",
        "src/cov/*.h",
        "src/jit/*.h",
        "src/mir/*.h",
        "src/psl/*.h",
        "src/rt/*.h",
        "src/sdf/*.h",
        "src/tcl/*.h",
        "src/vhdl/*.h",
        "src/vhpi/*.h",
        "src/vlog/*.h",
        "src/vpi/*.h",
        "thirdparty/*.h",
    ]) + [
        ":cov_style_h",
        ":gitsha_h",
    ],
    includes = [
        ".",
        "src",
        "thirdparty",
    ],
    deps = [":config_hdr"],
)

# ===========================================================================
# Third-party support library
#
# Matches thirdparty/Makemodule.am: fst writer, lz4, fastlz, sha1, the
# parallel JIT cpustate helpers, and the system-verilog RNG. Gnulib
# fallback implementations (memmem / strcasestr / getline / strchrnul
# / strndup) are pulled in only when the corresponding HAVE_* probe
# failed. Most modern Linux systems have these libc functions, but
# the autoconf check above will set HAVE_* and the fallback files
# compile to nothing in that case (their guards key off the HAVE_*
# defines).
# ===========================================================================

cc_library(
    name = "thirdparty",
    srcs = [
        "thirdparty/cpustate.c",
        "thirdparty/fastlz.c",
        "thirdparty/fstapi.c",
        "thirdparty/getdelim.c",
        "thirdparty/getline.c",
        "thirdparty/lz4.c",
        "thirdparty/memmem.c",
        "thirdparty/rawmemchr.c",
        "thirdparty/sha1.c",
        "thirdparty/strcasestr.c",
        "thirdparty/strchrnul.c",
        "thirdparty/strndup.c",
        "thirdparty/svrand.c",
    ],
    hdrs = glob(["thirdparty/*.h"]),
    copts = [
        "-Wno-implicit-function-declaration",
        "-Wno-pointer-sign",
        "-Wno-unused-function",
        "-Wno-unused-variable",
    ] + select({
        "@platforms//cpu:aarch64": ["-march=armv8-a+crypto"],
        "//conditions:default": [],
    }),
    includes = ["thirdparty"],
    deps = [
        ":config_hdr",
        "@zlib",
    ],
)

