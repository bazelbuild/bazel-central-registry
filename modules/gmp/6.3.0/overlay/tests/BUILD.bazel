"""GMP test suite."""

load("@rules_cc//cc:cc_library.bzl", "cc_library")
load("@rules_cc//cc:cc_test.bzl", "cc_test")

_TEST_COPTS = [
    "-D__GMP_WITHIN_GMP",
    "-w",
]

# spinner.c uses isatty(STDOUT_FILENO) which needs MSVC-specific handling:
# - STDOUT_FILENO is not defined (POSIX, from <unistd.h>)
# - isatty() is _isatty() in MSVC's <io.h>
# The spinner is effectively a no-op on Windows (no SIGALRM/alarm support),
# but it still needs to compile.
_TEST_WINDOWS_COPTS = select({
    "@platforms//os:windows": [
        "/DSTDOUT_FILENO=1",
        "/Disatty=_isatty",
        "/FIio.h",
    ],
    "//conditions:default": [],
})

# =============================================================================
# Test support library
# =============================================================================

cc_library(
    name = "libtests",
    testonly = True,
    srcs = [
        "memory.c",
        "misc.c",
        "refmpf.c",
        "refmpn.c",
        "refmpq.c",
        "refmpz.c",
        "spinner.c",
        "trace.c",
    ],
    hdrs = ["tests.h"],
    copts = _TEST_COPTS + _TEST_WINDOWS_COPTS,
    includes = ["."],
    deps = [
        "//:_gmp_hdrs",
        "//:gmp",
    ],
)

# =============================================================================
# Root-level tests
# =============================================================================

[
    cc_test(
        name = test,
        srcs = [test + ".c"],
        copts = _TEST_COPTS,
        deps = [
            ":libtests",
            "//:_gmp_hdrs",
            "//:gmp",
        ],
    )
    for test in [
        "t-bswap",
        "t-constants",
        "t-count_zeros",
        "t-hightomask",
        "t-modlinv",
        "t-popc",
        "t-parity",
        "t-sub",
    ]
]

