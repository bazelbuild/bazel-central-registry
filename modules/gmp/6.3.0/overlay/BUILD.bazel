cc_library(
    name = "gmp",
    srcs = [
        # Root-level core sources
        "assert.c",
        "compat.c",
        "errno.c",
        "extract-dbl.c",
        "invalid.c",
        "memory.c",
        "mp_bpl.c",
        "mp_clz_tab.c",
        "mp_dv_tab.c",
        "mp_get_fns.c",
        "mp_minv_tab.c",
        "mp_set_fns.c",
        "nextprime.c",
        "primesieve.c",
        "tal-reent.c",
        "version.c",
        # Generated sources
        ":gen_fib_table_c",
        ":gen_mp_bases_c",
    ] + glob(
        [
            "mpz/*.c",
            "mpq/*.c",
            "mpf/*.c",
            "printf/*.c",
            "scanf/*.c",
            "rand/*.c",
        ],
    ),
    hdrs = [":gmp_h"],
    copts = _GMP_COPTS,
    includes = ["."],
    textual_hdrs = glob(["mpn/generic/*.c"]) + [
        "mpn/generic/gmp-mparam.h",
        "mpn/generic/hgcd2-div.h",
        "mpz/aors.h",
        "mpz/aors_ui.h",
        "mpz/fits_s.h",
        "mpz/mul_i.h",
        "mpf/fits_s.h",
        "mpf/fits_u.h",
        "rand/randmt.h",
    ],
    visibility = ["//visibility:public"],
    deps = [
        ":_gmp_hdrs",
        ":_mpn",
    ],
)

# MPN function implementations (assembly + generic C).
cc_library(
    name = "_mpn",
    srcs = [":" + fn for fn in _ALL_MPN_FUNCTIONS],
    copts = _GMP_COPTS,
    textual_hdrs = glob(["mpn/generic/*.c"]) + [
        "mpn/generic/gmp-mparam.h",
        "mpn/generic/hgcd2-div.h",
    ],
    deps = [":_gmp_hdrs"],
)

