        ":gen_sieve_table_h",
        ":gmp_h",
        ":gmp_mparam_h",
    ],
    includes = ["."],
    textual_hdrs = [
        ":gen_perfsqr_h",
        ":gen_jacobitab_h",
        ":gen_trialdivtab_h",
    ],
    visibility = ["//tests:__subpackages__"],
)

