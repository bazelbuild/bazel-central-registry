# =============================================================================
# config.m4 (architecture-specific M4 definitions for .asm processing)
# =============================================================================

gmp_config_m4(
    name = "config_m4",
    arch = select({
        "@platforms//cpu:aarch64": "aarch64",
        "@platforms//cpu:arm": "arm",
        "@platforms//cpu:ppc64le": "powerpc64",
        "@platforms//cpu:s390x": "s390_64",
        "@platforms//cpu:x86_64": "x86_64",
        "//conditions:default": "generic",
    }),
    mparam_h = ":gmp_mparam_h",
    os = select({
        "@platforms//os:linux": "linux",
        "@platforms//os:macos": "macos",
        "@platforms//os:windows": "windows",
        "//conditions:default": "linux",
    }),
)

# =============================================================================
# MPN function targets (per-function, architecture-aware)
# =============================================================================

[
    gmp_mpn_m4(
        name = fn,
        arch = _MPN_ARCH,
        asm_srcs = _MPN_ASM_SRCS,
        cpu = ":cpu",
        generic_srcs = _MPN_GENERIC_SRCS,
        m4_deps = _MPN_M4_DEPS,
        operation = fn,
        os = _MPN_OS,
    )
    for fn in _ALL_MPN_FUNCTIONS
]

