# =============================================================================
# Internal headers (private, used by all GMP sources)
# =============================================================================

cc_library(
    name = "_gmp_hdrs",
    hdrs = [
        "asl.h",
        "gmp-impl.h",
        "longlong.h",
        ":config_h",
        ":gen_fac_table_h",
        ":gen_fib_table_h",
        ":gen_mp_bases_h",
        ":gen_sieve_table_h",
        ":gmp_h",
        ":gmp_mparam_h",
    ],
    includes = ["."],
    textual_hdrs = [
        ":gen_perfsqr_h",
        ":gen_jacobitab_h",
        ":gen_trialdivtab_h",
    ],
    visibility = ["//tests:__subpackages__"],
)

# =============================================================================
# Multi-function MPN wrappers (compiled as part of gmp, see srcs below)
# =============================================================================

_GMP_COPTS = [
    "-D__GMP_WITHIN_GMP",
    "-w",
]

_MPN_MULTI_SRCS = \
    gmp_mpn_multi(
        name = "logops",
        src = "mpn/generic/logops_n.c",
        operations = [
            "and_n",
            "andn_n",
            "nand_n",
            "ior_n",
            "iorn_n",
            "nior_n",
            "xor_n",
            "xnor_n",
        ],
    ) + gmp_mpn_multi(
        name = "popham",
        src = "mpn/generic/popham.c",
        operations = [
            "popcount",
            "hamdist",
        ],
    ) + gmp_mpn_multi(
        name = "sec_aors_1",
        src = "mpn/generic/sec_aors_1.c",
        operations = [
            "sec_add_1",
            "sec_sub_1",
        ],
    ) + gmp_mpn_multi(
        name = "sec_div",
        src = "mpn/generic/sec_div.c",
        operations = [
            "sec_div_qr",
            "sec_div_r",
        ],
    ) + gmp_mpn_multi(
        name = "sec_pi1_div",
        src = "mpn/generic/sec_pi1_div.c",
        operations = [
            "sec_pi1_div_qr",
            "sec_pi1_div_r",
        ],
    )

# =============================================================================
# libgmp
# =============================================================================

alias(
    name = "libgmp",
    actual = ":gmp",
    visibility = ["//visibility:public"],
)

cc_library(
    name = "gmp",
    srcs = [
        # Root-level core sources
        "assert.c",
        "compat.c",
        "errno.c",
        "extract-dbl.c",
        "invalid.c",
        "memory.c",
        "mp_bpl.c",
        "mp_clz_tab.c",
        "mp_dv_tab.c",
        "mp_get_fns.c",
        "mp_minv_tab.c",
        "mp_set_fns.c",
        "nextprime.c",
        "primesieve.c",
        "tal-reent.c",
        "version.c",
        # Generated sources
        ":gen_fib_table_c",
        ":gen_mp_bases_c",
    ] + _MPN_MULTI_SRCS + glob(
        [
            "mpn/generic/*.c",
            "mpz/*.c",
            "mpq/*.c",
            "mpf/*.c",
            "printf/*.c",
            "scanf/*.c",
            "rand/*.c",
        ],
        exclude = [
            # Multi-function files handled above
            "mpn/generic/logops_n.c",
            "mpn/generic/popham.c",
            "mpn/generic/sec_aors_1.c",
            "mpn/generic/sec_div.c",
            "mpn/generic/sec_pi1_div.c",
            # Optional/arch-specific files not in core generic build
            "mpn/generic/udiv_w_sdiv.c",
            "mpn/generic/add_n_sub_n.c",
            "mpn/generic/div_qr_1n_pi2.c",
            "mpn/generic/div_qr_1u_pi2.c",
        ],
    ),
    hdrs = [":gmp_h"],
    copts = _GMP_COPTS,
    includes = ["."],
    textual_hdrs = [
        "mpn/generic/gmp-mparam.h",
        "mpn/generic/hgcd2-div.h",
        # Multi-function sources included by generated wrappers
        "mpn/generic/logops_n.c",
        "mpn/generic/popham.c",
        "mpn/generic/sec_aors_1.c",
        "mpn/generic/sec_div.c",
        "mpn/generic/sec_pi1_div.c",
        "mpz/aors.h",
        "mpz/aors_ui.h",
        "mpz/fits_s.h",
        "mpz/mul_i.h",
        "mpf/fits_s.h",
        "mpf/fits_u.h",
        "rand/randmt.h",
    ],
    visibility = ["//visibility:public"],
    deps = [":_gmp_hdrs"],
)

# =============================================================================
# libgmpxx (C++ wrapper)
# =============================================================================

alias(
    name = "libgmpxx",
    actual = ":gmpxx",
    visibility = ["//visibility:public"],
)

cc_library(
    name = "gmpxx",
    srcs = glob(
        ["cxx/*.cc"],
        exclude = ["cxx/dummy.cc"],
    ),
    hdrs = ["gmpxx.h"],
    copts = [
        "-D__GMP_WITHIN_GMP",
        "-D__GMP_WITHIN_GMPXX",
        "-w",
    ],
    includes = ["."],
    visibility = ["//visibility:public"],
    deps = [
        ":_gmp_hdrs",
        ":gmp",
    ],
)
