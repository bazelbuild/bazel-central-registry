# libgmpxx (C++ wrapper)
# =============================================================================

alias(
    name = "libgmpxx",
    actual = ":gmpxx",
    visibility = ["//visibility:public"],
)

cc_library(
    name = "gmpxx",
    srcs = glob(
        ["cxx/*.cc"],
        exclude = ["cxx/dummy.cc"],
    ),
    hdrs = ["gmpxx.h"],
    copts = [
        "-D__GMP_WITHIN_GMP",
        "-D__GMP_WITHIN_GMPXX",
        "-w",
    ],
    includes = ["."],
    visibility = ["//visibility:public"],
    deps = [
        ":_gmp_hdrs",
        ":gmp",
    ],
)
