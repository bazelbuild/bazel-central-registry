--- CMake/unix_config.cmake
+++ CMake/unix_config.cmake
@@ -18,7 +18,16 @@ macro(os_set_flags)
     set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -pedantic -Wno-missing-field-initializers")
     set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -Wno-switch -Wno-multichar -Wsequence-point -Wformat -Wformat-security")

-    execute_process(COMMAND ${CMAKE_C_COMPILER} -dumpmachine OUTPUT_VARIABLE MACHINE)
+    # Probe -dumpmachine only for native builds. The bazel cc_wrapper.sh forwards
+    # args to clang without injecting --target=, so on a cross-compile from
+    # arm64-darwin -dumpmachine reports arm64-apple-darwin instead of the bazel
+    # target triple, mis-detecting arch. Use CMAKE_SYSTEM_PROCESSOR (set by the
+    # cross toolchain file) when available.
+    if(CMAKE_SYSTEM_PROCESSOR)
+        set(MACHINE "${CMAKE_SYSTEM_PROCESSOR}-")
+    else()
+        execute_process(COMMAND ${CMAKE_C_COMPILER} -dumpmachine OUTPUT_VARIABLE MACHINE)
+    endif()
     if(${MACHINE} MATCHES "arm64-*" OR ${MACHINE} MATCHES "aarch64-*")
         set(CMAKE_C_FLAGS   "${CMAKE_C_FLAGS}   -mstrict-align -ftree-vectorize")
         set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -mstrict-align -ftree-vectorize")
