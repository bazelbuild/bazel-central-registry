diff -urN orig/.bazelrc new/.bazelrc
--- orig/.bazelrc	2026-05-12 22:05:05.536726491 -0700
+++ new/.bazelrc	2026-05-12 22:05:05.544518483 -0700
@@ -6,7 +6,10 @@
 # Prevent incompatible versions of MODULE.bazel and MODULE.bazel.lock from being committed.
 # If you update MODULE.bazel, always re-run `bazel mod deps --lockfile_mode=update` and commit
 # the resulting MODULE.bazel.lock alongside your MODULE.bazel changes.
-common --lockfile_mode=error
+# The BCR test matrix spans multiple Bazel versions and platforms, so do not
+# consume a checked-in MODULE.bazel.lock here. Resolve modules per-build
+# instead of enforcing a repository-generated lockfile.
+common --lockfile_mode=off
 
 test --test_verbose_timeout_warnings
 # End of best practice options for Bazel
