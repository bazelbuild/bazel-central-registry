load("@rules_foreign_cc//foreign_cc:defs.bzl", "meson")

package(default_visibility = ["//visibility:public"])

filegroup(
    name = "all_srcs",
    srcs = glob(["**"]),
)

meson(
    name = "fribidi",
    lib_source = ":all_srcs",
    options = {
        "default_library": "static",
        "bin": "false",
        "docs": "false",
        "includedir": "include",
        "libdir": "lib",
        "tests": "false",
    },
    out_static_libs = ["libfribidi.a"],
)
