Always include <mutex>, <condition_variable>, and <thread> in
kernel/threading.h so the work-steal queue (introduced in v0.64)
builds even when YOSYS_ENABLE_THREADS is not defined. The work-steal
code uses std::unique_lock unconditionally; the existing guard meant
gcc 13+ failed with "std::unique_lock is not a member of std" on
non-threaded builds (ubuntu 22.04/24.04/debian13 BCR presubmit).

diff --git a/kernel/threading.h b/kernel/threading.h
--- a/kernel/threading.h
+++ b/kernel/threading.h
@@ -1,9 +1,7 @@
 #include <deque>

-#ifdef YOSYS_ENABLE_THREADS
 #include <condition_variable>
 #include <mutex>
 #include <thread>
-#endif

 #include "kernel/yosys_common.h"
