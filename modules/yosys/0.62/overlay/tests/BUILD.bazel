load("@rules_cc//cc:cc_test.bzl", "cc_test")
load(":ys_test.bzl", "yosys_ys_tests")

# Comprehensive C++ test binary for yosys functionality using Google Test
cc_test(
    name = "yosys_binary_test",
    size = "small",
    srcs = ["yosys_binary_test.cc"],
    data = ["@yosys"],
    env = {"YOSYS": "$(rlocationpath @yosys)"},
    deps = [
        "@googletest//:gtest",
        "@googletest//:gtest_main",
        "@rules_cc//cc/runfiles",
    ],
)

# .ys script regression tests — one sh_test per script file.

yosys_ys_tests(
    data = glob(
        ["opt/*"],
        exclude = ["opt/*.ys"],
    ),
    ys_files = glob(
        ["opt/*.ys"],
        exclude = [
            "opt/opt_lut.ys",  # synth_ice40 cmd not linked
        ],
    ),
)

yosys_ys_tests(
    data = glob(
        ["proc/*"],
        exclude = ["proc/*.ys"],
    ),
    ys_files = glob(["proc/*.ys"]),
)

yosys_ys_tests(
    data = glob(
        ["various/*"],
        exclude = ["various/*.ys"],
    ),
    ys_files = glob(
        ["various/*.ys"],
        exclude = [
            "various/stat.ys",  # Reads file with relative path that doesnt exit is bazel
            "various/stat_hierarchy.ys",  # Reads file with relative path that doesnt exit is bazel
            "various/check.ys",  # read command old?
            "various/check_2.ys",  # read command old?
            "various/check_3.ys",  # read command old?
            "various/check_4.ys",  # read command old?
            "various/hierarchy_defer.ys",  # read command
            "various/dynamic_part_select.ys",  # data file missing
            "various/celledges_shift.ys",  # test_cell cmd not there
            "various/bug4865.ys",  # ice40_dsp command not implemented
            "various/ice40_mince_abc9.ys",  # ice40_dsp command not implemented
            "various/aiger2.ys",  # read_aiger2 cmd not linked
        ],
    ),
)

yosys_ys_tests(
    data = glob(
        ["verilog/*"],
        exclude = ["verilog/*.ys"],
    ),
    ys_files = glob(["verilog/*.ys"]),
)

yosys_ys_tests(
    data = glob(
        ["techmap/*"],
        exclude = ["techmap/*.ys"],
    ),
    ys_files = glob(
        ["techmap/*.ys"],
        exclude = [
            "techmap/xaiger2-5169.ys",  # write_aiger2 cmd not linked
            "techmap/booth.ys",  # test_cell cmd not linked
        ],
    ),
)

yosys_ys_tests(
    data = glob(
        ["select/*"],
        exclude = ["select/*.ys"],
    ),
    ys_files = glob(
        ["select/*.ys"],
        exclude = [
            "select/no_warn_prefixed_arg_memb.ys",  # data file missing
        ],
    ),
)

yosys_ys_tests(
    data = glob(
        ["rtlil/*"],
        exclude = ["rtlil/*.ys"],
    ),
    ys_files = glob(["rtlil/*.ys"]),
)
