        checks.AC_TRY_LINK(
            name = "patch_cv_func_memrchr",
            code = """\
#define _GNU_SOURCE 1
#include <string.h>
int main(void) { (void)memrchr; return 0; }
""",
        ),
        checks.AC_SUBST(
            "COMPILE_MEMRCHR",
            condition = "!patch_cv_func_memrchr",
        ),

        # getrandom: missing on older macOS
        checks.AC_TRY_LINK(
            name = "patch_cv_func_getrandom",
            code = """\
