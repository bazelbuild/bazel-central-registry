    name = "patch",
    srcs = [
        "src/inp.c",
        "src/merge.c",
        "src/patch.c",
        "src/pch.c",
        "src/safe.c",
        "src/util.c",
        "src/version.c",
    ] + glob(["src/*.h"]),
