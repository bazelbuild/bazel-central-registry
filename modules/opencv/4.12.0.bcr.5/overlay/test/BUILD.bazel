load("@bazel_skylib//lib:dicts.bzl", "dicts")
load("@rules_cc//cc:cc_test.bzl", "cc_test")
load("@rules_qt//:qt.bzl", "LINUX_ENV_DATA", "qt_plugin_data")

cc_test(
    name = "qt6_smoke_test",
    srcs = ["qt6_smoke_test.cpp"],
    data = qt_plugin_data,
    env = dicts.add(LINUX_ENV_DATA, {"QT_QPA_PLATFORM": "offscreen"}),
    target_compatible_with = ["@platforms//os:linux"],
    deps = [
        "@opencv//:core",
        "@opencv//:highgui",
    ],
)
