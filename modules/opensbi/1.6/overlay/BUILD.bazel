# The generic platform glue.
opensbi_library(
    name = "generic",
    srcs = [
        "platform/generic/allwinner/sun20i-d1.c",
        "platform/generic/andes/ae350.c",
        "platform/generic/andes/andes_pma.c",
        "platform/generic/andes/andes_pmu.c",
