load(
    "@rules_opensbi//build/opensbi:rules.bzl",
    "opensbi_firmware",
    "opensbi_library",
)

package(default_visibility = ["//visibility:public"])

# All headers needed to compile any OpenSBI translation unit.
filegroup(
    name = "headers",
    srcs = glob([
        "include/**",
        "lib/utils/libfdt/*.h",
        "platform/generic/include/**",
    ]),
)

# Firmware entry sources and linker scripts (reused by downstream firmwares).
exports_files(glob([
    "firmware/*.S",
    "firmware/*.ldS",
    "config/generic/autoconf.h",
]))

