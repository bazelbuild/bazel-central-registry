        "platform/generic/andes/sleep.S",
        "platform/generic/platform.c",
        "platform/generic/platform_override_modules.carray.c",
        "platform/generic/renesas/rzfive/rzfive.c",
        "platform/generic/sifive/fu540.c",
        "platform/generic/sifive/fu740.c",
        "platform/generic/sophgo/sg2042.c",
        "platform/generic/starfive/jh7110.c",
        "platform/generic/thead/thead-generic.c",
        "platform/generic/thead/thead_c9xx_errata_tlb_flush.c",
        "platform/generic/thead/thead_c9xx_pmu.c",
        "platform/generic/thead/thead_c9xx_tlb_trap_handler.S",
    ],
    hdrs = [":headers"],
    includes = ["platform/generic/include"],
    deps = [":sbiutils"],
)

# Firmware images for the generic platform.
[
    opensbi_firmware(
        name = "fw_" + t,
        fw_src = "firmware/fw_" + t + ".S",
        fw_type = t,
        lib = ":generic",
        linker_script = "firmware/fw_" + t + ".elf.ldS",
        textual_hdrs = [
            "firmware/fw_base.S",
            "firmware/fw_base.ldS",
        ],
    )
    for t in [
        "dynamic",
        "jump",
    ]
]
