/* Minimal internal OpenBLAS build configuration for TARGET=GENERIC.
 * Generated via cmake_configure_file instead of OpenBLAS's own
 * getarch/Makefile.system probing, since the Bazel build fixes the
 * target to the portable, assembly-free GENERIC kernel set. */

#cmakedefine OS_LINUX
#cmakedefine OS_DARWIN
#cmakedefine ARCH_X86_64
#cmakedefine ARCH_ARM64
#cmakedefine C_GCC
#cmakedefine C_CLANG

#define __64BIT__		1
#define FUNDERSCORE		_
#define BUNDERSCORE		_
#define NEEDBUNDERSCORE		1
#define PTHREAD_CREATE_FUNC	pthread_create

#define GENERIC
#define CORE_generic
#define CHAR_CORENAME		"generic"

#define L1_DATA_SIZE		32768
#define L1_DATA_LINESIZE	128
#define L2_SIZE			512488
#define L2_LINESIZE		128
#define DTB_DEFAULT_ENTRIES	128
#define DTB_SIZE		4096
#define L2_ASSOCIATIVE		8
#define GEMM_MULTITHREAD_THRESHOLD	4
