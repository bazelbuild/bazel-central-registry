    "lib/error.h": "lib/error.in.h",
    "lib/fcntl.h": "lib/fcntl.in.h",
    "lib/getopt-cdefs.h": "lib/getopt-cdefs.in.h",
    "lib/inttypes.h": "lib/inttypes.in.h",
    "lib/langinfo.h": "lib/langinfo.in.h",
    "lib/locale.h": "lib/locale.in.h",
    "lib/selinux/context.h": "lib/se-context.in.h",
    "lib/selinux/label.h": "lib/se-label.in.h",
    "lib/selinux/selinux.h": "lib/se-selinux.in.h",
    "lib/stdio.h": "lib/stdio.in.h",
    "lib/stdlib.h": "lib/stdlib.in.h",
    "lib/string.h": "lib/string.in.h",
    "lib/sys/random.h": "lib/sys_random.in.h",
    "lib/sys/stat.h": "lib/sys_stat.in.h",
    "lib/time.h": "lib/time.in.h",
    "lib/uchar.h": "lib/uchar.in.h",
    "lib/unicase.h": "lib/unicase.in.h",
    "lib/unictype.h": "lib/unictype.in.h",
    "lib/uninorm.h": "lib/uninorm.in.h",
    "lib/unistd.h": "lib/unistd.in.h",
    "lib/unitypes.h": "lib/unitypes.in.h",
    "lib/wchar.h": "lib/wchar.in.h",
    "lib/wctype.h": "lib/wctype.in.h",
}

# Conditionally-generated headers: gnulib's m4 modules decide whether the
# system header needs shadowing via GL_GENERATE_<HDR>_H.  Wired through
# cc_gnulib_conditional_hdrs below; gate-true -> shadow on include path,
# gate-false -> falls through to system header.
CONDITIONAL_GENERATED_HDRS = {
    "lib/alloca.h": "lib/alloca.in.h",
    "lib/getopt.h": "lib/getopt.in.h",
    "lib/limits.h": "lib/limits.in.h",
    "lib/obstack.h": "lib/obstack.in.h",
    "lib/stdckdint.h": "lib/stdckdint.in.h",
    "lib/stdcountof.h": "lib/stdcountof.in.h",
    "lib/stddef.h": "lib/stddef.in.h",
}

# Generated into an isolated output dir (kept off the lib/ include path)
# so MSVC never sees them; :lib_hdrs_nonmsvc re-exposes them only on
# non-MSVC toolchains.
#
# lib/stdint.h: macOS gnulib needs UINTPTR_WIDTH for lib/rawmemchr.c, but
# MSVC mis-parses gnulib's stdint template (bare `.`, mismatched #if/#endif)
# even though m4/stdint sets HAVE_C99_STDINT_H=1 to skip the main body.
NONMSVC_GENERATED_HDRS = {
    "stdint.h": "lib/stdint.in.h",
}

# Fallbacks for @VAR@ markers gnulib leaves unset because their m4 module
# only sets them when the system header is incomplete.  Values match
# gnulib's Makefile.am defaults.
DEFAULT_SUBSTITUTIONS = {
    "@HAVE_LANGINFO_T_FMT_AMPM@": "1",
    "@HAVE_LANGINFO_YESEXPR@": "1",
}

# The inlines/mode/substitutions/deps quartet below is identical across
# the three lib/*.in.h -> *.h substitution loops (lib/, _cond_hdrs/,
# nonmsvc_hdrs/).  BUILD files disallow `def` / `**kwargs` so the block
# is repeated rather than factored.
[
    autoconf_hdr(
        name = hdr[:-len(".h")].replace("/", "_") + "_h",
        out = hdr,
        defaults = True,
        inlines = {
            "/* The definition of _GL_ARG_NONNULL is copied here.  */": "lib/arg-nonnull.h",
            "/* The definition of _GL_WARN_ON_USE is copied here.  */": "lib/warn-on-use.h",
            "/* The definitions of _GL_FUNCDECL_RPL etc. are copied here.  */": "lib/c++defs.h",
        },
        mode = "subst",
        substitutions = DEFAULT_SUBSTITUTIONS,
        template = template,
        deps = [":configure_ac"],
    )
    for hdr, template in GENERATED_HDRS.items()
]

# Generated into _cond_hdrs/ so the intermediate is never directly on the
# include path; cc_gnulib_conditional_hdrs below decides per-header whether
# to expose the shadow under lib/ or let the system header take over.
[
    autoconf_hdr(
        name = "_cond_" + hdr[:-len(".h")].replace("/", "_") + "_h",
        out = "_cond_hdrs/" + hdr,
        defaults = True,
        inlines = {
            "/* The definition of _GL_ARG_NONNULL is copied here.  */": "lib/arg-nonnull.h",
            "/* The definition of _GL_WARN_ON_USE is copied here.  */": "lib/warn-on-use.h",
            "/* The definitions of _GL_FUNCDECL_RPL etc. are copied here.  */": "lib/c++defs.h",
        },
        mode = "subst",
        substitutions = DEFAULT_SUBSTITUTIONS,
        template = template,
        deps = [":configure_ac"],
    )
    for hdr, template in CONDITIONAL_GENERATED_HDRS.items()
]

cc_gnulib_conditional_hdrs(
    name = "conditional_hdrs",
    hdrs = {
        # GL_GENERATE_<NAME>_H gate derived from each header path; matches
        # the upstream gnulib m4 modules that own these conditional headers.
        ":_cond_" + hdr[:-len(".h")].replace("/", "_") + "_h": "GL_GENERATE_{}_H".format(hdr[len("lib/"):-len(".h")].upper())
        for hdr in CONDITIONAL_GENERATED_HDRS.keys()
    },
    deps = [":configure_ac"],
)

# GL_COND_OBJ_<X>-gated sources from lib/gnulib.mk.  autoconf_srcs wraps
# each .c in `#ifdef <CONDITION>` so the TU is a no-op when the autoconf
# check says the system version suffices.  Conditions referencing
# REPLACE_<X> or USES_MSVCRT (unexported by rules_cc_autoconf 0.13.2) are
# approximated; see comments per entry.  These also remain omitted entirely:
#   iswdigit.c, iswpunct.c, iswxdigit.c, localeconv.c, pthread-once.c,
#   stdio-consolesafe.c, strncpy.c -- all evaluate false in stock gnulib's
#   configure on our target platforms, so omission matches upstream.
CONDITIONAL_SRC_CONDS = {
    "lib/fseterr.c": "HAVE___FSETERR==0",
    # Drops the REPLACE_ISWCNTRL branch; remainder is "no iswcntrl AND no
    # iswblank", which never happens on Linux/macOS.
    "lib/iswblank.c": "HAVE_ISWCNTRL==1&&HAVE_ISWBLANK==0",
    "lib/iswctype.c": "HAVE_WCTYPE_T==0||GNULIBHEADERS_OVERRIDE_WINT_T==1",
    "lib/strtoimax.c": "HAVE_DECL_STRTOIMAX==0||REPLACE_STRTOIMAX==1",
    "lib/strtoll.c": "HAVE_STRTOLL==0||REPLACE_STRTOLL==1",
    # Drops REPLACE_WCTYPE branch; HAVE_WCTYPE==0 covers the common case.
    "lib/wctype.c": "HAVE_WCTYPE==0",
}

autoconf_srcs(
    name = "conditional_srcs",
    srcs = CONDITIONAL_SRC_CONDS,
    deps = [":configure_ac"],
)

# Generate NONMSVC_GENERATED_HDRS into the isolated `nonmsvc_hdrs/` output
# directory.  The action runs unconditionally and the file is fine on disk;
# only the cc_library that re-exposes that directory is conditional.
[
    autoconf_hdr(
        name = "nonmsvc_" + hdr[:-len(".h")].replace("/", "_") + "_h",
        out = "nonmsvc_hdrs/" + hdr,
        defaults = True,
        inlines = {
            "/* The definition of _GL_ARG_NONNULL is copied here.  */": "lib/arg-nonnull.h",
            "/* The definition of _GL_WARN_ON_USE is copied here.  */": "lib/warn-on-use.h",
            "/* The definitions of _GL_FUNCDECL_RPL etc. are copied here.  */": "lib/c++defs.h",
        },
        mode = "subst",
        substitutions = DEFAULT_SUBSTITUTIONS,
        template = template,
        deps = [":configure_ac"],
    )
    for hdr, template in NONMSVC_GENERATED_HDRS.items()
]

cc_library(
    name = "lib_hdrs_nonmsvc",
    hdrs = [":nonmsvc_" + hdr[:-len(".h")].replace("/", "_") + "_h" for hdr in NONMSVC_GENERATED_HDRS.keys()],
    includes = ["nonmsvc_hdrs"],
)

# Gnulib renames a few headers so they can be re-included with different
# macros active; contents are unchanged.
[
    copy_file(
        name = name,
        src = src,
        out = out,
    )
    for name, src, out in [
        ("dynarray_skeleton_gl_h", "lib/malloc/dynarray-skeleton.c", "lib/malloc/dynarray-skeleton.gl.h"),
        ("dynarray_gl_h", "lib/malloc/dynarray.h", "lib/malloc/dynarray.gl.h"),
        ("scratch_buffer_gl_h", "lib/malloc/scratch_buffer.h", "lib/malloc/scratch_buffer.gl.h"),
    ]
]

# lib/static_assert.h is sed's alternate spelling of gnulib's _GL_VERIFY.
expand_template(
    name = "static_assert_h",
    out = "lib/static_assert.h",
    substitutions = {
        "_GL_VERIFY": "_GL_STATIC_ASSERT",
        "_gl_verify": "_gl_static_assert",
    },
    template = "lib/verify.h",
)

GENERATED_HDR_LABELS = [":" + hdr[:-len(".h")].replace("/", "_") + "_h" for hdr in GENERATED_HDRS.keys()]

ALL_GENERATED_HDRS = [
