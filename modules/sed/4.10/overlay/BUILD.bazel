    },
    module_bazel = "MODULE.bazel",
    package_bugreport = "bug-sed@gnu.org",
    package_url = "https://www.gnu.org/software/sed/",
    strip_bcr_version = True,
)

# m4 modules not provided by @rules_cc_autoconf//gnulib/m4 (excluded from the
# auto-mapped GNULIB_M4_DEPS below and handled inline).
SED_UNIQUE_M4_FILES = [
    "m4/gnulib-comp.m4",
    # memeq/streq are C2y proposals new in sed-4.10's gnulib; no upstream module yet.
    "m4/memeq.m4",
    "m4/streq.m4",
    "m4/wchar_t.m4",
    "m4/year2038.m4",
    # Locally overridden -- see m4_c32rtomb below for the rationale.
    "m4/c32rtomb.m4",
]

GNULIB_M4_DEPS = [
    "@rules_cc_autoconf//gnulib/m4/{}".format(file[len("m4/"):-len(".m4")])
    for file in glob(
        include = ["m4/*.m4"],
        exclude = SED_UNIQUE_M4_FILES,
    )
]

autoconf(
    name = "m4_wchar_t",
    checks = [
        checks.AC_TRY_COMPILE(
            name = "gt_cv_c_wchar_t",
            code = "#include <stddef.h>\nwchar_t foo = (wchar_t)'\\0';\nint main(void) { return 0; }\n",
        ),
        checks.AC_DEFINE(
            "HAVE_WCHAR_T",
            1,
            requires = ["gt_cv_c_wchar_t"],
        ),
    ],
)

# year2038: guarantees 64-bit time_t.  Mingw needs an opt-in macro; everywhere
# else modern time_t is the default.
autoconf(
    name = "m4_year2038",
    checks = select({
        "@platforms//os:windows": [
            checks.AC_DEFINE("__MINGW_USE_VC2005_COMPAT", 1),
        ],
        "//conditions:default": [],
    }),
)

autoconf(
    name = "m4_memeq",
    checks = [checks.AC_CHECK_DECL(
        "memeq",
        define = "HAVE_DECL_MEMEQ",
        includes = ["string.h"],
    )],
)

autoconf(
    name = "m4_streq",
    checks = [checks.AC_CHECK_DECL(
        "streq",
        define = "HAVE_DECL_STREQ",
        includes = ["string.h"],
    )],
)

# Upstream's gl_CHECK_FUNC_C32RTOMB probes c32rtomb at the autoconf toolchain's
# own compile flags rather than the consumer's; on macOS, libSystem's <uchar.h>
# hides the c32rtomb prototype unless a feature-test macro is set that
# -std=gnu11 doesn't activate, so the probe says "available" but sed's TU
# can't see the decl.  We sidestep the probe and pin HAVE_C32RTOMB from
# platform knowledge: Linux glibc has it; macOS at gnu11 doesn't expose the
# decl; MSVC has no <uchar.h> at all.  Other substs/cache vars come from the
# toolchain defaults + mbrtoc32's transitive :gl_C32RTOMB_SANITYCHECK dep.
autoconf(
    name = "m4_c32rtomb",
    checks = select({
        "@platforms//os:linux": [
            checks.AC_SUBST("HAVE_C32RTOMB", 1),
        ],
        "//conditions:default": [
            checks.AC_SUBST("HAVE_C32RTOMB", 0),
        ],
    }),
)

