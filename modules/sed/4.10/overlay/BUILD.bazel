)

# lib/*.in.h templates that always need @VAR@ substitution plus inline
# expansion of the gnulib helper headers (_GL_ARG_NONNULL, _GL_WARN_ON_USE,
# etc.).  The replacement chains through #include_next to the system header
# and exists only to expose gnulib's GNULIB_X function-indicator macros, so
# it's additive and safe to always shadow.  Several headers are deliberately
# omitted:
#   * errno.h, assert.h -- gnulib only ships a replacement when the system
#     version is incomplete.
#   * sys/types.h -- gnulib's template needs Windows typedefs (ino_t,
#     nlink_t) that rules_cc_autoconf doesn't populate.
#   * stdint.h -- routed through NONMSVC_GENERATED_HDRS below because MSVC
#     mis-parses gnulib's template even when its main body is gated out.
GENERATED_HDRS = {
    "lib/ctype.h": "lib/ctype.in.h",
    "lib/dirent.h": "lib/dirent.in.h",
    # Required on MSVC where the SDK has no <error.h>; copy-acl.c includes it
