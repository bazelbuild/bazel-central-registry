    "//conditions:default": [
        "-w",
        "-std=gnu11",
    ],
})

LOCAL_DEFINES = [
    "HAVE_CONFIG_H",
    # Seven gnulib lib/*.c files use bare C11 `static_assert` without
    # `#include <assert.h>`; surface the keyword mapping directly so config.h
    # doesn't need to gate on HAVE_C_STATIC_ASSERT (autoconf detects support
    # so the gate stays at 1 and config.h's define doesn't fire).
    "static_assert=_Static_assert",
] + select({
    # sed/compile.c calls C23 `unreachable()` directly; gnulib's stddef.h
    # polyfill is gated on HAVE_C_UNREACHABLE which rules_cc_autoconf's
    # macOS probe sets to 1 (probe uses C23, sed compiles at gnu11), so the
    # polyfill never fires.  Map onto the compiler builtin instead.
    "@rules_cc//cc/compiler:msvc-cl": [
        "unreachable()=__assume(0)",
        # lib/setlocale_null.c hardcodes a __declspec(dllimport) extern for
        # gl_get_setlocale_null_lock, but the static-link build of
        # setlocale-lock.c has no matching dllexport.  AVOID_ANY_THREADS
        # collapses the locking branch before that extern is seen.
        "AVOID_ANY_THREADS=1",
    ],
    "//conditions:default": [
        "unreachable=__builtin_unreachable",
    ],
})

