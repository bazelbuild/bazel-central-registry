# Aggregates every gnulib m4 module + sed-specific defines from configure.ac.
autoconf(
    name = "configure_ac",
    checks = [
        checks.AC_DEFINE("GNULIB_NO_VLA", 1),
        # gnulib derives this from PACKAGE_NAME via gnulib-common.m4 shell
        # macros; sed expects "GL".
        checks.AC_SUBST("GUARD_PREFIX", "GL"),
        # The other AC_CHECK_HEADERS_ONCE(locale.h errno.h wchar.h wctype.h)
        # entries are handled by their dedicated gnulib m4 modules.
        checks.AC_CHECK_HEADER(
            "mcheck.h",
            define = "HAVE_MCHECK_H",
        ),
        # The remaining AC_CHECK_FUNCS_ONCE entries (isatty/memcpy/strtoul/
        # readlink/popen/setlocale/wcscoll) come from gnulib m4 modules.
    ] + macros.AC_CHECK_FUNCS([
        "isascii",
        "strchr",
        "pathconf",
        "fchown",
        "fchmod",
    ]) + [
        checks.AC_DEFINE("LOCALEDIR", '"/usr/share/locale"'),
    ] + select({
        # AC_CACHE_CHECK([whether "rt" can be used with fopen]) is a runtime
        # check; assume yes on cygwin/mingw, no elsewhere.
        "@platforms//os:windows": [
            checks.AC_DEFINE("HAVE_FOPEN_RT", 1),
        ],
        "//conditions:default": [],
    }) + select({
        ":i18n_disabled": [
            checks.AC_SUBST("ac_cv_func_wcscoll", "no"),
        ],
        "//conditions:default": [],
    }),
    deps = [
        ":sed_package_info",
    ] + SED_UNIQUE_AUTOCONF_TARGETS + GNULIB_M4_DEPS,
)

autoconf_hdr(
