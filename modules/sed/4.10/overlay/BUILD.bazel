[
    [
        write_file(
            name = "behavior_{}_golden".format(name),
            out = "behavior_{}_golden.txt".format(name),
            content = spec["golden"],
            newline = "unix",
        ),
        genrule(
            name = "behavior_{}_output".format(name),
            srcs = [":browning_input"],
            outs = ["behavior_{}_output.txt".format(name)],
            cmd = "$(execpath :sed) {extra} '{expr}' $(SRCS) > $@".format(
                expr = spec["expr"],
                extra = spec.get("extra_flags", ""),
            ),
            # cmd_bat goes through cmd.exe instead of msys2 bash so that
            # scripts starting with `/` (e.g. `/Browning/p`) don't get
            # rewritten to Windows paths; double-quote because cmd.exe
            # doesn't strip single quotes.  --binary keeps sed.exe's
            # stdin/stdout in binary mode so `> $@` doesn't CRLF-translate
            # the output relative to the unix-newline golden.
            cmd_bat = '$(execpath :sed) --binary {extra} "{expr}" $(SRCS) > $@'.format(
                expr = spec["expr"],
                extra = spec.get("extra_flags", ""),
            ),
            tools = [":sed"],
        ),
        diff_test(
            name = "behavior_{}_test".format(name),
            file1 = "behavior_{}_output.txt".format(name),
            file2 = "behavior_{}_golden.txt".format(name),
        ),
    ]
    for name, spec in SED_BEHAVIOR_TESTS.items()
]
