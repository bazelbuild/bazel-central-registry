    hdrs = PUBLIC_HDRS,
    copts = COPTS,
    # lib_hdrs is implementation_deps so the gnulib lib/*.h replacements
    # don't leak to consumers (see BCR#7642 -- transitive lib/stdio.h can
    # mis-order vs. system headers under stricter compilers like clang-21).
    implementation_deps = [":lib_hdrs"],
    include_prefix = "sed",
    linkopts = select({
        # lib/getrandom.c uses CryptAcquireContextA / CryptGenRandom from
        # Advapi32.lib, which MSVC doesn't link by default.
        "@rules_cc//cc/compiler:msvc-cl": ["/DEFAULTLIB:advapi32.lib"],
        "//conditions:default": [],
    }),
    local_defines = LOCAL_DEFINES,
    strip_include_prefix = "lib",
    visibility = ["//visibility:public"],
)

alias(
    name = "libsed",
    actual = ":lib/sed",
    visibility = ["//visibility:public"],
)

write_file(
    name = "version_h",
    out = "sed/version.h",
    content = [
        "extern char const *Version;",
        "",
    ],
    newline = "unix",
)

write_file(
    name = "version_c_template",
    out = "sed/version.in.c",
    content = [
        "#include \"config.h\"",
        "char const *Version = @PACKAGE_VERSION@;",
        "",
    ],
    newline = "unix",
)

# PACKAGE_VERSION comes from :sed_package_info (via :configure_ac), which
# reads MODULE.bazel.  Keeps the version single-sourced from the module.
autoconf_hdr(
    name = "version_c",
    out = "sed/version.c",
    mode = "subst",
    template = ":version_c_template",
    deps = [":configure_ac"],
)

cc_binary(
    name = "bin/sed",
    srcs = [
        "basicdefs.h",
        "sed/compile.c",
        "sed/debug.c",
        "sed/execute.c",
        "sed/mbcs.c",
        "sed/regexp.c",
        "sed/sed.c",
        "sed/sed.h",
        "sed/utils.c",
        "sed/utils.h",
        "sed/version.c",
        "sed/version.h",
    ],
    copts = COPTS,
    includes = [
        ".",
        "sed",
    ],
    local_defines = LOCAL_DEFINES + [
        # bindtextdomain() arguments; AC_INIT exports PACKAGE and configure
        # sets LOCALEDIR from --datarootdir.
        "PACKAGE=\\\"sed\\\"",
        "LOCALEDIR=\\\"/usr/share/locale\\\"",
    ],
    visibility = ["//visibility:public"],
    # sed/utils.h needs _GL_ATTRIBUTE_FORMAT_PRINTF_STANDARD from
    # lib/stdio.h, which :libsed exposes only as implementation_deps;
    # re-list lib_hdrs here so the binary can see it.
    deps = [
        ":lib_hdrs",
        ":libsed",
    ],
)

# Legacy alias
alias(
    name = "sed_bin",
    actual = ":bin/sed",
    visibility = ["//visibility:public"],
)

alias(
    name = "sed",
    actual = ":bin/sed",
    visibility = ["//visibility:public"],
)

