load("@bazel_skylib//rules:write_file.bzl", "write_file")
load("@bazel_skylib//rules:diff_test.bzl", "diff_test")

write_file(
    name = "test_input",
    out = "test_input.txt",
    content = [
        "Hello LLVM",
        "Testing hermetic toolchain",
        "",
    ],
    newline = "unix",
)

write_file(
    name = "test_golden",
    out = "test_golden.txt",
    content = [
        "Hello Clang",
        "Testing hermetic toolchain",
        "",
    ],
    newline = "unix",
)

genrule(
    name = "sed_llvm_test_output",
    srcs = ["test_input.txt"],
    outs = ["test_output.txt"],
    cmd = "$(execpath @sed//:sed) 's/LLVM/Clang/g' $(execpath :test_input.txt) > $@",
    cmd_bat = "$(execpath @sed//:sed) \"s/LLVM/Clang/g\" $(execpath :test_input.txt) > $@",
    tools = ["@sed//:sed"],
)

diff_test(
    name = "llvm_toolchain_regression_test",
    file1 = "test_output.txt",
    file2 = "test_golden.txt",
)
