"""Regression test for sed with LLVM hermetic toolchain"""

module(
    name = "test_sed_llvm",
    version = "0.0.0",
)

bazel_dep(name = "sed", version = "4.9.bcr.4")
local_path_override(
    module_name = "sed",
    path = "..",
)

bazel_dep(name = "bazel_skylib", version = "1.9.0")

# Enable LLVM hermetic toolchain
bazel_dep(name = "llvm", version = "0.6.7")

llvm_toolchain = use_extension("@llvm//extensions:toolchain.bzl", "toolchain")
use_repo(llvm_toolchain, "llvm_toolchains")

register_toolchains("@llvm_toolchains//:all")
