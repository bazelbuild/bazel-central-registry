Drop the `_LIBC` gate on `#undef memchr` in vendored gnulib so the
polyfill survives glibc 2.43+'s `_Generic` wrapper in <string.h>.
Drop when upstream gnulib lands an unconditional undef.

--- a/lib/memchr.c	2022-07-02 20:22:03.000000000 +0200
+++ b/lib/memchr.c	2026-05-27 10:17:01.526657631 +0200
@@ -46,9 +46,7 @@
 #endif
 
 #undef __memchr
-#ifdef _LIBC
-# undef memchr
-#endif
+#undef memchr
 
 #ifndef weak_alias
 # define __memchr memchr
